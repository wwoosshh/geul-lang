(*
 * 어셈블리생성기.글 - 글IR → x86-64 MASM 어셈블리 생성
 *
 * C 의존성 제거를 위한 네이티브 백엔드.
 * 파이프라인: .글 → AST → 글IR → x86-64 asm → ml64.exe → link.exe → .exe
 *
 * 스택 기반 코드 생성 (모든 임시변수를 스택에 배치)
 * Windows x64 호출 규약 준수
 *)

포함 "구문분석기.글"
포함 "IR변환기.글"

(* ===== 문자열 상수 풀 ===== *)
정수 최대어셈문자열수 = 4096.
문자열[4096] 어셈문자열풀.
정수 어셈문자열수 = 0.

(* ===== 스택 오프셋 표 ===== *)
(* 임시변수 인덱스 → rbp 기준 음수 오프셋 *)
정수[32768] 임시오프셋.

(* ===== 호출 인자 버퍼 (중첩 보호) ===== *)
정수[64] 어셈인자목록.
정수 어셈인자수 = 0.
정수[256] 어셈인자저장.
정수[16] 어셈인자수저장.
정수 어셈저장깊이 = 0.

(* ===== 네이티브 모드 플래그 ===== *)
(* 1이면 ExitProcess 사용하는 독립 실행 파일용 어셈블리 생성 *)
정수 네이티브모드 = 0.

(* 현재 생성 중인 함수가 main인지 추적 *)
정수 현재생성_메인 = 0.

(* ===== 전역 변수 이름 목록 ===== *)
문자열[512] 전역변수이름풀.
정수 전역변수수 = 0.

(* ===== 함수 이름 맹글링 (한글→ASCII) ===== *)
문자열[512] 맹글링원본풀.
문자열[512] 맹글링결과풀.
정수 맹글링수 = 0.
문자[16384] 맹글링버퍼.
정수 맹글링버퍼위치 = 0.

[문자열 이름을 어셈함수맹글링]은 → 문자열 {
    문자열_비교(이름, "시작하기") == 0이면 { 반환 "main". }
    (* 기존 맹글링 검색 *)
    정수 번호 = 0.
    (번호 < 맹글링수)동안 {
        문자열_비교(이름, 맹글링원본풀[번호]) == 0이면 {
            반환 맹글링결과풀[번호].
        }
        번호++다.
    }
    (* 새 맹글링 생성: _fn0, _fn1, ... *)
    맹글링원본풀[맹글링수] = 이름.
    문자열 결과는 맹글링버퍼 + 맹글링버퍼위치.
    버퍼에_쓰기(결과, 32, "_fn%d", 맹글링수).
    맹글링버퍼위치 = 맹글링버퍼위치 + 글자수(결과) + 1.
    맹글링결과풀[맹글링수] = 결과.
    맹글링수++다.
    반환 결과.
}

(* 호출 대상 함수 이름 맹글링 — 외부 C 함수는 그대로 *)
[문자열 이름을 어셈호출맹글링]은 → 문자열 {
    (* 매크로 치환 — 정의된 이름이면 치환 후 재시도 *)
    문자열 치환됨은 이름을 매크로치환다.
    치환됨 != 이름이면 { 이름 = 치환됨. }
    문자열_비교(이름, "시작하기") == 0이면 { 반환 "main". }
    (* C 표준 함수는 그대로 *)
    문자열_비교(이름, "printf") == 0이면 { 반환 "printf". }
    문자열_비교(이름, "malloc") == 0이면 { 반환 "malloc". }
    문자열_비교(이름, "free") == 0이면 { 반환 "free". }
    문자열_비교(이름, "exit") == 0이면 { 반환 "exit". }
    문자열_비교(이름, "strcmp") == 0이면 { 반환 "strcmp". }
    문자열_비교(이름, "strlen") == 0이면 { 반환 "strlen". }
    문자열_비교(이름, "atoi") == 0이면 { 반환 "atoi". }
    문자열_비교(이름, "fopen") == 0이면 { 반환 "fopen". }
    문자열_비교(이름, "fclose") == 0이면 { 반환 "fclose". }
    문자열_비교(이름, "fread") == 0이면 { 반환 "fread". }
    (* 한글 함수 → 맹글링 *)
    반환 이름을 어셈함수맹글링다.
}

(* ===== 문자열 이스케이프 처리용 논리 레이블 카운터 ===== *)
정수 논리레이블번호 = 0.

(* ===== 유틸리티 ===== *)

(* 문자열 상수 등록 — 중복 검사 후 인덱스 반환 *)
[문자열 값을 어셈문자열등록]은 → 정수 {
    정수 번호 = 0.
    (번호 < 어셈문자열수)동안 {
        문자열_비교(값, 어셈문자열풀[번호]) == 0이면 {
            반환 번호.
        }
        번호++다.
    }
    어셈문자열수 < 최대어셈문자열수이면 {
        어셈문자열풀[어셈문자열수] = 값.
        어셈문자열수++다.
    }
    반환 어셈문자열수 - 1.
}

(* 피연산자를 스택 슬롯에서 레지스터로 적재 *)
[정수 임시번호를 문자열 레지스터로 어셈적재]는 {
    임시번호 < 0이면 { 반환. }
    정수 종류 = 임시변수종류풀[임시번호].
    (* 전역 변수는 심볼 이름으로 접근 *)
    종류 == 2이면 {
        "    mov %s, QWORD PTR [%s]\n"을 레지스터를 임시변수이름풀[임시번호]를 쓰기다.
        반환.
    }
    정수 오프셋 = 임시오프셋[임시번호].
    "    mov %s, QWORD PTR [rbp-%d]\n"을 레지스터를 오프셋을 쓰기다.
}

(* 레지스터 값을 스택 슬롯에 저장 *)
[문자열 레지스터를 정수 임시번호를 어셈저장]은 {
    임시번호 < 0이면 { 반환. }
    정수 종류 = 임시변수종류풀[임시번호].
    종류 == 2이면 {
        "    mov QWORD PTR [%s], %s\n"을 임시변수이름풀[임시번호]를 레지스터를 쓰기다.
        반환.
    }
    정수 오프셋 = 임시오프셋[임시번호].
    "    mov QWORD PTR [rbp-%d], %s\n"을 오프셋을 레지스터를 쓰기다.
}

(* ===== 문자열 상수 사전 수집 ===== *)
(* 모든 함수의 IR을 스캔하여 문자열 상수를 수집 *)
[어셈문자열사전수집]은 {
    어셈문자열수 = 0.
    정수 번호 = 0.
    (번호 < 명령총수)동안 {
        (명령종류풀[번호] == 명령_상수문자열)이면 {
            명령문자열값풀[번호] != 0이면 {
                어셈문자열등록(명령문자열값풀[번호]).
            }
        }
        번호++다.
    }
}

(* 문자열을 MASM DB 바이트열로 출력 *)
(* 예: "hello\n" → 'h','e','l','l','o',10,0 *)
[문자열 값을 어셈문자열바이트출력]은 {
    값 == 0이면 { "    DB 0\n"을 쓰기다. 반환. }
    정수 길이는 글자수(값).
    (* 따옴표 제거: 첫/끝 " *)
    정수 시작 = 0.
    정수 끝은 길이.
    (길이 > 0) * (값[0] == 34)이면 { 시작 = 1. }
    (끝 > 시작) * (값[끝 - 1] == 34)이면 { 끝 = 끝 - 1. }

    "    DB "를 쓰기다.
    정수 위치는 시작.
    정수 첫항목 = 1.
    (위치 < 끝)동안 {
        정수 현재바이트는 값[위치].
        (* 이스케이프 시퀀스 처리 *)
        (현재바이트 == 92) * (위치 + 1 < 끝)이면 {
            정수 다음바이트는 값[위치 + 1].
            첫항목 == 0이면 { ","를 쓰기다. }
            (다음바이트 == 110)이면 {
                "10"을 쓰기다.  (* \n *)
            }
            아니면 (다음바이트 == 116)이면 {
                "9"를 쓰기다.   (* \t *)
            }
            아니면 (다음바이트 == 48)이면 {
                "0"을 쓰기다.   (* \0 *)
            }
            아니면 (다음바이트 == 34)이면 {
                "34"를 쓰기다.  (* \" *)
            }
            아니면 (다음바이트 == 92)이면 {
                "92"를 쓰기다.  (* \\ *)
            }
            아니면 {
                "%d"를 다음바이트를 쓰기다.
            }
            첫항목 = 0.
            위치 = 위치 + 2.
        }
        아니면 {
            첫항목 == 0이면 { ","를 쓰기다. }
            (* 일반 문자 — ASCII 인쇄 범위이면 문자, 아니면 부호없는 바이트 *)
            (현재바이트 >= 32) * (현재바이트 < 127)이면 {
                "'%c'"를 현재바이트를 쓰기다.
            }
            아니면 {
                (* 부호 있는 char → 부호 없는 바이트 변환 *)
                정수 부호없는값은 현재바이트.
                부호없는값 < 0이면 {
                    부호없는값 = 부호없는값 + 256.
                }
                "%d"를 부호없는값을 쓰기다.
            }
            첫항목 = 0.
            위치++다.
        }
    }
    (* 널 종단 *)
    첫항목 == 0이면 { ","를 쓰기다. }
    "0\n"을 쓰기다.
}

(* ===== 프레임 크기 계산 ===== *)

[정수 함수번호를 어셈프레임계산]은 → 정수 {
    정수 임시시작 = 중간함수임시시작풀[함수번호].
    정수 임시수 = 중간함수임시수풀[함수번호].

    (* 각 임시변수에 슬롯 할당 — 묶음이면 크기만큼, 아니면 8바이트 *)
    정수 현재오프셋 = 8.  (* rbp-8부터 시작 *)
    정수 번호 = 0.
    (번호 < 임시수)동안 {
        정수 인덱스 = 임시시작 + 번호.
        정수 종류 = 임시변수종류풀[인덱스].
        (* 전역(2)은 스택 할당 안 함 *)
        종류 != 2이면 {
            정수 슬롯크기 = 8.
            정수 묶음크기 = 임시변수크기풀[인덱스].
            묶음크기 > 8이면 {
                슬롯크기 = 묶음크기.
            }
            임시오프셋[인덱스] = 현재오프셋.
            현재오프셋 = 현재오프셋 + 슬롯크기.
        }
        번호++다.
    }

    (* 호출용 공간: 최소 32바이트 섀도 + 추가 인자 *)
    정수 최대인자 = 4.
    정수 명령시작 = 중간함수명령시작풀[함수번호].
    정수 명령수 = 중간함수명령수풀[함수번호].
    번호 = 0.
    (번호 < 명령수)동안 {
        정수 인덱스 = 명령시작 + 번호.
        (명령종류풀[인덱스] == 명령_호출)이면 {
            정수 인자개수 = 명령인자1풀[인덱스].
            인자개수 > 최대인자이면 {
                최대인자 = 인자개수.
            }
        }
        번호++다.
    }
    정수 호출공간 = 최대인자 * 8.
    호출공간 < 32이면 { 호출공간 = 32. }

    정수 총크기는 현재오프셋 + 호출공간.
    (* 16바이트 정렬 *)
    (총크기 % 16) != 0이면 {
        총크기 = 총크기 + (16 - (총크기 % 16)).
    }
    반환 총크기.
}

(* ===== 단일 IR 명령어 → asm ===== *)

[정수 명령인덱스를 어셈명령생성]은 {
    정수 종류 = 명령종류풀[명령인덱스].
    정수 결과 = 명령결과풀[명령인덱스].
    정수 인자1 = 명령인자1풀[명령인덱스].
    정수 인자1종류 = 명령인자1종류풀[명령인덱스].
    정수 인자2 = 명령인자2풀[명령인덱스].
    정수 인자2종류 = 명령인자2종류풀[명령인덱스].

    (* 레이블 *)
    (종류 == 명령_레이블)이면 {
        "__L%d:\n"을 인자1을 쓰기다.
        반환.
    }

    (* 인자전달 — 버퍼에 수집 *)
    (종류 == 명령_인자전달)이면 {
        (인자2 == 0) * (어셈인자수 > 0)이면 {
            정수 저장번호 = 0.
            정수 저장시작 = 어셈저장깊이 * 16.
            (저장번호 < 어셈인자수) * (저장번호 < 16)동안 {
                어셈인자저장[저장시작 + 저장번호] = 어셈인자목록[저장번호].
                저장번호++다.
            }
            어셈인자수저장[어셈저장깊이] = 어셈인자수.
            어셈저장깊이++다.
            어셈인자수 = 0.
        }
        인자2 < 64이면 {
            어셈인자목록[인자2] = 인자1.
            (인자2 >= 어셈인자수)이면 {
                어셈인자수 = 인자2 + 1.
            }
        }
        반환.
    }

    (* 상수 정수 *)
    (종류 == 명령_상수정수)이면 {
        긴정수 값은 명령정수값풀[명령인덱스].
        "    mov QWORD PTR [rbp-%d], %lld\n"을 임시오프셋[결과]를 값을 쓰기다.
        반환.
    }

    (* 상수 문자열 *)
    (종류 == 명령_상수문자열)이면 {
        문자열 값은 명령문자열값풀[명령인덱스].
        정수 문자열번호는 어셈문자열등록(값).
        "    lea rax, __str%d\n"을 문자열번호를 쓰기다.
        "rax"를 결과를 어셈저장다.
        반환.
    }

    (* 복사 *)
    (종류 == 명령_복사)이면 {
        인자1을 "r10"으로 어셈적재다.
        "r10"을 결과를 어셈저장다.
        반환.
    }

    (* 이항 산술: 더하기, 빼기 *)
    (종류 == 명령_더하기)이면 {
        인자1을 "r10"으로 어셈적재다.
        인자2를 "r11"로 어셈적재다.
        "    add r10, r11\n"을 쓰기다.
        "r10"을 결과를 어셈저장다.
        반환.
    }

    (종류 == 명령_빼기)이면 {
        인자1을 "r10"으로 어셈적재다.
        인자2를 "r11"로 어셈적재다.
        "    sub r10, r11\n"을 쓰기다.
        "r10"을 결과를 어셈저장다.
        반환.
    }

    (종류 == 명령_곱하기)이면 {
        인자1을 "rax"로 어셈적재다.
        인자2를 "r11"로 어셈적재다.
        "    imul rax, r11\n"을 쓰기다.
        "rax"를 결과를 어셈저장다.
        반환.
    }

    (종류 == 명령_나누기)이면 {
        인자1을 "rax"로 어셈적재다.
        "    cqo\n"을 쓰기다.
        인자2를 "r11"로 어셈적재다.
        "    idiv r11\n"을 쓰기다.
        "rax"를 결과를 어셈저장다.
        반환.
    }

    (종류 == 명령_나머지)이면 {
        인자1을 "rax"로 어셈적재다.
        "    cqo\n"을 쓰기다.
        인자2를 "r11"로 어셈적재다.
        "    idiv r11\n"을 쓰기다.
        "rdx"를 결과를 어셈저장다.
        반환.
    }

    (* 비교 *)
    (종류 == 명령_같음) + (종류 == 명령_다름) + (종류 == 명령_큼) + (종류 == 명령_작음) + (종류 == 명령_크거나같음) + (종류 == 명령_작거나같음) > 0이면 {
        인자1을 "r10"으로 어셈적재다.
        인자2를 "r11"로 어셈적재다.
        "    cmp r10, r11\n"을 쓰기다.
        (종류 == 명령_같음)이면       { "    sete al\n"을 쓰기다. }
        (종류 == 명령_다름)이면       { "    setne al\n"을 쓰기다. }
        (종류 == 명령_큼)이면         { "    setg al\n"을 쓰기다. }
        (종류 == 명령_작음)이면       { "    setl al\n"을 쓰기다. }
        (종류 == 명령_크거나같음)이면 { "    setge al\n"을 쓰기다. }
        (종류 == 명령_작거나같음)이면 { "    setle al\n"을 쓰기다. }
        "    movzx r10, al\n"을 쓰기다.
        "r10"을 결과를 어셈저장다.
        반환.
    }

    (* 논리곱 *)
    (종류 == 명령_논리곱)이면 {
        정수 거짓라벨 = 논리레이블번호.
        정수 끝라벨 = 논리레이블번호 + 1.
        논리레이블번호 = 논리레이블번호 + 2.
        인자1을 "r10"으로 어셈적재다.
        "    test r10, r10\n"을 쓰기다.
        "    jz __LL%d\n"을 거짓라벨을 쓰기다.
        인자2를 "r10"으로 어셈적재다.
        "    test r10, r10\n"을 쓰기다.
        "    jz __LL%d\n"을 거짓라벨을 쓰기다.
        "    mov r10, 1\n"을 쓰기다.
        "    jmp __LL%d\n"을 끝라벨을 쓰기다.
        "__LL%d:\n"을 거짓라벨을 쓰기다.
        "    xor r10, r10\n"을 쓰기다.
        "__LL%d:\n"을 끝라벨을 쓰기다.
        "r10"을 결과를 어셈저장다.
        반환.
    }

    (* 논리합 *)
    (종류 == 명령_논리합)이면 {
        정수 참라벨 = 논리레이블번호.
        정수 끝라벨 = 논리레이블번호 + 1.
        논리레이블번호 = 논리레이블번호 + 2.
        인자1을 "r10"으로 어셈적재다.
        "    test r10, r10\n"을 쓰기다.
        "    jnz __LL%d\n"을 참라벨을 쓰기다.
        인자2를 "r10"으로 어셈적재다.
        "    test r10, r10\n"을 쓰기다.
        "    jnz __LL%d\n"을 참라벨을 쓰기다.
        "    xor r10, r10\n"을 쓰기다.
        "    jmp __LL%d\n"을 끝라벨을 쓰기다.
        "__LL%d:\n"을 참라벨을 쓰기다.
        "    mov r10, 1\n"을 쓰기다.
        "__LL%d:\n"을 끝라벨을 쓰기다.
        "r10"을 결과를 어셈저장다.
        반환.
    }

    (* 논리부정 *)
    (종류 == 명령_논리부정)이면 {
        인자1을 "r10"으로 어셈적재다.
        "    test r10, r10\n"을 쓰기다.
        "    sete al\n"을 쓰기다.
        "    movzx r10, al\n"을 쓰기다.
        "r10"을 결과를 어셈저장다.
        반환.
    }

    (* 비트 연산 *)
    (종류 == 명령_비트와)이면 {
        인자1을 "r10"으로 어셈적재다.
        인자2를 "r11"로 어셈적재다.
        "    and r10, r11\n"을 쓰기다.
        "r10"을 결과를 어셈저장다.
        반환.
    }
    (종류 == 명령_비트또는)이면 {
        인자1을 "r10"으로 어셈적재다.
        인자2를 "r11"로 어셈적재다.
        "    or r10, r11\n"을 쓰기다.
        "r10"을 결과를 어셈저장다.
        반환.
    }
    (종류 == 명령_비트배타)이면 {
        인자1을 "r10"으로 어셈적재다.
        인자2를 "r11"로 어셈적재다.
        "    xor r10, r11\n"을 쓰기다.
        "r10"을 결과를 어셈저장다.
        반환.
    }
    (종류 == 명령_비트부정)이면 {
        인자1을 "r10"으로 어셈적재다.
        "    not r10\n"을 쓰기다.
        "r10"을 결과를 어셈저장다.
        반환.
    }
    (종류 == 명령_왼쪽이동)이면 {
        인자1을 "r10"으로 어셈적재다.
        인자2를 "rcx"로 어셈적재다.
        "    shl r10, cl\n"을 쓰기다.
        "r10"을 결과를 어셈저장다.
        반환.
    }
    (종류 == 명령_오른쪽이동)이면 {
        인자1을 "r10"으로 어셈적재다.
        인자2를 "rcx"로 어셈적재다.
        "    sar r10, cl\n"을 쓰기다.
        "r10"을 결과를 어셈저장다.
        반환.
    }

    (* 부호반전 *)
    (종류 == 명령_부호반전)이면 {
        인자1을 "r10"으로 어셈적재다.
        "    neg r10\n"을 쓰기다.
        "r10"을 결과를 어셈저장다.
        반환.
    }

    (* 증가/감소 *)
    (종류 == 명령_증가)이면 {
        인자1을 "r10"으로 어셈적재다.
        "r10"을 결과를 어셈저장다.   (* 후위: 먼저 저장 *)
        "    inc r10\n"을 쓰기다.
        "r10"을 인자1을 어셈저장다.   (* 원래 변수 갱신 *)
        반환.
    }
    (종류 == 명령_감소)이면 {
        인자1을 "r10"으로 어셈적재다.
        "r10"을 결과를 어셈저장다.
        "    dec r10\n"을 쓰기다.
        "r10"을 인자1을 어셈저장다.
        반환.
    }

    (* 무조건 이동 *)
    (종류 == 명령_이동)이면 {
        "    jmp __L%d\n"을 인자1을 쓰기다.
        반환.
    }

    (* 조건분기 *)
    (종류 == 명령_조건분기)이면 {
        인자1을 "r10"으로 어셈적재다.
        "    test r10, r10\n"을 쓰기다.
        "    jnz __L%d\n"을 인자2를 쓰기다.
        "    jmp __L%d\n"을 명령타입풀[명령인덱스]을 쓰기다.
        반환.
    }

    (* 반환 *)
    (종류 == 명령_반환)이면 {
        인자1 >= 0이면 {
            인자1을 "rax"로 어셈적재다.
        }
        (* 네이티브 모드에서 main 함수는 ExitProcess 호출 *)
        (네이티브모드 != 0) * (현재생성_메인 != 0)이면 {
            "    mov rcx, rax\n"을 쓰기다.
            "    call ExitProcess\n"을 쓰기다.
        }
        아니면 {
            "    leave\n"을 쓰기다.
            "    ret\n"을 쓰기다.
        }
        반환.
    }

    (* 함수 호출 — Windows x64 ABI *)
    (종류 == 명령_호출)이면 {
        정수 인자개수 = 인자1.
        문자열 함수이름은 명령이름풀[명령인덱스].
        함수이름 == 0이면 { 함수이름 = "???". }

        (* 인자를 레지스터/스택에 배치 *)
        정수 번호 = 0.
        (번호 < 인자개수)동안 {
            어셈인자목록[번호]를 "r10"으로 어셈적재다.
            (번호 == 0)이면 { "    mov rcx, r10\n"을 쓰기다. }
            (번호 == 1)이면 { "    mov rdx, r10\n"을 쓰기다. }
            (번호 == 2)이면 { "    mov r8, r10\n"을 쓰기다. }
            (번호 == 3)이면 { "    mov r9, r10\n"을 쓰기다. }
            번호 > 3이면 {
                "    mov QWORD PTR [rsp+%d], r10\n"을 (번호 * 8)을 쓰기다.
            }
            번호++다.
        }

        문자열 호출이름은 함수이름을 어셈호출맹글링다.
        "    call %s\n"을 호출이름을 쓰기다.

        결과 >= 0이면 {
            "rax"를 결과를 어셈저장다.
        }

        (* 중첩 호출 복원 *)
        어셈인자수 = 0.
        어셈저장깊이 > 0이면 {
            어셈저장깊이--다.
            어셈인자수 = 어셈인자수저장[어셈저장깊이].
            정수 복원번호 = 0.
            정수 복원시작 = 어셈저장깊이 * 16.
            (복원번호 < 어셈인자수)동안 {
                어셈인자목록[복원번호] = 어셈인자저장[복원시작 + 복원번호].
                복원번호++다.
            }
        }
        반환.
    }

    (* 적재 *)
    (종류 == 명령_적재)이면 {
        인자1을 "r10"으로 어셈적재다.
        "r10"을 결과를 어셈저장다.
        반환.
    }

    (* 저장 *)
    (종류 == 명령_저장)이면 {
        인자2를 "r10"으로 어셈적재다.
        "r10"을 인자1을 어셈저장다.
        반환.
    }

    (* 주소 *)
    (종류 == 명령_주소)이면 {
        정수 오프셋 = 임시오프셋[인자1].
        "    lea r10, [rbp-%d]\n"을 오프셋을 쓰기다.
        "r10"을 결과를 어셈저장다.
        반환.
    }

    (* 필드 적재: 결과 = 구조체.필드 *)
    (* 명령타입풀: 0=직접(스택 묶음, LEA), 1=화살표(포인터, 값 로드) *)
    (종류 == 명령_필드적재)이면 {
        정수 화살표여부 = 명령타입풀[명령인덱스].
        화살표여부 == 1이면 {
            인자1을 "r10"으로 어셈적재다.
        }
        아니면 {
            정수 구조체오프셋 = 임시오프셋[인자1].
            "    lea r10, [rbp-%d]\n"을 구조체오프셋을 쓰기다.
        }
        정수 필드오프셋 = 명령정수값풀[명령인덱스].
        필드오프셋 > 0이면 {
            "    add r10, %d\n"를 필드오프셋을 쓰기다.
        }
        "    mov r10, [r10]\n"을 쓰기다.
        "r10"을 결과를 어셈저장다.
        반환.
    }

    (* 필드 저장: 구조체.필드 = 값 *)
    (* 명령타입풀: 0=직접(스택 묶음, LEA), 1=화살표(포인터, 값 로드) *)
    (종류 == 명령_필드저장)이면 {
        정수 화살표여부2 = 명령타입풀[명령인덱스].
        화살표여부2 == 1이면 {
            인자1을 "r10"으로 어셈적재다.
        }
        아니면 {
            정수 구조체오프셋2 = 임시오프셋[인자1].
            "    lea r10, [rbp-%d]\n"을 구조체오프셋2를 쓰기다.
        }
        정수 필드오프셋2 = 명령정수값풀[명령인덱스].
        필드오프셋2 > 0이면 {
            "    add r10, %d\n"를 필드오프셋2를 쓰기다.
        }
        인자2를 "r11"으로 어셈적재다.
        "    mov [r10], r11\n"을 쓰기다.
        반환.
    }

    (* 할당 — 프레임 계산에서 이미 처리됨 *)
    (종류 == 명령_할당)이면 { 반환. }
    (종류 == 명령_없음)이면 { 반환. }

    (* 미구현 명령 *)
    "    ; TODO: IR 명령 %d\n"을 종류를 쓰기다.
}

(* ===== 함수 어셈블리 생성 ===== *)

[정수 함수번호를 어셈함수생성]은 {
    문자열 이름 = 중간함수이름풀[함수번호].
    정수 원본노드 = 중간함수원본노드풀[함수번호].

    (* 외부 선언은 건너뜀 *)
    원본노드 >= 0이면 {
        (노드플래그풀[원본노드] & 1)이면 { 반환. }
    }

    (* 함수 이름 맹글링 *)
    문자열 어셈이름은 이름을 어셈함수맹글링다.

    (* 프레임 크기 계산 *)
    정수 프레임크기는 함수번호를 어셈프레임계산다.

    (* 프롤로그 *)
    "%s PROC\n"을 어셈이름을 쓰기다.
    "    push rbp\n"을 쓰기다.
    "    mov rbp, rsp\n"을 쓰기다.
    "    sub rsp, %d\n"을 프레임크기를 쓰기다.

    (* 매개변수를 스택에 저장 *)
    정수 매개수 = 중간함수매개수풀[함수번호].
    정수 임시시작 = 중간함수임시시작풀[함수번호].
    정수 매개번호 = 0.
    (매개번호 < 매개수)동안 {
        정수 매개인덱스 = 임시시작 + 매개번호.
        정수 오프셋 = 임시오프셋[매개인덱스].
        (매개번호 == 0)이면 { "    mov QWORD PTR [rbp-%d], rcx\n"을 오프셋을 쓰기다. }
        (매개번호 == 1)이면 { "    mov QWORD PTR [rbp-%d], rdx\n"을 오프셋을 쓰기다. }
        (매개번호 == 2)이면 { "    mov QWORD PTR [rbp-%d], r8\n"을 오프셋을 쓰기다. }
        (매개번호 == 3)이면 { "    mov QWORD PTR [rbp-%d], r9\n"을 오프셋을 쓰기다. }
        매개번호++다.
    }

    (* 현재 함수가 main인지 추적 *)
    현재생성_메인 = 0.
    문자열_비교(어셈이름, "main") == 0이면 {
        현재생성_메인 = 1.
    }

    (* 명령어 생성 *)
    정수 명령시작 = 중간함수명령시작풀[함수번호].
    정수 명령수 = 중간함수명령수풀[함수번호].
    어셈인자수 = 0.
    어셈저장깊이 = 0.
    정수 번호 = 0.
    (번호 < 명령수)동안 {
        (명령시작 + 번호)를 어셈명령생성다.
        번호++다.
    }

    (* main 함수는 기본 반환 추가 *)
    문자열_비교(어셈이름, "main") == 0이면 {
        "    xor eax, eax\n"을 쓰기다.
        (* 네이티브 모드에서는 ExitProcess 호출 *)
        네이티브모드 != 0이면 {
            "    mov rcx, rax\n"을 쓰기다.
            "    call ExitProcess\n"을 쓰기다.
        }
        아니면 {
            "    leave\n"을 쓰기다.
            "    ret\n"을 쓰기다.
        }
    }

    "%s ENDP\n\n"을 어셈이름을 쓰기다.
}

(* ===== 전체 프로그램 어셈블리 생성 ===== *)

[정수 구문루트를 어셈프로그램생성]은 {
    어셈문자열수 = 0.
    논리레이블번호 = 0.
    전역변수수 = 0.
    맹글링수 = 0.
    맹글링버퍼위치 = 0.

    (* 1. 문자열 상수 사전 수집 *)
    어셈문자열사전수집().

    (* 2. 헤더 *)
    "; 글 컴파일러 x86-64 어셈블리 백엔드 생성\n"을 쓰기다.
    "option casemap:none\n\n"을 쓰기다.

    (* 3. 외부 심볼 선언 *)
    네이티브모드 != 0이면 {
        "extrn ExitProcess : proc\n"을 쓰기다.
        "extrn printf : proc\n"을 쓰기다.
        "extrn malloc : proc\n"을 쓰기다.
        "extrn free : proc\n"을 쓰기다.
    }
    아니면 {
        "EXTRN printf:PROC\n"을 쓰기다.
        "EXTRN malloc:PROC\n"을 쓰기다.
        "EXTRN free:PROC\n"을 쓰기다.
        "EXTRN exit:PROC\n"을 쓰기다.
        "EXTRN strcmp:PROC\n"을 쓰기다.
        "EXTRN strlen:PROC\n"을 쓰기다.
    }
    "\n"을 쓰기다.

    (* 4. 문자열 상수 섹션 *)
    ".const\n"을 쓰기다.
    정수 번호 = 0.
    (번호 < 어셈문자열수)동안 {
        "__str%d "를 번호를 쓰기다.
        어셈문자열풀[번호]를 어셈문자열바이트출력다.
        번호++다.
    }
    "\n"을 쓰기다.

    (* 5. 전역 변수 섹션 *)
    ".data\n"을 쓰기다.
    정수 시작 = 노드목록시작풀[구문루트].
    정수 수 = 노드목록수풀[구문루트].
    번호 = 0.
    (번호 < 수)동안 {
        정수 선언 = 목록항목풀[시작 + 번호].
        (노드종류풀[선언] == 노드_변수선언)이면 {
            문자열 변수이름은 노드이름풀[선언].
            "%s DQ 0\n"을 변수이름을 쓰기다.
        }
        번호++다.
    }
    "\n"을 쓰기다.

    (* 6. 코드 섹션 *)
    ".code\n\n"을 쓰기다.

    (* 7. 함수 생성 *)
    번호 = 0.
    (번호 < 중간함수총수)동안 {
        번호를 어셈함수생성다.
        번호++다.
    }

    (* 8. 종료 *)
    "END\n"을 쓰기다.
}
