(*
 * IR변환기.글 - AST → 글IR 변환
 *
 * AST 노드를 순회하며 3-주소 코드(TAC) IR 명령으로 변환한다.
 * 표현식은 재귀적으로 하위 노드를 먼저 변환하고,
 * 결과 임시변수 번호를 반환한다.
 *)

포함 "중간표현.글"

(* ===== 배열 크기 계산 헬퍼 ===== *)
[정수 배열타입노드를 배열원소크기결정]은 → 정수 {
    정수 원소타입 = 노드왼쪽풀[배열타입노드].
    (원소타입 >= 0) * (노드종류풀[원소타입] == 노드_기본타입) > 0이면 {
        (노드연산자풀[원소타입] == 종류_문자)이면 {
            반환 1.
        }
    }
    반환 8.
}

[정수 배열타입노드를 배열총크기계산]은 → 정수 {
    정수 원소수 = 노드정수풀[배열타입노드].
    원소수 <= 0이면 { 반환 8. }
    정수 단위크기 = 배열원소크기결정(배열타입노드).
    반환 원소수 * 단위크기.
}

(* ===== 변수 매핑 테이블 ===== *)
(* AST 식별자 이름 → IR 임시변수 인덱스 *)
정수 최대변수수 = 4096.
문자열[4096] 변수이름풀.
정수[4096] 변수임시풀.     (* 대응하는 IR 임시변수 인덱스 *)
정수 변수수 = 0.

(* 현재 함수의 지역 변수 시작 인덱스 *)
정수 지역변수시작 = 0.

(* 전역 변수 초기화 추적 *)
정수 최대전역초기화 = 1024.
정수[1024] 전역초기화임시풀.    (* 전역 임시변수 번호 *)
정수[1024] 전역초기화노드풀.    (* AST 초기값 노드 *)
정수 전역초기화수 = 0.

(* 루프 탈출/계속 레이블 스택 *)
정수 최대루프깊이 = 64.
정수[64] 탈출레이블스택.
정수[64] 계속레이블스택.
정수 루프깊이 = 0.

(* ===== 묶음 필드 오프셋 테이블 ===== *)
(* 묶음 이름 + 필드 이름 → 바이트 오프셋 *)
정수 최대묶음필드항 = 2048.
문자열[2048] 묶음오프셋이름풀.
정수[2048] 묶음오프셋값풀.
정수 묶음오프셋수 = 0.

(* 묶음 이름 → 전체 바이트 크기 테이블 *)
정수 최대묶음크기항 = 256.
문자열[256] 묶음크기이름풀.
정수[256] 묶음크기값풀.
정수 묶음크기수 = 0.

(* 묶음 정의를 스캔하여 필드 오프셋 등록 *)
[정수 노드를 묶음필드등록]은 {
    정수 필드 = 노드왼쪽풀[노드].
    정수 오프셋 = 0.
    (필드 >= 0)동안 {
        묶음오프셋수 < 최대묶음필드항이면 {
            묶음오프셋이름풀[묶음오프셋수] = 필드이름풀[필드].
            묶음오프셋값풀[묶음오프셋수] = 오프셋.
            묶음오프셋수++다.
        }
        오프셋 = 오프셋 + 8.  (* 모든 필드 8바이트 — 64비트 *)
        필드 = 필드다음풀[필드].
    }
    (* 묶음 이름 → 전체 크기 등록 *)
    묶음크기수 < 최대묶음크기항이면 {
        묶음크기이름풀[묶음크기수] = 노드이름풀[노드].
        묶음크기값풀[묶음크기수] = 오프셋.
        묶음크기수++다.
    }
}

(* 묶음 이름으로 전체 바이트 크기 검색 — 없으면 0 *)
[문자열 이름으로 묶음크기찾기]는 → 정수 {
    정수 번호 = 0.
    (번호 < 묶음크기수)동안 {
        문자열_비교(이름, 묶음크기이름풀[번호]) == 0이면 {
            반환 묶음크기값풀[번호].
        }
        번호++다.
    }
    반환 0.
}

(* 필드 이름으로 바이트 오프셋 검색 *)
[문자열 이름으로 필드오프셋찾기]는 → 정수 {
    정수 번호 = 0.
    (번호 < 묶음오프셋수)동안 {
        문자열_비교(이름, 묶음오프셋이름풀[번호]) == 0이면 {
            반환 묶음오프셋값풀[번호].
        }
        번호++다.
    }
    반환 0.  (* 못 찾으면 오프셋 0 *)
}

(* ===== 변수 매핑 유틸리티 ===== *)

[문자열 이름으로 변수찾기]는 → 정수 {
    (* 역순 검색 — 가장 최근 선언 우선 *)
    정수 번호 = 변수수 - 1.
    (번호 >= 지역변수시작)동안 {
        문자열_비교(이름, 변수이름풀[번호]) == 0이면 {
            반환 변수임시풀[번호].
        }
        번호--다.
    }
    (* 전역 변수도 검색 *)
    번호 = 지역변수시작 - 1.
    (번호 >= 0)동안 {
        문자열_비교(이름, 변수이름풀[번호]) == 0이면 {
            반환 변수임시풀[번호].
        }
        번호--다.
    }
    반환 -1.
}

[문자열 이름을 정수 임시번호를 변수등록]은 {
    변수수 < 최대변수수이면 {
        변수이름풀[변수수] = 이름.
        변수임시풀[변수수] = 임시번호.
        변수수++다.
    }
}

(* ===== 연산자 → IR 명령종류 변환 ===== *)

[정수 연산코드를 연산자명령변환]은 → 정수 {
    (연산코드 == 종류_더하기)이면 { 반환 명령_더하기. }
    (연산코드 == 종류_빼기)이면 { 반환 명령_빼기. }
    (연산코드 == 종류_곱하기)이면 { 반환 명령_곱하기. }
    (연산코드 == 종류_나누기)이면 { 반환 명령_나누기. }
    (연산코드 == 종류_나머지)이면 { 반환 명령_나머지. }
    (연산코드 == 종류_같다)이면 { 반환 명령_같음. }
    (연산코드 == 종류_다르다)이면 { 반환 명령_다름. }
    (연산코드 == 종류_크다)이면 { 반환 명령_큼. }
    (연산코드 == 종류_작다)이면 { 반환 명령_작음. }
    (연산코드 == 종류_크거나같다)이면 { 반환 명령_크거나같음. }
    (연산코드 == 종류_작거나같다)이면 { 반환 명령_작거나같음. }
    (연산코드 == 종류_그리고)이면 { 반환 명령_논리곱. }
    (연산코드 == 종류_또는)이면 { 반환 명령_논리합. }
    (연산코드 == 종류_비트와)이면 { 반환 명령_비트와. }
    (연산코드 == 종류_비트또는)이면 { 반환 명령_비트또는. }
    (연산코드 == 종류_비트배타)이면 { 반환 명령_비트배타. }
    (연산코드 == 종류_왼쪽이동)이면 { 반환 명령_왼쪽이동. }
    (연산코드 == 종류_오른쪽이동)이면 { 반환 명령_오른쪽이동. }
    반환 명령_없음.
}

(* ===== 표현식 IR 변환 ===== *)
(* 표현식을 IR로 변환하고, 결과 임시변수 인덱스를 반환 *)

외부 [정수 노드를 표현식변환]은 → 정수.

[정수 노드를 표현식변환]은 → 정수 {
    노드 < 0이면 { 반환 -1. }

    정수 종류 = 노드종류풀[노드].

    (* 정수 리터럴 *)
    (종류 == 노드_정수리터럴)이면 {
        반환 노드정수풀[노드]를 -1을 정수상수명령생성다.
    }

    (* 문자열 리터럴 *)
    (종류 == 노드_문자열리터럴)이면 {
        반환 노드문자열풀[노드]를 -1을 문자열상수명령생성다.
    }

    (* 참/거짓 리터럴 *)
    (종류 == 노드_참거짓리터럴)이면 {
        반환 노드정수풀[노드]를 -1을 정수상수명령생성다.
    }

    (* 없음(NULL) 리터럴 *)
    (종류 == 노드_없음리터럴)이면 {
        반환 0을 -1을 정수상수명령생성다.
    }

    (* 문자 리터럴 — 정수로 처리 *)
    (종류 == 노드_문자리터럴)이면 {
        반환 노드정수풀[노드]를 -1을 정수상수명령생성다.
    }

    (* 실수 리터럴 — 문자열 형태로 보관, 명령_상수실수 사용 *)
    (종류 == 노드_실수리터럴)이면 {
        정수 결과는 -1을 새임시변수다.
        정수 인덱스는 명령등록(명령_상수실수, 결과, -1, 피연산자_없음, -1, 피연산자_없음).
        인덱스 >= 0이면 {
            명령문자열값풀[인덱스] = 노드문자열풀[노드].
            명령타입풀[인덱스] = -1.
        }
        반환 결과.
    }

    (* 식별자 — 변수 참조 *)
    (종류 == 노드_식별자)이면 {
        정수 변수임시 = 노드이름풀[노드]로 변수찾기다.
        변수임시 >= 0이면 {
            반환 변수임시.
        }
        (* 나열(enum) 상수 검색 — 변수 테이블에 없으면 나열값 테이블 확인 *)
        문자열 식별이름 = 노드이름풀[노드].
        정수 나열검색 = 0.
        (나열검색 < 나열값총수)동안 {
            문자열_비교(식별이름, 나열값이름풀[나열검색]) == 0이면 {
                정수 나열결과는 -1을 새임시변수다.
                정수 나열인덱스는 명령등록(명령_상수정수, 나열결과, -1, 피연산자_없음, -1, 피연산자_없음).
                나열인덱스 >= 0이면 {
                    명령정수값풀[나열인덱스] = 나열값정수풀[나열검색].
                }
                반환 나열결과.
            }
            나열검색 = 나열검색 + 1.
        }
        (* 미등록 식별자 — 전역 또는 외부 함수명일 수 있음 *)
        반환 -1.
    }

    (* 이항 연산 *)
    (종류 == 노드_이항연산)이면 {
        정수 왼쪽 = 노드왼쪽풀[노드]를 표현식변환다.
        정수 오른쪽 = 노드오른쪽풀[노드]를 표현식변환다.
        정수 결과 = -1을 새임시변수다.
        정수 명령 = 노드연산자풀[노드]를 연산자명령변환다.
        이항명령생성(명령, 결과, 왼쪽, 오른쪽).
        반환 결과.
    }

    (* 단항 연산 *)
    (종류 == 노드_단항연산)이면 {
        정수 피연산값 = 노드왼쪽풀[노드]를 표현식변환다.
        정수 연산 = 노드연산자풀[노드].
        정수 결과 = -1을 새임시변수다.
        (연산 == 종류_빼기)이면 {
            명령등록(명령_부호반전, 결과, 피연산값, 피연산자_임시변수, -1, 피연산자_없음).
        }
        아니면 (연산 == 종류_아닌)이면 {
            명령등록(명령_논리부정, 결과, 피연산값, 피연산자_임시변수, -1, 피연산자_없음).
        }
        아니면 (연산 == 종류_비트아닌)이면 {
            명령등록(명령_비트부정, 결과, 피연산값, 피연산자_임시변수, -1, 피연산자_없음).
        }
        반환 결과.
    }

    (* 대입 *)
    (종류 == 노드_대입)이면 {
        정수 값 = 노드오른쪽풀[노드]를 표현식변환다.
        정수 연산 = 노드연산자풀[노드].

        (* 왼쪽이 식별자인 경우 *)
        정수 왼쪽노드 = 노드왼쪽풀[노드].
        (노드종류풀[왼쪽노드] == 노드_식별자)이면 {
            정수 변수 = 노드이름풀[왼쪽노드]로 변수찾기다.
            변수 >= 0이면 {
                (* 복합 대입 처리 *)
                (연산 == 종류_더하기대입)이면 {
                    정수 임시 = -1을 새임시변수다.
                    이항명령생성(명령_더하기, 임시, 변수, 값).
                    변수를 임시를 복사명령생성다.
                    반환 임시.
                }
                아니면 (연산 == 종류_빼기대입)이면 {
                    정수 임시 = -1을 새임시변수다.
                    이항명령생성(명령_빼기, 임시, 변수, 값).
                    변수를 임시를 복사명령생성다.
                    반환 임시.
                }
                아니면 {
                    (* 단순 대입 *)
                    변수를 값을 복사명령생성다.
                    반환 값.
                }
            }
        }
        (* 왼쪽이 배열 접근인 경우: 배열[인덱스] = 값 *)
        (노드종류풀[왼쪽노드] == 노드_배열접근)이면 {
            정수 배열 = 노드왼쪽풀[왼쪽노드]를 표현식변환다.
            정수 인덱스값 = 노드오른쪽풀[왼쪽노드]를 표현식변환다.
            정수 저장명령번호 = 명령등록(명령_원소저장, 값, 배열, 피연산자_임시변수, 인덱스값, 피연산자_임시변수).
            저장명령번호 >= 0이면 {
                (배열 >= 0) * (임시변수원소크기풀[배열] == 8) > 0이면 {
                    명령정수값풀[저장명령번호] = 8.
                }
                아니면 {
                    명령정수값풀[저장명령번호] = 1.  (* 바이트 기본 *)
                }
            }
            반환 값.
        }
        (* 왼쪽이 멤버 접근인 경우: 구조체.필드 = 값 *)
        (노드종류풀[왼쪽노드] == 노드_멤버접근)이면 {
            정수 객체 = 노드왼쪽풀[왼쪽노드]를 표현식변환다.
            정수 인덱스 = 명령등록(명령_필드저장, -1, 객체, 피연산자_임시변수, 값, 피연산자_임시변수).
            인덱스 >= 0이면 {
                명령이름풀[인덱스] = 노드이름풀[왼쪽노드].
                명령정수값풀[인덱스] = 노드이름풀[왼쪽노드]로 필드오프셋찾기다.  (* 필드 바이트 오프셋 *)
                명령타입풀[인덱스] = 노드플래그풀[왼쪽노드].  (* 0=직접, 1=화살표 *)
            }
            반환 값.
        }
        반환 -1.
    }

    (* 함수 호출 *)
    (종류 == 노드_호출)이면 {
        (* 인자 수집 *)
        정수 인자 = 노드왼쪽풀[노드].
        정수 인자수 = 0.
        정수 임시인자 = 인자.
        (임시인자 >= 0)동안 {
            인자수++다.
            임시인자 = 인자다음풀[임시인자].
        }

        (* 인자 변환 및 전달 *)
        인자 = 노드왼쪽풀[노드].
        정수 순번 = 0.
        (인자 >= 0)동안 {
            정수 인자값 = 인자값풀[인자]를 표현식변환다.
            인자전달명령생성(인자값, 순번).
            순번++다.
            인자 = 인자다음풀[인자].
        }

        (* 호출 명령 *)
        정수 결과 = -1을 새임시변수다.
        호출명령생성(노드이름풀[노드], 인자수, 결과).
        반환 결과.
    }

    (* 주소 참조 *)
    (종류 == 노드_주소참조)이면 {
        정수 대상 = 노드왼쪽풀[노드]를 표현식변환다.
        정수 결과 = -1을 새임시변수다.
        명령등록(명령_주소, 결과, 대상, 피연산자_임시변수, -1, 피연산자_없음).
        반환 결과.
    }

    (* 역참조 *)
    (종류 == 노드_역참조)이면 {
        정수 대상 = 노드왼쪽풀[노드]를 표현식변환다.
        정수 결과 = -1을 새임시변수다.
        적재명령생성(대상, -1).
        반환 결과.
    }

    (* 배열 접근 *)
    (종류 == 노드_배열접근)이면 {
        정수 배열 = 노드왼쪽풀[노드]를 표현식변환다.
        정수 인덱스값 = 노드오른쪽풀[노드]를 표현식변환다.
        정수 결과 = -1을 새임시변수다.
        정수 명령번호 = 명령등록(명령_원소적재, 결과, 배열, 피연산자_임시변수, 인덱스값, 피연산자_임시변수).
        명령번호 >= 0이면 {
            (* 배열 변수의 원소크기 결정 *)
            (배열 >= 0) * (임시변수원소크기풀[배열] == 8) > 0이면 {
                명령정수값풀[명령번호] = 8.
            }
            아니면 {
                명령정수값풀[명령번호] = 1.  (* 바이트 기본 *)
            }
        }
        반환 결과.
    }

    (* 멤버 접근 *)
    (종류 == 노드_멤버접근)이면 {
        정수 객체 = 노드왼쪽풀[노드]를 표현식변환다.
        정수 결과 = -1을 새임시변수다.
        정수 인덱스 = 명령등록(명령_필드적재, 결과, 객체, 피연산자_임시변수, -1, 피연산자_없음).
        인덱스 >= 0이면 {
            명령이름풀[인덱스] = 노드이름풀[노드].
            명령타입풀[인덱스] = 노드플래그풀[노드].  (* 0=직접, 1=화살표 *)
            명령정수값풀[인덱스] = 노드이름풀[노드]로 필드오프셋찾기다.  (* 필드 바이트 오프셋 *)
        }
        반환 결과.
    }

    (* 형변환 *)
    (종류 == 노드_형변환)이면 {
        정수 대상 = 노드왼쪽풀[노드]를 표현식변환다.
        반환 대상을 -1을 형변환명령생성다.
    }

    (* sizeof *)
    (종류 == 노드_크기)이면 {
        정수 결과 = -1을 새임시변수다.
        정수 인덱스 = 명령등록(명령_크기, 결과, -1, 피연산자_없음, -1, 피연산자_없음).
        인덱스 >= 0이면 {
            명령타입풀[인덱스] = 노드왼쪽풀[노드].
        }
        반환 결과.
    }

    (* 증감 연산 *)
    (종류 == 노드_증감)이면 {
        정수 피연산값 = 노드왼쪽풀[노드]를 표현식변환다.
        정수 플래그 = 노드플래그풀[노드].
        정수 결과 = -1을 새임시변수다.
        (플래그 & 1)이면 {
            명령등록(명령_증가, 결과, 피연산값, 피연산자_임시변수, 플래그, 피연산자_정수상수).
        }
        아니면 {
            명령등록(명령_감소, 결과, 피연산값, 피연산자_임시변수, 플래그, 피연산자_정수상수).
        }
        반환 결과.
    }

    (* 삼항 연산 *)
    (종류 == 노드_삼항)이면 {
        정수 조건 = 노드왼쪽풀[노드]를 표현식변환다.
        정수 참라벨 = 새레이블().
        정수 거짓라벨 = 새레이블().
        정수 끝라벨 = 새레이블().
        정수 결과 = -1을 새임시변수다.

        조건분기생성(조건, 참라벨, 거짓라벨).
        참라벨을 레이블명령생성다.
        정수 참값 = 노드오른쪽풀[노드]를 표현식변환다.
        결과를 참값을 복사명령생성다.
        끝라벨을 이동명령생성다.
        거짓라벨을 레이블명령생성다.
        정수 거짓값 = 노드추가풀[노드]를 표현식변환다.
        결과를 거짓값을 복사명령생성다.
        끝라벨을 레이블명령생성다.
        반환 결과.
    }

    (* 미지원 표현식 *)
    반환 -1.
}

(* ===== 문장 IR 변환 ===== *)

외부 [정수 노드를 문장변환]은.

[정수 블록노드를 블록변환]은 {
    블록노드 < 0이면 { 반환. }
    (노드종류풀[블록노드] != 노드_블록)이면 { 반환. }

    정수 시작 = 노드목록시작풀[블록노드].
    정수 수 = 노드목록수풀[블록노드].
    정수 번호 = 0.
    (번호 < 수)동안 {
        목록항목풀[시작 + 번호]를 문장변환다.
        번호++다.
    }
}

[정수 노드를 문장변환]은 {
    노드 < 0이면 { 반환. }

    정수 종류 = 노드종류풀[노드].

    (* 변수 선언 *)
    (종류 == 노드_변수선언)이면 {
        문자열 이름 = 노드이름풀[노드].
        정수 변수 = 이름을 -1을 1을 이름있는임시변수다.
        이름을 변수를 변수등록다.

        (* 배열 타입이면 크기 정보 저장 *)
        정수 타입노드 = 노드왼쪽풀[노드].
        (타입노드 >= 0) * (노드종류풀[타입노드] == 노드_배열타입) > 0이면 {
            임시변수크기풀[변수] = 배열총크기계산(타입노드).
            임시변수원소크기풀[변수] = 배열원소크기결정(타입노드).
        }
        (* 묶음 타입이면 크기 정보 저장 *)
        (타입노드 >= 0) * (노드종류풀[타입노드] == 노드_묶음타입명) > 0이면 {
            정수 묶음크기 = 노드이름풀[타입노드]로 묶음크기찾기다.
            묶음크기 > 0이면 {
                임시변수크기풀[변수] = 묶음크기.
            }
        }

        (* 초기값이 있으면 대입 *)
        노드오른쪽풀[노드] >= 0이면 {
            정수 값 = 노드오른쪽풀[노드]를 표현식변환다.
            변수를 값을 복사명령생성다.
        }
        반환.
    }

    (* 반환문 *)
    (종류 == 노드_반환문)이면 {
        노드왼쪽풀[노드] >= 0이면 {
            정수 값 = 노드왼쪽풀[노드]를 표현식변환다.
            값을 반환명령생성다.
        }
        아니면 {
            빈반환명령생성().
        }
        반환.
    }

    (* 표현식문 *)
    (종류 == 노드_표현식문)이면 {
        노드왼쪽풀[노드]를 표현식변환다.
        반환.
    }

    (* 대입문 (문장 위치) *)
    (종류 == 노드_대입)이면 {
        노드를 표현식변환다.
        반환.
    }

    (* 호출문 (문장 위치) *)
    (종류 == 노드_호출)이면 {
        노드를 표현식변환다.
        반환.
    }

    (* 증감문 *)
    (종류 == 노드_증감)이면 {
        노드를 표현식변환다.
        반환.
    }

    (* 조건문 *)
    (종류 == 노드_조건문)이면 {
        정수 조건 = 노드왼쪽풀[노드]를 표현식변환다.
        정수 참라벨 = 새레이블().
        정수 거짓라벨 = 새레이블().
        정수 끝라벨 = 새레이블().

        조건분기생성(조건, 참라벨, 거짓라벨).
        참라벨을 레이블명령생성다.
        노드오른쪽풀[노드]를 블록변환다.

        노드추가풀[노드] >= 0이면 {
            끝라벨을 이동명령생성다.
            거짓라벨을 레이블명령생성다.
            정수 거짓분기 = 노드추가풀[노드].
            (노드종류풀[거짓분기] == 노드_조건문)이면 {
                거짓분기를 문장변환다.
            }
            아니면 {
                거짓분기를 블록변환다.
            }
            끝라벨을 레이블명령생성다.
        }
        아니면 {
            거짓라벨을 레이블명령생성다.
        }
        반환.
    }

    (* 동안반복 (while) *)
    (종류 == 노드_동안반복)이면 {
        정수 조건라벨 = 새레이블().
        정수 몸체라벨 = 새레이블().
        정수 끝라벨 = 새레이블().

        (* 루프 레이블 스택 푸시 *)
        루프깊이 < 최대루프깊이이면 {
            탈출레이블스택[루프깊이] = 끝라벨.
            계속레이블스택[루프깊이] = 조건라벨.
            루프깊이++다.
        }

        조건라벨을 레이블명령생성다.
        정수 조건 = 노드왼쪽풀[노드]를 표현식변환다.
        조건분기생성(조건, 몸체라벨, 끝라벨).
        몸체라벨을 레이블명령생성다.
        노드오른쪽풀[노드]를 블록변환다.
        조건라벨을 이동명령생성다.
        끝라벨을 레이블명령생성다.

        루프깊이--다.
        반환.
    }

    (* 반복하기 (do-while) *)
    (종류 == 노드_반복하기)이면 {
        정수 몸체라벨 = 새레이블().
        정수 조건라벨 = 새레이블().
        정수 끝라벨 = 새레이블().

        루프깊이 < 최대루프깊이이면 {
            탈출레이블스택[루프깊이] = 끝라벨.
            계속레이블스택[루프깊이] = 조건라벨.
            루프깊이++다.
        }

        몸체라벨을 레이블명령생성다.
        노드오른쪽풀[노드]를 블록변환다.
        조건라벨을 레이블명령생성다.
        정수 조건 = 노드왼쪽풀[노드]를 표현식변환다.
        조건분기생성(조건, 몸체라벨, 끝라벨).
        끝라벨을 레이블명령생성다.

        루프깊이--다.
        반환.
    }

    (* 반복문 (C-style for) *)
    (종류 == 노드_반복문)이면 {
        (* 초기화 *)
        노드왼쪽풀[노드]를 문장변환다.

        정수 조건라벨 = 새레이블().
        정수 몸체라벨 = 새레이블().
        정수 증감라벨 = 새레이블().
        정수 끝라벨 = 새레이블().

        루프깊이 < 최대루프깊이이면 {
            탈출레이블스택[루프깊이] = 끝라벨.
            계속레이블스택[루프깊이] = 증감라벨.
            루프깊이++다.
        }

        조건라벨을 레이블명령생성다.
        (* 조건 — 노드추가풀[노드]에 조건 노드 *)
        정수 조건노드 = 노드추가풀[노드].
        조건노드 >= 0이면 {
            정수 조건 = 조건노드를 표현식변환다.
            조건분기생성(조건, 몸체라벨, 끝라벨).
        }
        아니면 {
            몸체라벨을 이동명령생성다.
        }

        몸체라벨을 레이블명령생성다.
        노드오른쪽풀[노드]를 블록변환다.

        증감라벨을 레이블명령생성다.
        (* 증감 — 노드정수풀[노드]에 증감 표현식 노드 저장됨 *)
        정수 증감노드 = 노드정수풀[노드].
        증감노드 >= 0이면 {
            증감노드를 표현식변환다.
        }
        조건라벨을 이동명령생성다.
        끝라벨을 레이블명령생성다.

        루프깊이--다.
        반환.
    }

    (* 탈출문 *)
    (종류 == 노드_탈출문)이면 {
        루프깊이 > 0이면 {
            탈출레이블스택[루프깊이 - 1]을 이동명령생성다.
        }
        반환.
    }

    (* 계속문 *)
    (종류 == 노드_계속문)이면 {
        루프깊이 > 0이면 {
            계속레이블스택[루프깊이 - 1]을 이동명령생성다.
        }
        반환.
    }

    (* 블록 *)
    (종류 == 노드_블록)이면 {
        노드를 블록변환다.
        반환.
    }
}

(* ===== 함수 IR 변환 ===== *)

[정수 노드를 함수변환]은 {
    (노드종류풀[노드] != 노드_함수정의)이면 { 반환. }
    (* 외부 선언은 건너뜀 *)
    (노드플래그풀[노드] & 1)이면 { 반환. }

    문자열 이름 = 노드이름풀[노드].
    정수 함수번호 = 이름을 노드를 중간함수시작다.

    (* 지역 변수 시작점 기록 *)
    정수 이전지역시작 = 지역변수시작.
    지역변수시작 = 변수수.

    (* 매개변수 등록 *)
    정수 매개 = 노드왼쪽풀[노드].
    정수 매개순번 = 0.
    (매개 >= 0)동안 {
        문자열 매개이름 = 매개이름풀[매개].
        정수 임시 = 매개이름을 -1을 3을 이름있는임시변수다.  (* 3 = 매개변수 *)
        매개이름을 임시를 변수등록다.
        (* 참조(포인터) 매개변수는 원소크기 8바이트 *)
        정수 매개타입 = 매개타입풀[매개].
        (매개타입 >= 0) * (노드종류풀[매개타입] == 노드_참조타입) > 0이면 {
            임시변수원소크기풀[임시] = 8.
        }
        매개순번++다.
        매개 = 매개다음풀[매개].
    }
    중간함수매개수풀[함수번호] = 매개순번.

    (* 본문 변환 *)
    노드오른쪽풀[노드]를 블록변환다.

    (* 함수 종료 *)
    함수번호를 중간함수종료다.

    (* 지역 변수 스택 복원 *)
    변수수 = 지역변수시작.
    지역변수시작 = 이전지역시작.
}

(* ===== 프로그램 전체 IR 변환 ===== *)

[정수 루트를 프로그램변환]은 {
    루트 < 0이면 { 반환. }
    (노드종류풀[루트] != 노드_프로그램)이면 { 반환. }

    중간초기화().
    변수수 = 0.
    지역변수시작 = 0.
    루프깊이 = 0.
    묶음오프셋수 = 0.
    묶음크기수 = 0.
    전역초기화수 = 0.

    정수 시작 = 노드목록시작풀[루트].
    정수 수 = 노드목록수풀[루트].
    정수 번호 = 0.

    (* 0차: 묶음 정의 스캔 — 필드 오프셋 계산 *)
    (번호 < 수)동안 {
        정수 항목 = 목록항목풀[시작 + 번호].
        (노드종류풀[항목] == 노드_묶음정의)이면 {
            항목을 묶음필드등록다.
        }
        번호++다.
    }

    (* 1차: 전역 변수 등록 *)
    번호 = 0.
    (번호 < 수)동안 {
        정수 선언 = 목록항목풀[시작 + 번호].
        (노드종류풀[선언] == 노드_변수선언)이면 {
            문자열 이름 = 노드이름풀[선언].
            정수 변수 = 이름을 -1을 2를 이름있는임시변수다.  (* 2 = 전역 *)
            이름을 변수를 변수등록다.

            (* 배열 타입이면 크기 정보 저장 *)
            정수 전역타입 = 노드왼쪽풀[선언].
            (전역타입 >= 0) * (노드종류풀[전역타입] == 노드_배열타입) > 0이면 {
                임시변수크기풀[변수] = 배열총크기계산(전역타입).
                임시변수원소크기풀[변수] = 배열원소크기결정(전역타입).
            }
            (* 묶음 타입이면 크기 정보 저장 *)
            (전역타입 >= 0) * (노드종류풀[전역타입] == 노드_묶음타입명) > 0이면 {
                정수 전역묶음크기 = 노드이름풀[전역타입]로 묶음크기찾기다.
                전역묶음크기 > 0이면 {
                    임시변수크기풀[변수] = 전역묶음크기.
                }
            }

            (* 초기값이 있으면 기록 — 나중에 시작하기 함수에 주입 *)
            (노드오른쪽풀[선언] >= 0) * (전역초기화수 < 최대전역초기화) > 0이면 {
                전역초기화임시풀[전역초기화수] = 변수.
                전역초기화노드풀[전역초기화수] = 노드오른쪽풀[선언].
                전역초기화수 = 전역초기화수 + 1.
            }
        }
        번호++다.
    }

    (* 2차: 함수 변환 *)
    번호 = 0.
    (번호 < 수)동안 {
        정수 선언 = 목록항목풀[시작 + 번호].
        (노드종류풀[선언] == 노드_함수정의)이면 {
            선언을 함수변환다.
        }
        번호++다.
    }
}
