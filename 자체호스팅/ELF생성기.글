(*
 * ELF생성기.글 -- 최소 ELF64 바이너리 생성 (1단계: syscall만, libc 없음)
 *
 * "Hello, 글!" 을 출력하고 종료하는 정적 ELF64 실행파일을 생성한다.
 * write(2) syscall과 exit(2) syscall만 사용하며, libc 의존성이 없다.
 *
 * 파일 구조:
 *   0x0000  ELF 헤더 (64바이트)
 *   0x0040  프로그램 헤더 #0: .text  (56바이트)
 *   0x0078  프로그램 헤더 #1: .rodata (56바이트)
 *   0x00B0  패딩 (0x1000까지)
 *   0x1000  .text 섹션 (기계어 코드)
 *   패딩    (다음 페이지까지)
 *   0x2000  .rodata 섹션 (문자열 데이터)
 *)

(* ===== ELF 헤더 바이트 버퍼 ===== *)

문자[8192] ELF_헤더.
정수 ELF_헤더위치 = 0.

(* --- ELF 헤더 바이트 쓰기 헬퍼 --- *)

[정수 바이트값을 ELF_헤더바이트]는 {
    ELF_헤더[ELF_헤더위치] = 바이트값.
    ELF_헤더위치++다.
}

[정수 값을 ELF_헤더16비트]는 {
    ELF_헤더바이트(값 & 255).
    ELF_헤더바이트((값 >> 8) & 255).
}

[정수 값을 ELF_헤더32비트]는 {
    ELF_헤더바이트(값 & 255).
    ELF_헤더바이트((값 >> 8) & 255).
    ELF_헤더바이트((값 >> 16) & 255).
    ELF_헤더바이트((값 >> 24) & 255).
}

(* ELF는 진짜 64비트 필드가 필요하지만, 0x400000 범위이므로 하위 32비트 + 0으로 충분 *)
[정수 값을 ELF_헤더64비트]는 {
    ELF_헤더32비트(값).
    ELF_헤더32비트(0).
}

(* ===== 정렬 올림 유틸리티 ===== *)

[정수 값을 정수 정렬단위로 ELF_정렬올림]은 -> 정수 {
    반환 ((값 + 정렬단위 - 1) / 정렬단위) * 정렬단위.
}

(* ===== ELF 상수 ===== *)

정수 ELF_이미지베이스 = 4194304.   (* 0x400000 *)
정수 ELF_페이지크기 = 4096.         (* 0x1000 *)

(* ===== .text 코드 버퍼 (하드코딩된 기계어) ===== *)

문자[4096] ELF_코드버퍼.
정수 ELF_코드버퍼위치 = 0.

[정수 바이트값을 ELF_코드바이트]는 {
    ELF_코드버퍼[ELF_코드버퍼위치] = 바이트값.
    ELF_코드버퍼위치++다.
}

(* ===== .rodata 데이터 버퍼 ===== *)

문자[4096] ELF_데이터버퍼.
정수 ELF_데이터버퍼위치 = 0.

[정수 바이트값을 ELF_데이터바이트]는 {
    ELF_데이터버퍼[ELF_데이터버퍼위치] = 바이트값.
    ELF_데이터버퍼위치++다.
}

(* ===== 하드코딩된 Hello 프로그램 생성 ===== *)

[ELF_Hello프로그램생성]은 {
    ELF_코드버퍼위치 = 0.
    ELF_데이터버퍼위치 = 0.

    (* --- .rodata: "Hello, 글!\n" --- *)
    (* H=0x48 e=0x65 l=0x6C l=0x6C o=0x6F ,=0x2C 공백=0x20 *)
    ELF_데이터바이트(72).    (* H *)
    ELF_데이터바이트(101).   (* e *)
    ELF_데이터바이트(108).   (* l *)
    ELF_데이터바이트(108).   (* l *)
    ELF_데이터바이트(111).   (* o *)
    ELF_데이터바이트(44).    (* , *)
    ELF_데이터바이트(32).    (* 공백 *)
    (* 글 = UTF-8: 0xEA 0xB8 0x80 *)
    ELF_데이터바이트(234).   (* 0xEA *)
    ELF_데이터바이트(184).   (* 0xB8 *)
    ELF_데이터바이트(128).   (* 0x80 *)
    ELF_데이터바이트(33).    (* ! *)
    ELF_데이터바이트(10).    (* \n *)
    (* 총 12바이트 *)

    정수 메시지길이 = 12.

    (* --- .text: write(1, msg, 12) + exit(0) --- *)

    (* lea rsi, [rip+N] 에서 N 계산:
     *   .text 가상주소 = 0x401000
     *   .rodata 가상주소 = 0x402000
     *   lea 명령어가 위치할 코드 오프셋을 고려해야 함
     *   lea rsi, [rip+rel32] 에서 rip는 lea 명령 다음 바이트를 가리킴
     *)

    (* mov rax, 1  -- write syscall 번호 *)
    (* 48 C7 C0 01 00 00 00 *)
    ELF_코드바이트(72).     (* 0x48 REX.W *)
    ELF_코드바이트(199).    (* 0xC7 *)
    ELF_코드바이트(192).    (* 0xC0 -- mod=11, reg=0, rm=0 (rax) *)
    ELF_코드바이트(1).      (* imm32: 1 *)
    ELF_코드바이트(0).
    ELF_코드바이트(0).
    ELF_코드바이트(0).
    (* 코드 오프셋: 7 *)

    (* mov rdi, 1  -- fd = stdout *)
    (* 48 C7 C7 01 00 00 00 *)
    ELF_코드바이트(72).     (* 0x48 REX.W *)
    ELF_코드바이트(199).    (* 0xC7 *)
    ELF_코드바이트(199).    (* 0xC7 -- mod=11, reg=0, rm=7 (rdi) *)
    ELF_코드바이트(1).      (* imm32: 1 *)
    ELF_코드바이트(0).
    ELF_코드바이트(0).
    ELF_코드바이트(0).
    (* 코드 오프셋: 14 *)

    (* lea rsi, [rip+rel32]  -- 메시지 주소 *)
    (* 48 8D 35 [rel32] *)
    (* rip = 0x401000 + 14 + 7 = 0x401015 (lea 명령 끝 주소) *)
    (* 대상 = 0x402000 *)
    (* rel32 = 0x402000 - 0x401015 = 0xFEB *)
    ELF_코드바이트(72).     (* 0x48 REX.W *)
    ELF_코드바이트(141).    (* 0x8D *)
    ELF_코드바이트(53).     (* 0x35 -- mod=00, reg=6(rsi), rm=5(rip+disp32) *)
    (* rel32 = 0x402000 - (0x401000 + 14 + 7) = 0x402000 - 0x401015 = 0xFEB *)
    ELF_코드바이트(235).    (* 0xEB *)
    ELF_코드바이트(15).     (* 0x0F *)
    ELF_코드바이트(0).
    ELF_코드바이트(0).
    (* 코드 오프셋: 21 *)

    (* mov rdx, 12  -- 메시지 길이 *)
    (* 48 C7 C2 0C 00 00 00 *)
    ELF_코드바이트(72).     (* 0x48 REX.W *)
    ELF_코드바이트(199).    (* 0xC7 *)
    ELF_코드바이트(194).    (* 0xC2 -- mod=11, reg=0, rm=2 (rdx) *)
    ELF_코드바이트(메시지길이). (* imm32: 12 *)
    ELF_코드바이트(0).
    ELF_코드바이트(0).
    ELF_코드바이트(0).
    (* 코드 오프셋: 28 *)

    (* syscall *)
    (* 0F 05 *)
    ELF_코드바이트(15).     (* 0x0F *)
    ELF_코드바이트(5).      (* 0x05 *)
    (* 코드 오프셋: 30 *)

    (* mov rax, 60  -- exit syscall 번호 *)
    (* 48 C7 C0 3C 00 00 00 *)
    ELF_코드바이트(72).     (* 0x48 REX.W *)
    ELF_코드바이트(199).    (* 0xC7 *)
    ELF_코드바이트(192).    (* 0xC0 *)
    ELF_코드바이트(60).     (* imm32: 60 = 0x3C *)
    ELF_코드바이트(0).
    ELF_코드바이트(0).
    ELF_코드바이트(0).
    (* 코드 오프셋: 37 *)

    (* xor rdi, rdi  -- exit code = 0 *)
    (* 48 31 FF *)
    ELF_코드바이트(72).     (* 0x48 REX.W *)
    ELF_코드바이트(49).     (* 0x31 *)
    ELF_코드바이트(255).    (* 0xFF -- mod=11, reg=7(rdi), rm=7(rdi) *)
    (* 코드 오프셋: 40 *)

    (* syscall *)
    (* 0F 05 *)
    ELF_코드바이트(15).     (* 0x0F *)
    ELF_코드바이트(5).      (* 0x05 *)
    (* 코드 오프셋: 42 -- 최종 코드 크기 *)
}

(* ===== ELF 헤더 구성 (64바이트) ===== *)

[정수 코드크기를 정수 데이터크기를 정수 데이터파일오프셋을 정수 데이터가상주소를 ELF_헤더구성]은 {
    ELF_헤더위치 = 0.

    (* --- e_ident (16바이트) --- *)
    ELF_헤더바이트(127).    (* 0x7F *)
    ELF_헤더바이트(69).     (* 'E' = 0x45 *)
    ELF_헤더바이트(76).     (* 'L' = 0x4C *)
    ELF_헤더바이트(70).     (* 'F' = 0x46 *)
    ELF_헤더바이트(2).      (* EI_CLASS: ELFCLASS64 *)
    ELF_헤더바이트(1).      (* EI_DATA: ELFDATA2LSB (리틀엔디안) *)
    ELF_헤더바이트(1).      (* EI_VERSION: EV_CURRENT *)
    ELF_헤더바이트(0).      (* EI_OSABI: ELFOSABI_NONE *)
    (* EI_ABIVERSION + 패딩 (8바이트) *)
    ELF_헤더바이트(0).
    ELF_헤더바이트(0).
    ELF_헤더바이트(0).
    ELF_헤더바이트(0).
    ELF_헤더바이트(0).
    ELF_헤더바이트(0).
    ELF_헤더바이트(0).
    ELF_헤더바이트(0).

    (* --- ELF 헤더 본체 --- *)
    ELF_헤더16비트(2).       (* e_type: ET_EXEC *)
    ELF_헤더16비트(62).      (* e_machine: EM_X86_64 = 0x3E *)
    ELF_헤더32비트(1).       (* e_version: EV_CURRENT *)

    (* e_entry: 진입점 = 0x401000 *)
    ELF_헤더64비트(ELF_이미지베이스 + ELF_페이지크기).

    (* e_phoff: 프로그램 헤더 오프셋 = 64 *)
    ELF_헤더64비트(64).

    (* e_shoff: 섹션 헤더 없음 = 0 *)
    ELF_헤더64비트(0).

    ELF_헤더32비트(0).       (* e_flags *)
    ELF_헤더16비트(64).      (* e_ehsize: ELF 헤더 크기 *)
    ELF_헤더16비트(56).      (* e_phentsize: 프로그램 헤더 항목 크기 *)
    ELF_헤더16비트(2).       (* e_phnum: 프로그램 헤더 2개 (text + data) *)
    ELF_헤더16비트(64).      (* e_shentsize: 섹션 헤더 항목 크기 (사용 안 함) *)
    ELF_헤더16비트(0).       (* e_shnum: 섹션 헤더 0개 *)
    ELF_헤더16비트(0).       (* e_shstrndx: 없음 *)
    (* 여기까지 64바이트 *)

    (* === 프로그램 헤더 #0: .text (PT_LOAD, R+X) === *)
    ELF_헤더32비트(1).       (* p_type: PT_LOAD *)
    ELF_헤더32비트(5).       (* p_flags: PF_R | PF_X *)
    ELF_헤더64비트(ELF_페이지크기).  (* p_offset: 파일 내 오프셋 = 0x1000 *)
    ELF_헤더64비트(ELF_이미지베이스 + ELF_페이지크기).  (* p_vaddr = 0x401000 *)
    ELF_헤더64비트(ELF_이미지베이스 + ELF_페이지크기).  (* p_paddr = 0x401000 *)
    ELF_헤더64비트(코드크기).  (* p_filesz *)
    ELF_헤더64비트(코드크기).  (* p_memsz *)
    ELF_헤더64비트(ELF_페이지크기).  (* p_align = 0x1000 *)

    (* === 프로그램 헤더 #1: .rodata (PT_LOAD, R+W) === *)
    ELF_헤더32비트(1).       (* p_type: PT_LOAD *)
    ELF_헤더32비트(6).       (* p_flags: PF_R | PF_W *)
    ELF_헤더64비트(데이터파일오프셋). (* p_offset *)
    ELF_헤더64비트(데이터가상주소).   (* p_vaddr *)
    ELF_헤더64비트(데이터가상주소).   (* p_paddr *)
    ELF_헤더64비트(데이터크기).       (* p_filesz *)
    ELF_헤더64비트(데이터크기).       (* p_memsz *)
    ELF_헤더64비트(ELF_페이지크기).   (* p_align = 0x1000 *)

    (* 패딩: 헤더 끝(0x00B0)에서 0x1000까지 *)
    (ELF_헤더위치 < ELF_페이지크기)동안 {
        ELF_헤더바이트(0).
    }
}

(* ===== ELF 파일 출력 ===== *)

[문자열 경로를 정수 코드크기를 정수 데이터크기를 정수 데이터파일오프셋을 ELF_파일출력]은 {
    공허 참조 출력파일은 파일_열기(경로, "wb").
    출력파일 == 0이면 {
        쓰기( "오류: ELF 파일을 생성할 수 없습니다: %s\n", 경로).
        반환.
    }

    (* 1. 헤더 + 프로그램 헤더 + 패딩 (0x1000바이트) *)
    파일_쓰기(ELF_헤더, 1, ELF_페이지크기, 출력파일).

    (* 2. .text 섹션 *)
    파일_쓰기(ELF_코드버퍼, 1, 코드크기, 출력파일).

    (* 3. .text에서 다음 페이지까지 패딩 *)
    정수 텍스트패딩 = 데이터파일오프셋 - ELF_페이지크기 - 코드크기.
    텍스트패딩 > 0이면 {
        문자[512] 영패딩.
        메모리_채우기(영패딩, 0, 512).
        정수 남은패딩은 텍스트패딩.
        (남은패딩 > 0)동안 {
            정수 쓸크기는 남은패딩.
            쓸크기 > 512이면 { 쓸크기 = 512. }
            파일_쓰기(영패딩, 1, 쓸크기, 출력파일).
            남은패딩 = 남은패딩 - 쓸크기.
        }
    }

    (* 4. .rodata 섹션 *)
    파일_쓰기(ELF_데이터버퍼, 1, 데이터크기, 출력파일).

    파일_닫기(출력파일).
}

(* ===== ELF 파일 쓰기 -- 조율 함수 ===== *)

[문자열 경로를 ELF_파일쓰기]는 {
    (* 1. 하드코딩된 Hello 프로그램 생성 *)
    ELF_Hello프로그램생성().

    (* 2. 크기 계산 *)
    정수 코드크기는 ELF_코드버퍼위치.
    정수 데이터크기는 ELF_데이터버퍼위치.

    (* .text 파일 오프셋 = 0x1000 *)
    (* .rodata 파일 오프셋 = 다음 페이지 경계 *)
    정수 텍스트파일끝은 ELF_페이지크기 + 코드크기.
    정수 데이터파일오프셋은 ELF_정렬올림(텍스트파일끝, ELF_페이지크기).

    (* 가상 주소 계산 *)
    (* .text: 0x401000 *)
    (* .rodata: 0x401000 + 정렬올림(코드크기) = 0x402000 *)
    정수 텍스트가상주소는 ELF_이미지베이스 + ELF_페이지크기.   (* 0x401000 *)
    정수 데이터가상주소는 텍스트가상주소 + ELF_페이지크기.     (* 0x402000 *)

    쓰기( "ELF 생성: 코드=%d바이트, 데이터=%d바이트\n", 코드크기, 데이터크기).
    쓰기( "  .text  파일오프셋=0x%X, 가상주소=0x%X\n", ELF_페이지크기, 텍스트가상주소).
    쓰기( "  .rodata 파일오프셋=0x%X, 가상주소=0x%X\n", 데이터파일오프셋, 데이터가상주소).

    (* 3. ELF 헤더 + 프로그램 헤더 구성 *)
    ELF_헤더구성(코드크기, 데이터크기, 데이터파일오프셋, 데이터가상주소).

    (* 4. 파일 출력 *)
    ELF_파일출력(경로, 코드크기, 데이터크기, 데이터파일오프셋).

    쓰기( "ELF 파일 생성 완료: %s\n", 경로).
}
