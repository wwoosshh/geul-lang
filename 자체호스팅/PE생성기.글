(* --- 메모리 접근: mov reg, [rbp-N] --- *)

[정수 레지를 정수 오프셋을 인코딩_mov_reg_mem]은 {
    정수 변위는 0 - 오프셋.
    정수 레지하위는 레지 & 7.

    (* REX 접두사 *)
    정수 렉스는 72.             (* 0x48 *)
    레지 >= 8이면 {
        렉스 = 76.              (* 0x4C = REX.W + REX.R *)
    }
    렉스를 코드바이트쓰기다.

    (* opcode: 8B (mov reg, r/m) *)
    139를 코드바이트쓰기다.

    (* ModRM 바이트 *)
    (오프셋 <= 127) * (오프셋 > 0) > 0이면 {
        정수 모드알엠은 69 + (레지하위 * 8).
        모드알엠을 코드바이트쓰기다.
        (변위 & 255)을 코드바이트쓰기다.
    }
    아니면 {
        정수 모드알엠은 133 + (레지하위 * 8).
        모드알엠을 코드바이트쓰기다.
        변위를 코드리틀엔디안32쓰기다.
    }
}

(* --- 메모리 접근: mov qword ptr [rbp-N], imm32 --- *)
(* 48 C7 45/85 [disp] [le32_imm] *)

[정수 오프셋을 정수 값을 인코딩_mov_mem_imm32]은 {
    정수 변위는 0 - 오프셋.

    72를 코드바이트쓰기다.       (* 0x48 REX.W *)
