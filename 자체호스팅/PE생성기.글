(* ===== 5b. SSE2 부동소수점 명령어 인코더 ===== *)

(* --- 실수 임시변수 추적 --- *)
정수[65536] PE_임시실수여부.

(* --- 실수 상수 풀 --- *)
정수 PE_최대실수상수수 = 1024.
정수[1024] PE_실수상수오프셋풀.    (* 데이터버퍼 내 오프셋 *)
문자열[1024] PE_실수상수값풀.       (* 원본 문자열 *)
정수 PE_실수상수수 = 0.

(* 실수 상수 등록 — 중복 검사 후 인덱스 반환 *)
[문자열 값을 PE_실수상수등록]은 → 정수 {
    정수 번호 = 0.
    (번호 < PE_실수상수수)동안 {
        문자열_비교(값, PE_실수상수값풀[번호]) == 0이면 {
            반환 번호.
        }
        번호++다.
    }
    (PE_실수상수수 < PE_최대실수상수수)이면 {
        PE_실수상수값풀[PE_실수상수수] = 값.
        PE_실수상수오프셋풀[PE_실수상수수] = -1.
        PE_실수상수수++다.
    }
    반환 PE_실수상수수 - 1.
}

(* 실수를 8바이트 IEEE 754 double로 데이터 버퍼에 기록 *)
(* 전역 배열+메모리복사로 주소 취득 문제 회피 *)
문자[8] PE_실수변환버퍼.
[실수 넣을값을 PE_실수바이트기록]은 {
    메모리_복사(PE_실수변환버퍼, &넣을값, 8).
    정수 번호 = 0.
    (번호 < 8)동안 {
        정수 바이트값은 PE_실수변환버퍼[번호].
        바이트값 < 0이면 { 바이트값 = 바이트값 + 256. }
        바이트값을 데이터바이트쓰기다.
        번호++다.
    }
}

(* 모든 실수 상수를 데이터 버퍼에 기록하고 오프셋 설정 *)
[PE_실수데이터생성]은 {
    (* 8바이트 정렬 *)
    (데이터버퍼위치 & 7) != 0이면 {
        정수 패딩필요 = 8 - (데이터버퍼위치 & 7).
        정수 패딩번호 = 0.
