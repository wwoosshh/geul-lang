(* ===== 10b. 비교-분기 융합 후보 표시 ===== *)
(* 비교 결과가 오직 직후의 조건분기에만 사용되면 setcc/movzx/store 생략 가능 *)
정수[65536] PE_융합생략.   (* 1이면 해당 명령의 setcc+movzx+store 생략 *)

[정수 함수번호를 PE_융합분석]은 {
    정수 명령시작 = 중간함수명령시작풀[함수번호].
    정수 명령수 = 중간함수명령수풀[함수번호].
    정수 임시시작 = 중간함수임시시작풀[함수번호].
    정수 임시수 = 중간함수임시수풀[함수번호].

    (* 초기화 *)
    정수 초기번호 = 0.
    (초기번호 < 명령수)동안 {
        PE_융합생략[명령시작 + 초기번호] = 0.
        초기번호++다.
    }

    (* 각 조건분기 명령에 대해 직전 비교를 확인 *)
    정수 번호 = 1.
    (번호 < 명령수)동안 {
        정수 현재인덱스 = 명령시작 + 번호.
        (명령종류풀[현재인덱스] == 명령_조건분기)이면 {
            정수 조건임시 = 명령인자1풀[현재인덱스].
            (* 직전 유효 명령 찾기 *)
            정수 이전번호 = 번호 - 1.
            정수 이전인덱스 = 명령시작 + 이전번호.
            (이전번호 > 0) * (명령종류풀[이전인덱스] == 명령_없음)동안 {
                이전번호--다.
                이전인덱스 = 명령시작 + 이전번호.
            }
            정수 이전종류 = 명령종류풀[이전인덱스].
            정수 이전결과 = 명령결과풀[이전인덱스].
            (* 이전 명령이 비교이고 결과가 조건임시와 같으면 *)
            (이전결과 == 조건임시)이면 {
                정수 비교임 = 0.
                (이전종류 == 명령_같음)이면       { 비교임 = 1. }
                (이전종류 == 명령_다름)이면       { 비교임 = 1. }
                (이전종류 == 명령_큼)이면         { 비교임 = 1. }
                (이전종류 == 명령_작음)이면       { 비교임 = 1. }
                (이전종류 == 명령_크거나같음)이면 { 비교임 = 1. }
                (이전종류 == 명령_작거나같음)이면 { 비교임 = 1. }
                비교임 != 0이면 {
                    (* 실수 비교가 아닌지 확인 *)
                    정수 인자1 = 명령인자1풀[이전인덱스].
                    정수 인자2 = 명령인자2풀[이전인덱스].
                    (PE_실수여부(인자1) + PE_실수여부(인자2) == 0)이면 {
                        (* 조건임시가 이 분기 이외에 다른 곳에서 사용되는지 확인 *)
                        (* 임시변수(종류0)만 생략 가능 — 로컬/매개변수는 값으로 사용될 수 있음 *)
                        (임시변수종류풀[조건임시] == 0)이면 {
                            정수 다른사용 = 0.
                            정수 검사번호 = 0.
                            (검사번호 < 명령수) * (다른사용 == 0)동안 {
                                정수 검사인덱스 = 명령시작 + 검사번호.
                                정수 검사종류 = 명령종류풀[검사인덱스].
                                (검사종류 != 명령_없음) * (검사인덱스 != 현재인덱스)이면 {
                                    (명령인자1풀[검사인덱스] == 조건임시)이면 { 다른사용 = 1. }
                                    (명령인자2풀[검사인덱스] == 조건임시)이면 { 다른사용 = 1. }
                                }
                                검사번호++다.
                            }
                            다른사용 == 0이면 {
                                PE_융합생략[이전인덱스] = 1.
                            }
                        }
                    }
                }
            }
        }
        번호++다.
    }
}

(* ===== 11. IR 명령어 → 기계어 변환 (분할) ===== *)

정수 PE_현재생성_메인 = 0.
정수 PE_현재잎함수 = 0.     (* 현재 함수가 호출을 하지 않는 잎함수인지 *)
정수 PE_현재함수번호 = -1.   (* 현재 인코딩 중인 함수 번호 *)
문자[64] PE_본문레이블버퍼.   (* 꼬리호출용 함수 본문 시작 레이블 *)
문자열 PE_본문레이블 = 0.     (* 프롤로그 직후 레이블 이름 *)

(* 레지스터 캐시 — 현재 r10/r11에 어떤 임시변수가 있는지 추적 *)
정수 PE_캐시_r10임시 = -1.    (* r10에 있는 임시변수 번호, -1이면 없음 *)
정수 PE_캐시_r11임시 = -1.    (* r11에 있는 임시변수 번호 *)

(* 레지스터 캐시 무효화 *)
[PE_캐시무효화]는 {
    PE_캐시_r10임시 = -1.
    PE_캐시_r11임시 = -1.
}

(* --- 11a. 산술 명령 인코딩: 더하기, 빼기, 곱하기, 나누기, 나머지 --- *)
[정수 명령인덱스를 PE_산술명령인코딩]은 → 정수 {
    정수 종류 = 명령종류풀[명령인덱스].
    정수 결과 = 명령결과풀[명령인덱스].
    정수 인자1 = 명령인자1풀[명령인덱스].
    정수 인자2 = 명령인자2풀[명령인덱스].

    (* 더하기 *)
    (종류 == 명령_더하기)이면 {
        PE_실수여부(인자1) + PE_실수여부(인자2) > 0이면 {
            PE_실수여부(인자1) == 0이면 {
                PE_적재_r10(인자1).
                인코딩_cvtsi2sd_xmm0_r10().
            }
            아니면 { PE_적재실수_xmm0(인자1). }
            PE_실수여부(인자2) == 0이면 {
                PE_적재_r10(인자2).
                인코딩_cvtsi2sd_xmm1_r10().
            }
            아니면 { PE_적재실수_xmm1(인자2). }
            인코딩_addsd_xmm0_xmm1().
            PE_저장실수_xmm0(결과).
            (결과 >= 0) * (결과 < 65536) > 0이면 {
                PE_임시실수여부[결과] = 1.
            }
            반환 1.
        }
        PE_적재_r10(인자1).
        PE_적재_r11(인자2).
        인코딩_add_r10_r11().
        PE_저장_r10(결과).
        반환 1.
    }

    (* 빼기 *)
    (종류 == 명령_빼기)이면 {
        PE_실수여부(인자1) + PE_실수여부(인자2) > 0이면 {
            PE_실수여부(인자1) == 0이면 {
                PE_적재_r10(인자1).
                인코딩_cvtsi2sd_xmm0_r10().
            }
            아니면 { PE_적재실수_xmm0(인자1). }
            PE_실수여부(인자2) == 0이면 {
                PE_적재_r10(인자2).
                인코딩_cvtsi2sd_xmm1_r10().
            }
            아니면 { PE_적재실수_xmm1(인자2). }
            인코딩_subsd_xmm0_xmm1().
            PE_저장실수_xmm0(결과).
            (결과 >= 0) * (결과 < 65536) > 0이면 {
                PE_임시실수여부[결과] = 1.
            }
            반환 1.
        }
        PE_적재_r10(인자1).
        PE_적재_r11(인자2).
        인코딩_sub_r10_r11().
        PE_저장_r10(결과).
        반환 1.
    }

    (* 곱하기 *)
    (종류 == 명령_곱하기)이면 {
        PE_실수여부(인자1) + PE_실수여부(인자2) > 0이면 {
            PE_실수여부(인자1) == 0이면 {
                PE_적재_r10(인자1).
                인코딩_cvtsi2sd_xmm0_r10().
            }
            아니면 { PE_적재실수_xmm0(인자1). }
            PE_실수여부(인자2) == 0이면 {
                PE_적재_r10(인자2).
                인코딩_cvtsi2sd_xmm1_r10().
            }
            아니면 { PE_적재실수_xmm1(인자2). }
            인코딩_mulsd_xmm0_xmm1().
            PE_저장실수_xmm0(결과).
            (결과 >= 0) * (결과 < 65536) > 0이면 {
                PE_임시실수여부[결과] = 1.
            }
            반환 1.
        }
        PE_적재_rax(인자1).
        PE_적재_r11(인자2).
        인코딩_imul_rax_r11().
        PE_저장_rax(결과).
        반환 1.
    }

    (* 나누기 *)
    (종류 == 명령_나누기)이면 {
        PE_실수여부(인자1) + PE_실수여부(인자2) > 0이면 {
            PE_실수여부(인자1) == 0이면 {
                PE_적재_r10(인자1).
                인코딩_cvtsi2sd_xmm0_r10().
            }
            아니면 { PE_적재실수_xmm0(인자1). }
            PE_실수여부(인자2) == 0이면 {
                PE_적재_r10(인자2).
                인코딩_cvtsi2sd_xmm1_r10().
            }
            아니면 { PE_적재실수_xmm1(인자2). }
            인코딩_divsd_xmm0_xmm1().
            PE_저장실수_xmm0(결과).
            (결과 >= 0) * (결과 < 65536) > 0이면 {
                PE_임시실수여부[결과] = 1.
            }
            반환 1.
        }
        PE_적재_rax(인자1).
        인코딩_cqo().
        PE_적재_r11(인자2).
        인코딩_idiv_r11().
        PE_저장_rax(결과).
        반환 1.
    }

    (* 나머지 *)
    (종류 == 명령_나머지)이면 {
        PE_적재_rax(인자1).
        인코딩_cqo().
        PE_적재_r11(인자2).
        인코딩_idiv_r11().
        PE_저장_rdx(결과).
        반환 1.
    }

    반환 0.
}

(* --- 11b. 비교/논리 명령 인코딩 --- *)
[정수 명령인덱스를 PE_비교명령인코딩]은 → 정수 {
    정수 종류 = 명령종류풀[명령인덱스].
    정수 결과 = 명령결과풀[명령인덱스].
    정수 인자1 = 명령인자1풀[명령인덱스].
    정수 인자2 = 명령인자2풀[명령인덱스].

    (* 비교 *)
    (종류 == 명령_같음) + (종류 == 명령_다름) + (종류 == 명령_큼) + (종류 == 명령_작음) + (종류 == 명령_크거나같음) + (종류 == 명령_작거나같음) > 0이면 {
        (* 실수 비교: ucomisd + 부호없는 조건 플래그 *)
        PE_실수여부(인자1) + PE_실수여부(인자2) > 0이면 {
            PE_실수여부(인자1) == 0이면 {
                PE_적재_r10(인자1).
                인코딩_cvtsi2sd_xmm0_r10().
            }
            아니면 { PE_적재실수_xmm0(인자1). }
            PE_실수여부(인자2) == 0이면 {
                PE_적재_r10(인자2).
                인코딩_cvtsi2sd_xmm1_r10().
            }
            아니면 { PE_적재실수_xmm1(인자2). }
            인코딩_ucomisd_xmm0_xmm1().
            (종류 == 명령_같음)이면       { 인코딩_setcc(조건_같음). }
            (종류 == 명령_다름)이면       { 인코딩_setcc(조건_다름). }
            (종류 == 명령_큼)이면         { 인코딩_setcc(조건_실수큼). }
            (종류 == 명령_작음)이면       { 인코딩_setcc(조건_실수작음). }
            (종류 == 명령_크거나같음)이면 { 인코딩_setcc(조건_실수크거나같음). }
            (종류 == 명령_작거나같음)이면 { 인코딩_setcc(조건_실수작거나같음). }
            인코딩_movzx_r10_al().
            PE_저장_r10(결과).
            반환 1.
        }
        PE_적재_r10(인자1).
        PE_적재_r11(인자2).
        인코딩_cmp_r10_r11().
        (* 융합 생략: 결과가 직후 분기에만 사용되면 setcc+movzx+store 불필요 *)
        PE_융합생략[명령인덱스] == 0이면 {
            (종류 == 명령_같음)이면       { 인코딩_setcc(조건_같음). }
            (종류 == 명령_다름)이면       { 인코딩_setcc(조건_다름). }
            (종류 == 명령_큼)이면         { 인코딩_setcc(조건_큼). }
            (종류 == 명령_작음)이면       { 인코딩_setcc(조건_작음). }
            (종류 == 명령_크거나같음)이면 { 인코딩_setcc(조건_크거나같음). }
            (종류 == 명령_작거나같음)이면 { 인코딩_setcc(조건_작거나같음). }
            인코딩_movzx_r10_al().
            PE_저장_r10(결과).
        }
        반환 1.
    }

    (* 논리곱 *)
    (종류 == 명령_논리곱)이면 {
        정수 거짓번호는 PE_논리레이블번호.
        정수 끝번호는 PE_논리레이블번호 + 1.
        PE_논리레이블번호 = PE_논리레이블번호 + 2.
        문자열 거짓이름은 PE_논리레이블이름(거짓번호).
        문자열 끝이름은 PE_논리레이블이름(끝번호).

        PE_적재_r10(인자1).
        인코딩_test_r10_r10().
        인코딩_je(거짓이름).
        PE_적재_r10(인자2).
        인코딩_test_r10_r10().
        인코딩_je(거짓이름).
        인코딩_mov_r10_1().
        인코딩_jmp(끝이름).
        거짓이름을 레이블등록다.
        인코딩_xor_r10_r10().
        끝이름을 레이블등록다.
        PE_저장_r10(결과).
        반환 1.
    }

    (* 논리합 *)
    (종류 == 명령_논리합)이면 {
        정수 참번호는 PE_논리레이블번호.
        정수 끝번호는 PE_논리레이블번호 + 1.
        PE_논리레이블번호 = PE_논리레이블번호 + 2.
        문자열 참이름은 PE_논리레이블이름(참번호).
        문자열 끝이름은 PE_논리레이블이름(끝번호).

        PE_적재_r10(인자1).
        인코딩_test_r10_r10().
        인코딩_jne(참이름).
        PE_적재_r10(인자2).
        인코딩_test_r10_r10().
        인코딩_jne(참이름).
        인코딩_xor_r10_r10().
        인코딩_jmp(끝이름).
        참이름을 레이블등록다.
        인코딩_mov_r10_1().
        끝이름을 레이블등록다.
        PE_저장_r10(결과).
        반환 1.
    }

    (* 논리부정 *)
    (종류 == 명령_논리부정)이면 {
        PE_적재_r10(인자1).
        인코딩_test_r10_r10().
        인코딩_sete_al().
        인코딩_movzx_r10_al().
        PE_저장_r10(결과).
        반환 1.
    }

    반환 0.
}

(* --- 11c. 비트 연산 명령 인코딩 --- *)
[정수 명령인덱스를 PE_비트명령인코딩]은 → 정수 {
    정수 종류 = 명령종류풀[명령인덱스].
    정수 결과 = 명령결과풀[명령인덱스].
    정수 인자1 = 명령인자1풀[명령인덱스].
    정수 인자2 = 명령인자2풀[명령인덱스].

    (종류 == 명령_비트와)이면 {
        PE_적재_r10(인자1).
        PE_적재_r11(인자2).
        인코딩_and_r10_r11().
        PE_저장_r10(결과).
        반환 1.
    }
    (종류 == 명령_비트또는)이면 {
        PE_적재_r10(인자1).
        PE_적재_r11(인자2).
        인코딩_or_r10_r11().
        PE_저장_r10(결과).
        반환 1.
    }
    (종류 == 명령_비트배타)이면 {
        PE_적재_r10(인자1).
        PE_적재_r11(인자2).
        인코딩_xor_r10_r11().
        PE_저장_r10(결과).
        반환 1.
    }
    (종류 == 명령_비트부정)이면 {
        PE_적재_r10(인자1).
        인코딩_not_r10().
        PE_저장_r10(결과).
        반환 1.
    }
    (종류 == 명령_왼쪽이동)이면 {
        PE_적재_r10(인자1).
        PE_적재_rcx(인자2).
        인코딩_shl_r10_cl().
        PE_저장_r10(결과).
        반환 1.
    }
    (종류 == 명령_오른쪽이동)이면 {
        PE_적재_r10(인자1).
        PE_적재_rcx(인자2).
        인코딩_sar_r10_cl().
        PE_저장_r10(결과).
        반환 1.
    }

    (* 부호반전 *)
    (종류 == 명령_부호반전)이면 {
        PE_적재_r10(인자1).
        인코딩_neg_r10().
        PE_저장_r10(결과).
        반환 1.
    }

    반환 0.
}

(* --- 11d. 메모리 명령 인코딩: 적재, 저장, 주소, 형변환, 크기 --- *)
[정수 명령인덱스를 PE_메모리명령인코딩]은 → 정수 {
    정수 종류 = 명령종류풀[명령인덱스].
    정수 결과 = 명령결과풀[명령인덱스].
    정수 인자1 = 명령인자1풀[명령인덱스].
    정수 인자2 = 명령인자2풀[명령인덱스].

    (* 적재 *)
    (종류 == 명령_적재)이면 {
        PE_적재_r10(인자1).
        PE_저장_r10(결과).
        반환 1.
    }

    (* 저장 *)
    (종류 == 명령_저장)이면 {
        PE_적재_r10(인자2).
        PE_저장_r10(인자1).
        반환 1.
    }

    (* 주소 *)
    (종류 == 명령_주소)이면 {
        (* 전역 변수이면 RIP-상대 lea *)
        (인자1 >= 0) * (임시변수종류풀[인자1] == 2) > 0이면 {
            76을 코드바이트쓰기다.    (* 0x4C *)
            141을 코드바이트쓰기다.   (* 0x8D *)
            21을 코드바이트쓰기다.    (* 0x15 = ModRM(00,010,101) *)
            PE_전역패치추가(인자1).
            0을 코드리틀엔디안32쓰기다.
            PE_저장_r10(결과).
            반환 1.
        }
        정수 오프셋 = PE_임시오프셋[인자1].
        인코딩_lea_r10_rbp(오프셋).
        PE_저장_r10(결과).
        반환 1.
    }

    (* 형변환 *)
    (종류 == 명령_형변환)이면 {
        PE_실수여부(인자1) == 0이면 {
            PE_적재_r10(인자1).
            인코딩_cvtsi2sd_xmm0_r10().
            PE_저장실수_xmm0(결과).
            (결과 >= 0) * (결과 < 65536) > 0이면 {
                PE_임시실수여부[결과] = 1.
            }
        }
        아니면 {
            PE_적재_r10(인자1).
            PE_저장_r10(결과).
        }
        반환 1.
    }

    반환 0.
}

(* --- 11e. 제어 흐름 명령 인코딩: 레이블, 이동, 조건분기, 반환 --- *)
[정수 명령인덱스를 PE_제어명령인코딩]은 → 정수 {
    정수 종류 = 명령종류풀[명령인덱스].
    정수 인자1 = 명령인자1풀[명령인덱스].
    정수 인자2 = 명령인자2풀[명령인덱스].

    (* 레이블 — 분기 대상이므로 레지스터 캐시 무효화 *)
    (종류 == 명령_레이블)이면 {
        PE_캐시무효화().
        PE_IR레이블이름(인자1)을 레이블등록다.
        반환 1.
    }

    (* 무조건 이동 — 분기 후 캐시 무효화 *)
    (종류 == 명령_이동)이면 {
        인코딩_jmp(PE_IR레이블이름(인자1)).
        PE_캐시무효화().
        반환 1.
    }

    (* 조건분기 — 분기 후 캐시 무효화 *)
    (종류 == 명령_조건분기)이면 {
        (* 비교 융합: 직전 비교 명령의 결과가 조건임시이면 직접 jcc 사용 *)
        (* 없음 명령은 건너뛰고 가장 가까운 유효 명령을 찾음 *)
        정수 융합됨 = 0.
        정수 이전인덱스 = 명령인덱스 - 1.
        (이전인덱스 >= 0) * (명령종류풀[이전인덱스] == 명령_없음)동안 {
            이전인덱스--다.
        }
        (이전인덱스 >= 0)이면 {
            정수 이전종류 = 명령종류풀[이전인덱스].
            정수 이전결과 = 명령결과풀[이전인덱스].
            (이전결과 == 인자1)이면 {
                (* 정수 비교만 융합 — 실수 비교는 ucomisd로 다른 플래그 사용 *)
                정수 이전인자1 = 명령인자1풀[이전인덱스].
                정수 이전인자2 = 명령인자2풀[이전인덱스].
                (PE_실수여부(이전인자1) + PE_실수여부(이전인자2) == 0)이면 {
                    정수 융합조건 = 0.
                    (이전종류 == 명령_같음)이면       { 융합조건 = 조건_같음. }
                    (이전종류 == 명령_다름)이면       { 융합조건 = 조건_다름. }
                    (이전종류 == 명령_큼)이면         { 융합조건 = 조건_큼. }
                    (이전종류 == 명령_작음)이면       { 융합조건 = 조건_작음. }
                    (이전종류 == 명령_크거나같음)이면 { 융합조건 = 조건_크거나같음. }
                    (이전종류 == 명령_작거나같음)이면 { 융합조건 = 조건_작거나같음. }
                    융합조건 != 0이면 {
                        (* cmp 이후 setcc/movzx/store는 플래그를 변경하지 않음 *)
                        (* 직접 조건분기: 참이면 jcc, 거짓이면 jmp *)
                        PE_IR레이블이름(인자2)를 융합조건으로 인코딩_jcc.
                        인코딩_jmp(PE_IR레이블이름(명령타입풀[명령인덱스])).
                        PE_캐시무효화().
                        융합됨 = 1.
                    }
                }
            }
        }
        (* 융합 실패 시 기존 방식: test + jne + jmp *)
        융합됨 == 0이면 {
            PE_적재_r10(인자1).
            인코딩_test_r10_r10().
            인코딩_jne(PE_IR레이블이름(인자2)).
            인코딩_jmp(PE_IR레이블이름(명령타입풀[명령인덱스])).
            PE_캐시무효화().
        }
        반환 1.
    }

    (* 반환 *)
    (종류 == 명령_반환)이면 {
        인자1 >= 0이면 {
            PE_실수여부(인자1) != 0이면 {
                PE_적재실수_xmm0(인자1).
            }
            아니면 {
                PE_적재_rax(인자1).
            }
        }
        PE_현재생성_메인 != 0이면 {
            인코딩_mov_reg_reg(레지_RCX, 레지_RAX).
            인코딩_call("ExitProcess").
        }
        아니면 {
            인코딩_leave().
            정수 팝번호 = PE_핀수.
            (팝번호 > 0)동안 {
                팝번호--다.
                정수 팝레지 = PE_핀레지번호[팝번호].
                (팝레지 == 3)이면 { 91을 코드바이트쓰기다. }
                팝레지 >= 8이면 {
                    65를 코드바이트쓰기다.
                    (88 + (팝레지 & 7))을 코드바이트쓰기다.
                }
            }
            인코딩_ret().
        }
        반환 1.
    }

    반환 0.
}

(* --- 11f. 호출 명령 인코딩: 인자전달, 호출 --- *)
[정수 명령인덱스를 PE_호출명령인코딩]은 → 정수 {
    정수 종류 = 명령종류풀[명령인덱스].
    정수 결과 = 명령결과풀[명령인덱스].
    정수 인자1 = 명령인자1풀[명령인덱스].
    정수 인자2 = 명령인자2풀[명령인덱스].

    (* 인자전달 — 버퍼에 수집 *)
    (종류 == 명령_인자전달)이면 {
        (인자2 == 0) * (PE_인자수 > 0)이면 {
            정수 저장번호 = 0.
            정수 저장시작 = PE_저장깊이 * 16.
            (저장번호 < PE_인자수) * (저장번호 < 16)동안 {
                PE_인자저장[저장시작 + 저장번호] = PE_인자목록[저장번호].
                저장번호++다.
            }
            PE_인자수저장[PE_저장깊이] = PE_인자수.
            PE_저장깊이++다.
            PE_인자수 = 0.
        }
        인자2 < 64이면 {
            PE_인자목록[인자2] = 인자1.
            (인자2 >= PE_인자수)이면 {
                PE_인자수 = 인자2 + 1.
            }
        }
        반환 1.
    }

    (* 함수 호출 — Windows x64 ABI *)
    (종류 == 명령_호출)이면 {
        정수 호출인자수 = 인자1.
        문자열 함수이름은 명령이름풀[명령인덱스].
        함수이름 == 0이면 { 함수이름 = "???". }

        정수 번호 = 0.
        (번호 < 호출인자수)동안 {
            정수 인자임시는 PE_인자목록[번호].
            정수 인자실수 = PE_실수여부(인자임시).

            인자실수 != 0이면 {
                PE_적재실수_xmm0(인자임시).
                (번호 > 0) * (번호 <= 3) > 0이면 {
                    번호를 인코딩_movsd_xmmN_xmm0.
                }
                인코딩_movq_r10_xmm0().
                (번호 == 0)이면 { 인코딩_mov_reg_reg(레지_RCX, 레지_R10). }
                (번호 == 1)이면 { 인코딩_mov_reg_reg(레지_RDX, 레지_R10). }
                (번호 == 2)이면 { 인코딩_mov_reg_reg(레지_R8, 레지_R10). }
                (번호 == 3)이면 { 인코딩_mov_reg_reg(레지_R9, 레지_R10). }
                번호 > 3이면 {
                    인코딩_mov_rsp_r10((번호 * 8)).
                }
            }
            아니면 {
                PE_적재_r10(인자임시).
                (번호 == 0)이면 { 인코딩_mov_reg_reg(레지_RCX, 레지_R10). }
                (번호 == 1)이면 { 인코딩_mov_reg_reg(레지_RDX, 레지_R10). }
                (번호 == 2)이면 { 인코딩_mov_reg_reg(레지_R8, 레지_R10). }
                (번호 == 3)이면 { 인코딩_mov_reg_reg(레지_R9, 레지_R10). }
                번호 > 3이면 {
                    인코딩_mov_rsp_r10((번호 * 8)).
                }
            }
            번호++다.
        }

        (* 꼬리호출 최적화: 자기재귀 꼬리호출 감지 *)
        정수 꼬리호출 = 0.
        (PE_본문레이블 != 0) * (PE_현재함수번호 >= 0) > 0이면 {
            (* 현재 함수와 같은 이름인지 확인 *)
            문자열 현재이름은 중간함수이름풀[PE_현재함수번호].
            문자열_비교(함수이름, 현재이름) == 0이면 {
                (* 다음 유효 명령이 반환이고 반환값이 이 호출의 결과인지 확인 *)
                정수 탐색인덱스 = 명령인덱스 + 1.
                정수 명령끝 = 중간함수명령시작풀[PE_현재함수번호] + 중간함수명령수풀[PE_현재함수번호].
                (* 호출 직후가 반환인지 확인 — NOP만 건너뜀, 다른 명령 있으면 꼬리아님 *)
                정수 꼬리유효 = 1.
                (탐색인덱스 < 명령끝) * 꼬리유효동안 {
                    정수 탐색종류는 명령종류풀[탐색인덱스].
                    (탐색종류 == 명령_없음)이면 {
                        탐색인덱스++다.
                    }
                    아니면 (탐색종류 == 명령_반환)이면 {
                        (결과 >= 0) * (명령인자1풀[탐색인덱스] == 결과)이면 {
                            꼬리호출 = 1.
                        }
                        꼬리유효 = 0.
                    }
                    아니면 {
                        (* 다른 유의미한 명령 존재 → 꼬리호출 아님 *)
                        꼬리유효 = 0.
                    }
                }
            }
        }

        꼬리호출 != 0이면 {
            (* 꼬리호출: 인자를 매개변수 스택 슬롯에 다시 저장하고 본문으로 점프 *)
            (* 1단계: 모든 인자를 레지스터에 먼저 적재 (슬롯 겹침 방지) *)
            정수 매개수 = 중간함수매개수풀[PE_현재함수번호].
            정수 임시시작 = 중간함수임시시작풀[PE_현재함수번호].
            정수 꼬리적재 = 0.
            (꼬리적재 < 호출인자수) * (꼬리적재 < 매개수) * (꼬리적재 < 4) > 0동안 {
                정수 꼬리임시는 PE_인자목록[꼬리적재].
                PE_적재_r10(꼬리임시).
                (꼬리적재 == 0)이면 { 인코딩_mov_reg_reg(레지_RCX, 레지_R10). }
                (꼬리적재 == 1)이면 { 인코딩_mov_reg_reg(레지_RDX, 레지_R10). }
                (꼬리적재 == 2)이면 { 인코딩_mov_reg_reg(레지_R8, 레지_R10). }
                (꼬리적재 == 3)이면 { 인코딩_mov_reg_reg(레지_R9, 레지_R10). }
                꼬리적재++다.
            }
            PE_캐시무효화().
            (* 2단계: 레지스터에서 매개변수 스택 슬롯으로 저장 *)
            정수 꼬리저장 = 0.
            (꼬리저장 < 호출인자수) * (꼬리저장 < 매개수) * (꼬리저장 < 4) > 0동안 {
                정수 매개인덱스 = 임시시작 + 꼬리저장.
                정수 매개오프셋 = PE_임시오프셋[매개인덱스].
                (꼬리저장 == 0)이면 { 인코딩_mov_mem_reg(매개오프셋, 레지_RCX). }
                (꼬리저장 == 1)이면 { 인코딩_mov_mem_reg(매개오프셋, 레지_RDX). }
                (꼬리저장 == 2)이면 { 인코딩_mov_mem_reg(매개오프셋, 레지_R8). }
                (꼬리저장 == 3)이면 { 인코딩_mov_mem_reg(매개오프셋, 레지_R9). }
                (* 핀된 매개변수이면 핀 레지스터에도 기록 *)
                정수 꼬리핀레지 = PE_핀레지스터(매개인덱스).
                꼬리핀레지 >= 0이면 {
                    (꼬리저장 == 0)이면 { 인코딩_mov_reg_reg(꼬리핀레지, 레지_RCX). }
                    (꼬리저장 == 1)이면 { 인코딩_mov_reg_reg(꼬리핀레지, 레지_RDX). }
                    (꼬리저장 == 2)이면 { 인코딩_mov_reg_reg(꼬리핀레지, 레지_R8). }
                    (꼬리저장 == 3)이면 { 인코딩_mov_reg_reg(꼬리핀레지, 레지_R9). }
                }
                꼬리저장++다.
            }
            (* 본문 시작으로 점프 *)
            인코딩_jmp(PE_본문레이블).
            PE_캐시무효화().
        }
        아니면 {
            문자열 호출이름은 PE_호출맹글링(함수이름).
            인코딩_call(호출이름).

            (* 함수 호출 후 r10/r11은 caller-saved → 캐시 무효화 *)
            PE_캐시무효화().

            결과 >= 0이면 {
                PE_저장_rax(결과).
            }
        }

        PE_인자수 = 0.
        PE_저장깊이 > 0이면 {
            PE_저장깊이--다.
            PE_인자수 = PE_인자수저장[PE_저장깊이].
            정수 복원번호 = 0.
            정수 복원시작 = PE_저장깊이 * 16.
            (복원번호 < PE_인자수)동안 {
                PE_인자목록[복원번호] = PE_인자저장[복원시작 + 복원번호].
                복원번호++다.
            }
        }
        반환 1.
    }

    반환 0.
}

(* --- 11g. 구조체/배열 명령 인코딩 --- *)
[정수 명령인덱스를 PE_구조명령인코딩]은 → 정수 {
    정수 종류 = 명령종류풀[명령인덱스].
    정수 결과 = 명령결과풀[명령인덱스].
    정수 인자1 = 명령인자1풀[명령인덱스].
    정수 인자2 = 명령인자2풀[명령인덱스].

    (* 원소 적재: 결과 = 배열[인덱스] *)
    (종류 == 명령_원소적재)이면 {
        PE_적재_r10(인자1).
        PE_적재_r11(인자2).
        PE_캐시무효화().  (* 이후 산술로 r10/r11 변경됨 *)
        정수 원소크기 = 명령정수값풀[명령인덱스].
        원소크기 == 8이면 {
            인코딩_imul_r11_imm(8).
        }
        원소크기 == 4이면 {
            인코딩_imul_r11_imm(4).
        }
        인코딩_add_r10_r11().
        (원소크기 <= 1) + (원소크기 == 0) > 0이면 {
            인코딩_movzx_eax_byte_r10().
            인코딩_mov_reg_reg(레지_R10, 레지_RAX).
        }
        아니면 {
            인코딩_mov_r10_deref_r10().
        }
        PE_저장_r10(결과).
        반환 1.
    }

    (* 원소 저장: 배열[인덱스] = 값 *)
    (종류 == 명령_원소저장)이면 {
        PE_적재_r10(인자1).
        PE_적재_r11(인자2).
        PE_캐시무효화().  (* 이후 산술로 r10/r11 변경됨, PE_적재_r11(결과)도 있음 *)
        정수 원소크기2 = 명령정수값풀[명령인덱스].
        원소크기2 == 8이면 {
            인코딩_imul_r11_imm(8).
        }
        원소크기2 == 4이면 {
            인코딩_imul_r11_imm(4).
        }
        인코딩_add_r10_r11().
        PE_적재_r11(결과).
        (원소크기2 <= 1) + (원소크기2 == 0) > 0이면 {
            인코딩_mov_byte_r10_r11b().
        }
        아니면 {
            인코딩_mov_deref_r10_r11().
        }
        반환 1.
    }

    (* 필드 적재: 결과 = 구조체.필드 *)
    (종류 == 명령_필드적재)이면 {
        정수 화살표여부 = 명령타입풀[명령인덱스].
        화살표여부 == 1이면 {
            PE_적재_r10(인자1).
        }
        아니면 (인자1 >= 0) * (임시변수종류풀[인자1] == 2) > 0이면 {
            76을 코드바이트쓰기다.
            141을 코드바이트쓰기다.
            21을 코드바이트쓰기다.
            PE_전역패치추가(인자1).
            0을 코드리틀엔디안32쓰기다.
        }
        아니면 {
            정수 구조체오프셋 = PE_임시오프셋[인자1].
            인코딩_lea_r10_rbp(구조체오프셋).
        }
        PE_캐시_r10임시 = -1.  (* r10이 주소 계산으로 변경됨 *)
        정수 필드오프셋 = 명령정수값풀[명령인덱스].
        필드오프셋 > 0이면 {
            인코딩_add_r10_imm(필드오프셋).
        }
        인코딩_mov_r10_deref_r10().
        PE_저장_r10(결과).
        반환 1.
    }

    (* 필드 저장: 구조체.필드 = 값 *)
    (종류 == 명령_필드저장)이면 {
        정수 화살표여부2 = 명령타입풀[명령인덱스].
        화살표여부2 == 1이면 {
            PE_적재_r10(인자1).
        }
        아니면 (인자1 >= 0) * (임시변수종류풀[인자1] == 2) > 0이면 {
            76을 코드바이트쓰기다.
            141을 코드바이트쓰기다.
            21을 코드바이트쓰기다.
            PE_전역패치추가(인자1).
            0을 코드리틀엔디안32쓰기다.
        }
        아니면 {
            정수 구조체오프셋2 = PE_임시오프셋[인자1].
            인코딩_lea_r10_rbp(구조체오프셋2).
        }
        정수 필드오프셋2 = 명령정수값풀[명령인덱스].
        필드오프셋2 > 0이면 {
            인코딩_add_r10_imm(필드오프셋2).
        }
        PE_캐시무효화().  (* r10이 주소 계산으로 변경됨, PE_적재_r11 전에 무효화 *)
        PE_적재_r11(인자2).
        인코딩_mov_deref_r10_r11().
        반환 1.
    }

    반환 0.
}

(* --- 11h. 상수/복사/증감 명령 인코딩 --- *)
[정수 명령인덱스를 PE_상수명령인코딩]은 → 정수 {
    정수 종류 = 명령종류풀[명령인덱스].
    정수 결과 = 명령결과풀[명령인덱스].
    정수 인자1 = 명령인자1풀[명령인덱스].

    (* 상수 정수 *)
    (종류 == 명령_상수정수)이면 {
        정수 값은 명령정수값풀[명령인덱스].
        임시변수종류풀[결과] == 2이면 {
            73을 코드바이트쓰기다.
            199를 코드바이트쓰기다.
            194를 코드바이트쓰기다.
            값을 코드리틀엔디안32쓰기다.
            PE_저장_r10(결과).
            반환 1.
        }
        정수 오프셋 = PE_임시오프셋[결과].
        인코딩_mov_mem_imm32(오프셋, 값).
        정수 상수핀레지 = PE_핀레지스터(결과).
        상수핀레지 >= 0이면 {
            인코딩_mov_reg_mem(상수핀레지, 오프셋).
        }
        (* 직접 메모리 쓰기 — r10/r11이 결과를 캐시하고 있으면 무효화 *)
        (PE_캐시_r10임시 == 결과)이면 { PE_캐시_r10임시 = -1. }
        (PE_캐시_r11임시 == 결과)이면 { PE_캐시_r11임시 = -1. }
        반환 1.
    }

    (* 상수 실수 *)
    (종류 == 명령_상수실수)이면 {
        문자열 값은 명령문자열값풀[명령인덱스].
        정수 실수번호는 PE_실수상수등록(값).
        문자[32] 실수레이블.
        버퍼에_쓰기(실수레이블, 32, "__dbl%d", 실수번호).
        인코딩_movsd_xmm0_rip(실수레이블).
        PE_저장실수_xmm0(결과).
        (결과 >= 0) * (결과 < 65536) > 0이면 {
            PE_임시실수여부[결과] = 1.
        }
        반환 1.
    }

    (* 상수 문자열 *)
    (종류 == 명령_상수문자열)이면 {
        문자열 값은 명령문자열값풀[명령인덱스].
        정수 문자열번호는 PE_문자열등록(값).
        문자[32] 문자열레이블.
        버퍼에_쓰기(문자열레이블, 32, "__str%d", 문자열번호).
        인코딩_lea_rax_rip(문자열레이블).
        PE_저장_rax(결과).
        반환 1.
    }

    (* 복사 *)
    (종류 == 명령_복사)이면 {
        PE_실수여부(인자1) != 0이면 {
            PE_적재실수_xmm0(인자1).
            PE_저장실수_xmm0(결과).
            (결과 >= 0) * (결과 < 65536) > 0이면 {
                PE_임시실수여부[결과] = 1.
            }
            반환 1.
        }
        PE_적재_r10(인자1).
        PE_저장_r10(결과).
        반환 1.
    }

    (* 증가 *)
    (종류 == 명령_증가)이면 {
        PE_적재_r10(인자1).
        PE_저장_r10(결과).
        인코딩_inc_r10().
        PE_저장_r10(인자1).
        반환 1.
    }

    (* 감소 *)
    (종류 == 명령_감소)이면 {
        PE_적재_r10(인자1).
        PE_저장_r10(결과).
        인코딩_dec_r10().
        PE_저장_r10(인자1).
        반환 1.
    }

    (* 할당/없음 — 무시 *)
    (종류 == 명령_할당)이면 { 반환 1. }
    (종류 == 명령_없음)이면 { 반환 1. }

    반환 0.
}

(* --- 11z. 디스패처: IR 명령어 → 기계어 변환 --- *)
[정수 명령인덱스를 PE_명령인코딩]은 {
    (명령종류풀[명령인덱스] == 명령_없음)이면 { 반환. }
    PE_상수명령인코딩(명령인덱스) > 0이면 { 반환. }
    PE_산술명령인코딩(명령인덱스) > 0이면 { 반환. }
    PE_비교명령인코딩(명령인덱스) > 0이면 { 반환. }
    PE_비트명령인코딩(명령인덱스) > 0이면 { 반환. }
    PE_메모리명령인코딩(명령인덱스) > 0이면 { 반환. }
    PE_제어명령인코딩(명령인덱스) > 0이면 { 반환. }
    PE_호출명령인코딩(명령인덱스) > 0이면 { 반환. }
    PE_구조명령인코딩(명령인덱스) > 0이면 { 반환. }
}

(* ===== 12. 함수 기계어 생성 ===== *)

[정수 함수번호를 PE_함수인코딩]은 {
    문자열 이름 = 중간함수이름풀[함수번호].
    정수 원본노드 = 중간함수원본노드풀[함수번호].

    (* 외부 선언은 건너뜀 *)
    원본노드 >= 0이면 {
        (노드플래그풀[원본노드] & 1)이면 { 반환. }
    }

    (* 레지스터 핀 분석 *)
    PE_레지스터분석(함수번호).

    (* 비교-분기 융합 후보 분석 *)
    PE_융합분석(함수번호).

    (* 함수 이름 맹글링 및 레이블 등록 *)
    문자열 맹글이름은 PE_함수맹글링(이름).
    맹글이름을 레이블등록다.
    함수코드오프셋풀[함수번호] = 코드버퍼위치.

    (* 프레임 크기 계산 *)
    정수 프레임값은 PE_프레임계산(함수번호).

    (* 프롤로그: callee-saved push → push rbp → mov rbp,rsp → sub rsp,N *)
    (* 핀된 callee-saved 레지스터 보존: push (leave 전에 pop) *)
    정수 핀보존번호 = 0.
    (핀보존번호 < PE_핀수)동안 {
        정수 핀레지 = PE_핀레지번호[핀보존번호].
        (* push rbx=53, push r12=41 54, push r13=41 55, push r14=41 56 *)
        (핀레지 == 3)이면 { 83을 코드바이트쓰기다. }  (* 0x53 push rbx *)
        핀레지 >= 8이면 {
            65를 코드바이트쓰기다.  (* 0x41 REX.B *)
            (80 + (핀레지 & 7))을 코드바이트쓰기다.  (* 0x50+reg *)
        }
        핀보존번호++다.
    }
    인코딩_push_rbp().
    인코딩_mov_rbp_rsp().
    인코딩_sub_rsp(프레임값).

    (* 매개변수를 스택에 저장 *)
    정수 매개수 = 중간함수매개수풀[함수번호].
    정수 임시시작 = 중간함수임시시작풀[함수번호].
    정수 매개번호 = 0.
    (매개번호 < 매개수)동안 {
        정수 매개인덱스 = 임시시작 + 매개번호.
        정수 오프셋 = PE_임시오프셋[매개인덱스].
        (매개번호 == 0)이면 { 인코딩_mov_mem_reg(오프셋, 레지_RCX). }
        (매개번호 == 1)이면 { 인코딩_mov_mem_reg(오프셋, 레지_RDX). }
        (매개번호 == 2)이면 { 인코딩_mov_mem_reg(오프셋, 레지_R8). }
        (매개번호 == 3)이면 { 인코딩_mov_mem_reg(오프셋, 레지_R9). }
        매개번호++다.
    }

    (* 핀된 매개변수의 초기값을 레지스터에 적재 *)
    핀보존번호 = 0.
    (핀보존번호 < PE_핀수)동안 {
        정수 핀임시 = PE_핀임시번호[핀보존번호].
        정수 핀종류 = 임시변수종류풀[핀임시].
        (* 매개변수(3)이면 스택에 저장된 초기값을 레지스터에 적재 *)
        핀종류 == 3이면 {
            정수 핀오프셋 = PE_임시오프셋[핀임시].
            인코딩_mov_reg_mem(PE_핀레지번호[핀보존번호], 핀오프셋).
        }
        핀보존번호++다.
    }

    (* 현재 함수가 main인지 추적 *)
    PE_현재생성_메인 = 0.
    문자열_비교(맹글이름, "main") == 0이면 {
        PE_현재생성_메인 = 1.
    }

    (* 꼬리호출 최적화: 현재 함수 번호 추적 + 본문 시작 레이블 등록 *)
    PE_현재함수번호 = 함수번호.
    버퍼에_쓰기(PE_본문레이블버퍼, 64, "_tail_%d", 함수번호).
    PE_본문레이블 = PE_본문레이블버퍼.
    문자열 본문시작레이블은 PE_본문레이블.
    본문시작레이블을 레이블등록다.

    (* 명령어 인코딩 *)
    정수 명령시작 = 중간함수명령시작풀[함수번호].
    정수 명령수 = 중간함수명령수풀[함수번호].
    PE_인자수 = 0.
    PE_저장깊이 = 0.
    PE_캐시무효화().
    정수 번호 = 0.
    (번호 < 명령수)동안 {
        PE_명령인코딩((명령시작 + 번호)).
        번호++다.
    }

    (* main 함수는 기본 반환 추가: xor eax,eax; mov rcx,rax; call ExitProcess *)
    문자열_비교(맹글이름, "main") == 0이면 {
        인코딩_xor_eax_eax().
        인코딩_mov_reg_reg(레지_RCX, 레지_RAX).
        인코딩_call("ExitProcess").
    }
    아니면 {
        (* 비-main 함수: 기본 에필로그 추가 (void 함수 보호) *)
        인코딩_leave().
        정수 기본팝번호 = PE_핀수.
        (기본팝번호 > 0)동안 {
            기본팝번호--다.
            정수 기본팝레지 = PE_핀레지번호[기본팝번호].
            (기본팝레지 == 3)이면 { 91을 코드바이트쓰기다. }
            기본팝레지 >= 8이면 {
                65를 코드바이트쓰기다.
                (88 + (기본팝레지 & 7))을 코드바이트쓰기다.
            }
        }
        인코딩_ret().
    }
}

(* ===== 13. 전체 프로그램 기계어 생성 ===== *)

[PE_코드버퍼초기화]는 {
    코드버퍼위치 = 0.
    데이터버퍼위치 = 0.
    레이블총수 = 0.
    패치총수 = 0.
    레이블문자위치 = 0.
    PE_맹글링수 = 0.
    PE_맹글링버퍼위치 = 0.
    PE_논리레이블번호 = 0.
    PE_논리레이블버퍼위치 = 0.
    PE_IR레이블버퍼위치 = 0.
    PE_문자열수 = 0.
    PE_실수상수수 = 0.
    PE_핀수 = 0.
    PE_전역패치수 = 0.
    PE_전역총크기 = 0.
    PE_BSS주소 = 0.
