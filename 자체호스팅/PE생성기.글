(* ===== 4. 함수별 코드 오프셋 ===== *)
(* 각 IR 함수의 코드버퍼 시작 오프셋을 기록 *)

정수[512] 함수코드오프셋풀.

(* ===== 5. x86-64 명령어 인코더 ===== *)

(* 레지스터 번호 상수 *)
정수 레지_RAX = 0.
정수 레지_RCX = 1.
정수 레지_RDX = 2.
정수 레지_RBX = 3.
정수 레지_RSP = 4.
정수 레지_RBP = 5.
정수 레지_RSI = 6.
정수 레지_RDI = 7.
정수 레지_R8  = 8.
정수 레지_R9  = 9.
정수 레지_R10 = 10.
정수 레지_R11 = 11.

(* --- 스택 프레임 --- *)

(* push rbp → 55 *)
[인코딩_push_rbp]는 {
    85를 코드바이트쓰기다.
}

(* mov rbp, rsp → 48 8B EC *)
[인코딩_mov_rbp_rsp]는 {
    72를 코드바이트쓰기다.
    139를 코드바이트쓰기다.
    236을 코드바이트쓰기다.
}

(* sub rsp, imm32 → 48 81 EC [le32] *)
[정수 값을 인코딩_sub_rsp]는 {
    72를 코드바이트쓰기다.
    129를 코드바이트쓰기다.
    236을 코드바이트쓰기다.
    값을 코드리틀엔디안32쓰기다.
}

(* leave → C9 *)
[인코딩_leave]는 {
    201을 코드바이트쓰기다.
}

(* ret → C3 *)
[인코딩_ret]는 {
    195를 코드바이트쓰기다.
}

(* --- 메모리 접근: mov [rbp-N], reg --- *)
(* 레지: RAX=0, RCX=1, RDX=2, R8~R11=8~11 *)
(* disp8: N <= 127, disp32: N > 127 *)

[정수 오프셋을 정수 레지를 인코딩_mov_mem_reg]은 {
    정수 변위는 0 - 오프셋.     (* -N *)
    정수 레지하위는 레지 & 7.   (* 하위 3비트 *)

    (* REX 접두사: 0x48 기본, 확장 레지면 REX.R 추가 *)
    정수 렉스는 72.             (* 0x48 = REX.W *)
    레지 >= 8이면 {
        렉스 = 76.              (* 0x4C = REX.W + REX.R *)
    }
    렉스를 코드바이트쓰기다.

    (* opcode: 89 (mov r/m, reg) *)
    137을 코드바이트쓰기다.

    (* ModRM 바이트 *)
    (오프셋 <= 127) * (오프셋 > 0) > 0이면 {
        (* mod=01 (disp8), rm=5 (rbp) *)
        정수 모드알엠은 69 + (레지하위 * 8).  (* 0x45 + reg<<3 *)
        모드알엠을 코드바이트쓰기다.
        (변위 & 255)을 코드바이트쓰기다.
    }
    아니면 {
        (* mod=10 (disp32), rm=5 (rbp) *)
        정수 모드알엠은 133 + (레지하위 * 8).  (* 0x85 + reg<<3 *)
        모드알엠을 코드바이트쓰기다.
