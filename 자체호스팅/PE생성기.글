    PE_본문레이블 = 0.
    (* 실수 여부 배열 초기화 *)
    메모리_채우기(PE_임시실수여부, 0, 65536 * 4).
}

(* ===== 피프홀 최적화 ===== *)
(* 불필요한 복사 명령을 제거한다.
   패턴: 이전 명령이 임시변수 T에 결과를 쓰고, 바로 다음 명령_복사가
   T를 다른 변수 D로 복사하며, T가 이후에 사용되지 않으면
   이전 명령의 결과를 D로 바꾸고 복사 명령을 제거한다. *)

[정수 함수번호를 PE_피프홀최적화]는 {
    정수 명령시작 = 중간함수명령시작풀[함수번호].
    정수 명령수 = 중간함수명령수풀[함수번호].
    정수 번호 = 1.
    (번호 < 명령수)동안 {
        정수 현재인덱스 = 명령시작 + 번호.
        정수 현재종류 = 명령종류풀[현재인덱스].

        (* 복사 명령인지 확인 *)
        (현재종류 == 명령_복사)이면 {
            정수 복사원본 = 명령인자1풀[현재인덱스].
            정수 복사대상 = 명령결과풀[현재인덱스].

            (* 원본이 유효한 임시변수(종류0)인지 확인 *)
            (복사원본 >= 0) * (복사대상 >= 0) * (임시변수종류풀[복사원본] == 0)이면 {
                (* 바로 이전의 유효한 명령 찾기 — 없음/레이블은 건너뜀 *)
                정수 이전번호 = 번호 - 1.
                정수 이전인덱스 = 명령시작 + 이전번호.
                정수 이전종류 = 명령종류풀[이전인덱스].

                (* 이전 명령이 결과를 복사원본에 썼는지 확인 *)
                (명령결과풀[이전인덱스] == 복사원본)이면 {
                    (* 이전 명령이 결과를 생성하는 안전한 종류인지 확인 *)
                    (* 인자전달/레이블/이동/조건분기/반환/저장/없음/할당은 제외 *)
                    정수 안전함 = 1.
                    (이전종류 == 명령_인자전달)이면 { 안전함 = 0. }
                    (이전종류 == 명령_레이블)이면 { 안전함 = 0. }
                    (이전종류 == 명령_이동)이면 { 안전함 = 0. }
                    (이전종류 == 명령_조건분기)이면 { 안전함 = 0. }
                    (이전종류 == 명령_반환)이면 { 안전함 = 0. }
                    (이전종류 == 명령_저장)이면 { 안전함 = 0. }
                    (이전종류 == 명령_없음)이면 { 안전함 = 0. }
                    (이전종류 == 명령_할당)이면 { 안전함 = 0. }

                    안전함 != 0이면 {
                        (* 복사원본이 이후에 사용되지 않는지 확인 *)
                        정수 사용됨 = 0.
                        정수 검사번호 = 번호 + 1.
                        (검사번호 < 명령수) * (사용됨 == 0)동안 {
                            정수 검사인덱스 = 명령시작 + 검사번호.
                            정수 검사종류 = 명령종류풀[검사인덱스].
                            (* 인자1이나 인자2로 사용되는지 확인 *)
                            (명령인자1풀[검사인덱스] == 복사원본)이면 {
                                (검사종류 != 명령_없음)이면 { 사용됨 = 1. }
                            }
                            (명령인자2풀[검사인덱스] == 복사원본)이면 {
                                (검사종류 != 명령_없음)이면 { 사용됨 = 1. }
                            }
                            (* 결과로 다시 쓰이면 이전 정의는 죽은 것 — 중단 *)
                            (명령결과풀[검사인덱스] == 복사원본) * (검사종류 != 명령_없음)이면 {
                                검사번호 = 명령수.  (* 루프 탈출 *)
                            }
                            검사번호++다.
                        }

                        사용됨 == 0이면 {
                            (* 최적화 적용: 이전 명령의 결과를 복사대상으로 변경 *)
                            명령결과풀[이전인덱스] = 복사대상.
                            (* 복사 명령을 없음으로 표시 *)
                            명령종류풀[현재인덱스] = 명령_없음.
                        }
                    }
                }
            }
        }
        번호++다.
    }
}

(* ===== 죽은 저장 제거 (Dead Store Elimination) ===== *)
(* 함수 내에서 결과가 이후에 읽히지 않는 명령을 제거한다.
   기본 블록 내에서만 동작 — 레이블을 만나면 보수적으로 모두 살아있다고 가정한다. *)
정수[65536] PE_살아있음.

[정수 함수번호를 PE_죽은저장제거]는 {
    정수 명령시작 = 중간함수명령시작풀[함수번호].
    정수 명령수 = 중간함수명령수풀[함수번호].
    정수 임시시작 = 중간함수임시시작풀[함수번호].
    정수 임시수 = 중간함수임시수풀[함수번호].

    (* 살아있음 배열 초기화 — 모두 0 *)
    정수 초기번호 = 0.
    (초기번호 < 임시수)동안 {
        PE_살아있음[임시시작 + 초기번호] = 0.
        초기번호++다.
    }

    (* 끝에서부터 역순 스캔 *)
    정수 번호 = 명령수 - 1.
    (번호 >= 0)동안 {
        정수 인덱스 = 명령시작 + 번호.
        정수 종류 = 명령종류풀[인덱스].
        정수 제거됨 = 0.

        (종류 == 명령_없음)이면 {
            (* 이미 없음이면 아무 처리 안 함 *)
        }
        아니면 (종류 == 명령_레이블)이면 {
            (* 레이블 — 보수적으로 모든 임시변수를 살아있다고 표시 *)
            정수 리셋번호 = 0.
            (리셋번호 < 임시수)동안 {
                PE_살아있음[임시시작 + 리셋번호] = 1.
                리셋번호++다.
            }
        }
        아니면 {
            (* 부수효과 명령인지 확인 *)
            정수 부수효과 = 0.
            (종류 == 명령_호출)이면 { 부수효과 = 1. }
            (종류 == 명령_인자전달)이면 { 부수효과 = 1. }
            (종류 == 명령_이동)이면 { 부수효과 = 1. }
            (종류 == 명령_조건분기)이면 { 부수효과 = 1. }
            (종류 == 명령_반환)이면 { 부수효과 = 1. }
            (종류 == 명령_저장)이면 { 부수효과 = 1. }
            (종류 == 명령_필드저장)이면 { 부수효과 = 1. }
            (종류 == 명령_원소저장)이면 { 부수효과 = 1. }
            (종류 == 명령_할당)이면 { 부수효과 = 1. }
            (종류 == 명령_증가)이면 { 부수효과 = 1. }
            (종류 == 명령_감소)이면 { 부수효과 = 1. }

            (* 결과 임시변수 처리 — 죽은 저장 확인 *)
            정수 결과 = 명령결과풀[인덱스].
            (결과 >= 0) * (부수효과 == 0) * (임시변수종류풀[결과] == 0)이면 {
                PE_살아있음[결과] == 0이면 {
                    (* 죽은 저장 — 제거 *)
                    명령종류풀[인덱스] = 명령_없음.
                    제거됨 = 1.
                }
                아니면 {
                    (* 이 정의 이후부터 죽은 것이므로 살아있음에서 제거 *)
                    PE_살아있음[결과] = 0.
                }
            }

            (* 제거되지 않은 명령의 읽기 피연산자를 살아있음에 추가 *)
            제거됨 == 0이면 {
                정수 인자1 = 명령인자1풀[인덱스].
                정수 인자1종류 = 명령인자1종류풀[인덱스].
                (인자1 >= 0) * (인자1종류 == 피연산자_임시변수)이면 {
                    PE_살아있음[인자1] = 1.
                }

                정수 인자2 = 명령인자2풀[인덱스].
                정수 인자2종류 = 명령인자2종류풀[인덱스].
                (인자2 >= 0) * (인자2종류 == 피연산자_임시변수)이면 {
                    PE_살아있음[인자2] = 1.
                }

                (* 저장 명령의 결과(값)도 살아있음 표시 *)
                정수 저장여부 = 0.
                (종류 == 명령_원소저장)이면 { 저장여부 = 1. }
                (종류 == 명령_필드저장)이면 { 저장여부 = 1. }
                (종류 == 명령_저장)이면 { 저장여부 = 1. }
                (저장여부 > 0) * (결과 >= 0) > 0이면 {
                    PE_살아있음[결과] = 1.
                }
            }
        }

        번호--다.
    }
}

(* ===== 인라이닝 분석 메타데이터 ===== *)
(* 각 함수의 유효 명령 수(없음 제외)를 기록한다.
   추후 인라이닝 패스에서 작은 함수를 인라인할 때 사용한다. *)
정수[512] PE_함수유효명령수.
정수[512] PE_함수인라인가능.   (* 1이면 인라인 후보 *)

[PE_인라이닝분석]은 {
    정수 함수번호 = 0.
    (함수번호 < 중간함수총수)동안 {
        정수 명령시작 = 중간함수명령시작풀[함수번호].
        정수 명령수 = 중간함수명령수풀[함수번호].
        정수 유효수 = 0.
        정수 번호 = 0.
        (번호 < 명령수)동안 {
            정수 종류 = 명령종류풀[명령시작 + 번호].
            (* 없음, 할당(프롤로그), 반환(에필로그)은 제외 *)
            (종류 != 명령_없음) * (종류 != 명령_할당) * (종류 != 명령_반환)이면 {
                유효수++다.
            }
            번호++다.
        }
        PE_함수유효명령수[함수번호] = 유효수.
        (* 유효 명령 4개 이하면 인라인 후보 — 비활성화: 대형 프로그램 범위 밖 참조 버그 *)
        (유효수 <= 4)이면 {
            PE_함수인라인가능[함수번호] = 0.  (* 비활성화 *)
        }
        아니면 {
            PE_함수인라인가능[함수번호] = 0.
        }
        함수번호++다.
    }
}

(* ===== 인라이닝 적용 ===== *)
(* 인라인 가능한 작은 함수(<=4 유효 명령)의 호출을 인라인한다.
   래퍼 함수(인자를 그대로 전달하여 다른 함수를 호출하는 패턴)는
   호출 대상을 내부 함수로 직접 교체한다.
   그 외 작은 함수는 IR 명령을 호출자에 복사하여 인라인한다. *)

(* 래퍼 함수 분석 결과 — 래퍼이면 내부 호출 대상 이름 저장 *)
문자열[512] PE_래퍼대상풀.

[PE_래퍼분석]은 {
    정수 함수번호 = 0.
    (함수번호 < 중간함수총수)동안 {
        PE_래퍼대상풀[함수번호] = 0.
        PE_함수인라인가능[함수번호] != 0이면 {
            정수 명령시작 = 중간함수명령시작풀[함수번호].
            정수 명령수 = 중간함수명령수풀[함수번호].
            정수 매개수 = 중간함수매개수풀[함수번호].
            (* 내부 호출 명령 찾기 *)
            정수 호출인덱스 = -1.
            정수 호출수 = 0.
            정수 번호 = 0.
            (번호 < 명령수)동안 {
                정수 인덱스 = 명령시작 + 번호.
                (명령종류풀[인덱스] == 명령_호출)이면 {
                    호출인덱스 = 인덱스.
                    호출수++다.
                }
                번호++다.
            }
            (* 정확히 1개의 호출이 있고, 인자 수가 같으면 래퍼 후보 *)
            (호출수 == 1) * (호출인덱스 >= 0)이면 {
                정수 내부인자수 = 명령인자1풀[호출인덱스].
                내부인자수 == 매개수이면 {
                    정수 임시시작 = 중간함수임시시작풀[함수번호].
                    정수 순서맞음 = 1.
                    정수 인자번호 = 0.
                    (인자번호 < 내부인자수) * (순서맞음 != 0)동안 {
                        정수 전달찾음 = 0.
                        정수 검번호 = 0.
                        (검번호 < 명령수) * (전달찾음 == 0)동안 {
                            정수 검인덱스 = 명령시작 + 검번호.
                            (명령종류풀[검인덱스] == 명령_인자전달) * (명령인자2풀[검인덱스] == 인자번호)이면 {
                                정수 전달임시 = 명령인자1풀[검인덱스].
                                전달임시 == (임시시작 + 인자번호)이면 {
                                    전달찾음 = 1.
                                }
                                아니면 { 순서맞음 = 0. }
                            }
                            검번호++다.
                        }
                        전달찾음 == 0이면 { 순서맞음 = 0. }
                        인자번호++다.
                    }
                    순서맞음 != 0이면 {
                        PE_래퍼대상풀[함수번호] = 명령이름풀[호출인덱스].
                    }
                }
            }
        }
        함수번호++다.
    }
}

(* 함수 이름으로 함수 번호 검색 — 없으면 -1 *)
[문자열 이름을 PE_함수번호찾기]는 → 정수 {
    정수 번호 = 0.
    (번호 < 중간함수총수)동안 {
        문자열_비교(이름, 중간함수이름풀[번호]) == 0이면 {
            반환 번호.
        }
        번호++다.
    }
    반환 -1.
}

(* 인라이닝 적용 — 래퍼 함수는 호출 대상 교체, 일반 소함수는 IR 복사 *)
[PE_인라이닝적용]은 {
    PE_래퍼분석().

    정수 함수번호 = 0.
    (함수번호 < 중간함수총수)동안 {
        정수 명령시작 = 중간함수명령시작풀[함수번호].
        정수 명령수 = 중간함수명령수풀[함수번호].
        정수 번호 = 0.
        (번호 < 명령수)동안 {
            정수 인덱스 = 명령시작 + 번호.
            (명령종류풀[인덱스] == 명령_호출)이면 {
                문자열 호출이름은 명령이름풀[인덱스].
                호출이름 != 0이면 {
                    정수 대상번호 = PE_함수번호찾기(호출이름).
                    (대상번호 >= 0) * (PE_함수인라인가능[대상번호] != 0)이면 {
                        PE_래퍼대상풀[대상번호] != 0이면 {
                            (* 래퍼 함수 — 호출 대상을 내부 함수로 교체 *)
                            문자열 최종대상 = PE_래퍼대상풀[대상번호].
                            정수 체인깊이 = 0.
                            (체인깊이 < 8)동안 {
                                정수 중간번호 = PE_함수번호찾기(최종대상).
                                (중간번호 >= 0) * (PE_래퍼대상풀[중간번호] != 0)이면 {
                                    최종대상 = PE_래퍼대상풀[중간번호].
                                }
                                아니면 {
                                    체인깊이 = 8.
                                }
                                체인깊이++다.
                            }
                            명령이름풀[인덱스] = 최종대상.
                        }
                        아니면 {
                            (* 비-래퍼 소함수: IR 명령 복사로 인라인 *)
                            정수 대상시작 = 중간함수명령시작풀[대상번호].
                            정수 대상수 = 중간함수명령수풀[대상번호].
                            정수 대상매개수 = 중간함수매개수풀[대상번호].
                            정수 대상임시시작 = 중간함수임시시작풀[대상번호].
                            정수 대상임시수 = 중간함수임시수풀[대상번호].

                            정수 호출결과 = 명령결과풀[인덱스].
                            정수 호출인자수 = 명령인자1풀[인덱스].

                            (* 인자전달 명령에서 인자 임시 수집 *)
                            정수[16] 인자임시풀.
                            정수 인자초기 = 0.
                            (인자초기 < 16)동안 { 인자임시풀[인자초기] = -1. 인자초기++다. }

                            정수 역탐색 = 번호 - 1.
                            정수 수집수 = 0.
                            (역탐색 >= 0) * (수집수 < 호출인자수)동안 {
                                정수 역인덱스 = 명령시작 + 역탐색.
                                (명령종류풀[역인덱스] == 명령_인자전달)이면 {
                                    정수 순번 = 명령인자2풀[역인덱스].
                                    (순번 >= 0) * (순번 < 16)이면 {
                                        인자임시풀[순번] = 명령인자1풀[역인덱스].
                                    }
                                    수집수++다.
                                }
                                역탐색--다.
                            }

                            (* 임시변수 매핑 테이블 *)
                            정수[256] 임시매핑.
                            정수 매핑초기 = 0.
                            (매핑초기 < 256)동안 { 임시매핑[매핑초기] = -1. 매핑초기++다. }

                            (* 매개변수 매핑 *)
                            정수 매개매핑 = 0.
                            (매개매핑 < 대상매개수)동안 {
                                (매개매핑 < 256)이면 {
                                    임시매핑[매개매핑] = 인자임시풀[매개매핑].
                                }
                                매개매핑++다.
                            }

                            (* 지역 임시변수에 대해 새 임시변수 생성 *)
                            정수 지역매핑 = 대상매개수.
                            (지역매핑 < 대상임시수)동안 {
                                정수 원본임시 = 대상임시시작 + 지역매핑.
                                정수 원본타입 = 임시변수타입풀[원본임시].
                                정수 새임시 = 원본타입을 새임시변수다.
                                새임시 >= 0이면 {
                                    임시변수종류풀[새임시] = 임시변수종류풀[원본임시].
                                    임시변수크기풀[새임시] = 임시변수크기풀[원본임시].
                                }
                                (지역매핑 < 256)이면 {
                                    임시매핑[지역매핑] = 새임시.
                                }
                                지역매핑++다.
                            }

                            (* 레이블 매핑 *)
                            정수[64] 레이블매핑.
                            정수[64] 레이블원본.
                            정수 레이블매핑수 = 0.
                            정수 레이블탐색 = 0.
                            (레이블탐색 < 대상수)동안 {
                                정수 레이블탐인 = 대상시작 + 레이블탐색.
                                (명령종류풀[레이블탐인] == 명령_레이블)이면 {
                                    (레이블매핑수 < 64)이면 {
                                        레이블원본[레이블매핑수] = 명령인자1풀[레이블탐인].
                                        레이블매핑[레이블매핑수] = 새레이블().
                                        레이블매핑수++다.
                                    }
                                }
                                레이블탐색++다.
                            }

                            (* 공간 충분 + 호출 다음에 복귀 레이블 삽입 가능한지 확인 *)
                            (명령총수 + 대상수 + 4 < 최대명령수)이면 {
                                (* 인자전달 명령들을 없음으로 표시 *)
                                역탐색 = 번호 - 1.
                                수집수 = 0.
                                (역탐색 >= 0) * (수집수 < 호출인자수)동안 {
                                    정수 역인2 = 명령시작 + 역탐색.
                                    (명령종류풀[역인2] == 명령_인자전달)이면 {
                                        명령종류풀[역인2] = 명령_없음.
                                        수집수++다.
                                    }
                                    역탐색--다.
                                }

                                정수 인라인시작레이블 = 새레이블().
                                정수 복귀레이블 = 새레이블().

                                (* 호출 명령을 인라인 코드로의 이동으로 변환 *)
                                명령종류풀[인덱스] = 명령_이동.
                                명령인자1풀[인덱스] = 인라인시작레이블.
                                명령인자1종류풀[인덱스] = 피연산자_레이블.
                                명령결과풀[인덱스] = -1.

                                (* 호출 다음 위치에 복귀 레이블 삽입 *)
                                정수 복귀삽입됨 = 0.
                                (번호 + 1 < 명령수)이면 {
                                    정수 다음인덱스 = 명령시작 + 번호 + 1.
                                    (명령종류풀[다음인덱스] == 명령_없음)이면 {
                                        명령종류풀[다음인덱스] = 명령_레이블.
                                        명령결과풀[다음인덱스] = -1.
                                        명령인자1풀[다음인덱스] = 복귀레이블.
                                        명령인자1종류풀[다음인덱스] = 피연산자_레이블.
                                        명령인자2풀[다음인덱스] = -1.
                                        명령인자2종류풀[다음인덱스] = 피연산자_없음.
                                        명령이름풀[다음인덱스] = 0.
                                        명령타입풀[다음인덱스] = -1.
                                        명령정수값풀[다음인덱스] = 0.
                                        명령문자열값풀[다음인덱스] = 0.
                                        복귀삽입됨 = 1.
                                    }
                                }
                                복귀삽입됨 == 0이면 {
                                    (* 빈 슬롯이 없으면 호출로 복원 *)
                                    명령종류풀[인덱스] = 명령_호출.
                                    명령인자1풀[인덱스] = 호출인자수.
                                    명령인자1종류풀[인덱스] = 피연산자_정수상수.
                                    명령결과풀[인덱스] = 호출결과.
                                    명령이름풀[인덱스] = 호출이름.
                                }
                                아니면 {
                                    (* 인라인 시작 레이블 *)
                                    정수 복사위치 = 명령총수.
                                    명령종류풀[복사위치] = 명령_레이블.
                                    명령결과풀[복사위치] = -1.
                                    명령인자1풀[복사위치] = 인라인시작레이블.
                                    명령인자1종류풀[복사위치] = 피연산자_레이블.
                                    명령인자2풀[복사위치] = -1.
                                    명령인자2종류풀[복사위치] = 피연산자_없음.
                                    명령이름풀[복사위치] = 0.
                                    명령타입풀[복사위치] = -1.
                                    명령정수값풀[복사위치] = 0.
                                    명령문자열값풀[복사위치] = 0.
                                    명령총수++다.

                                    (* 대상 함수의 명령 복사 *)
                                    정수 복사번호 = 0.
                                    (복사번호 < 대상수)동안 {
                                        정수 원본인덱스 = 대상시작 + 복사번호.
                                        정수 원본종류 = 명령종류풀[원본인덱스].

                                        (원본종류 == 명령_할당) + (원본종류 == 명령_없음) > 0이면 {
                                            복사번호++다.
                                        }
                                        아니면 (원본종류 == 명령_반환)이면 {
                                            정수 반환임시 = 명령인자1풀[원본인덱스].
                                            (반환임시 >= 0) * (호출결과 >= 0)이면 {
                                                정수 매핑된반환 = 반환임시.
                                                (반환임시 >= 대상임시시작) * (반환임시 - 대상임시시작 < 256)이면 {
                                                    임시매핑[반환임시 - 대상임시시작] >= 0이면 {
                                                        매핑된반환 = 임시매핑[반환임시 - 대상임시시작].
                                                    }
                                                }
                                                복사위치 = 명령총수.
                                                명령종류풀[복사위치] = 명령_복사.
                                                명령결과풀[복사위치] = 호출결과.
                                                명령인자1풀[복사위치] = 매핑된반환.
                                                명령인자1종류풀[복사위치] = 피연산자_임시변수.
                                                명령인자2풀[복사위치] = -1.
                                                명령인자2종류풀[복사위치] = 피연산자_없음.
                                                명령이름풀[복사위치] = 0.
                                                명령타입풀[복사위치] = -1.
                                                명령정수값풀[복사위치] = 0.
                                                명령문자열값풀[복사위치] = 0.
                                                명령총수++다.
                                            }
                                            복사위치 = 명령총수.
                                            명령종류풀[복사위치] = 명령_이동.
                                            명령결과풀[복사위치] = -1.
                                            명령인자1풀[복사위치] = 복귀레이블.
                                            명령인자1종류풀[복사위치] = 피연산자_레이블.
                                            명령인자2풀[복사위치] = -1.
                                            명령인자2종류풀[복사위치] = 피연산자_없음.
                                            명령이름풀[복사위치] = 0.
                                            명령타입풀[복사위치] = -1.
                                            명령정수값풀[복사위치] = 0.
                                            명령문자열값풀[복사위치] = 0.
                                            명령총수++다.
                                            복사번호++다.
                                        }
                                        아니면 {
                                            (* 일반 명령 복사 — 임시변수/레이블 매핑 적용 *)
                                            복사위치 = 명령총수.
                                            명령종류풀[복사위치] = 원본종류.
                                            명령결과풀[복사위치] = 명령결과풀[원본인덱스].
                                            명령인자1풀[복사위치] = 명령인자1풀[원본인덱스].
                                            명령인자1종류풀[복사위치] = 명령인자1종류풀[원본인덱스].
                                            명령인자2풀[복사위치] = 명령인자2풀[원본인덱스].
                                            명령인자2종류풀[복사위치] = 명령인자2종류풀[원본인덱스].
                                            명령이름풀[복사위치] = 명령이름풀[원본인덱스].
                                            명령타입풀[복사위치] = 명령타입풀[원본인덱스].
                                            명령정수값풀[복사위치] = 명령정수값풀[원본인덱스].
                                            명령문자열값풀[복사위치] = 명령문자열값풀[원본인덱스].

                                            (* 결과 임시 매핑 *)
                                            정수 매핑결과 = 명령결과풀[복사위치].
                                            (매핑결과 >= 대상임시시작) * (매핑결과 - 대상임시시작 < 256)이면 {
                                                임시매핑[매핑결과 - 대상임시시작] >= 0이면 {
                                                    명령결과풀[복사위치] = 임시매핑[매핑결과 - 대상임시시작].
                                                }
                                            }

                                            (* 인자1 임시 매핑 *)
                                            (명령인자1종류풀[복사위치] == 피연산자_임시변수)이면 {
                                                정수 매핑인자1 = 명령인자1풀[복사위치].
                                                (매핑인자1 >= 대상임시시작) * (매핑인자1 - 대상임시시작 < 256)이면 {
                                                    임시매핑[매핑인자1 - 대상임시시작] >= 0이면 {
                                                        명령인자1풀[복사위치] = 임시매핑[매핑인자1 - 대상임시시작].
                                                    }
                                                }
                                            }

                                            (* 인자2 임시 매핑 *)
                                            (명령인자2종류풀[복사위치] == 피연산자_임시변수)이면 {
                                                정수 매핑인자2 = 명령인자2풀[복사위치].
                                                (매핑인자2 >= 대상임시시작) * (매핑인자2 - 대상임시시작 < 256)이면 {
                                                    임시매핑[매핑인자2 - 대상임시시작] >= 0이면 {
                                                        명령인자2풀[복사위치] = 임시매핑[매핑인자2 - 대상임시시작].
                                                    }
                                                }
                                            }

                                            (* 레이블 매핑 *)
                                            (명령인자1종류풀[복사위치] == 피연산자_레이블)이면 {
                                                정수 원본레이블 = 명령인자1풀[복사위치].
                                                정수 레맵번호 = 0.
                                                (레맵번호 < 레이블매핑수)동안 {
                                                    레이블원본[레맵번호] == 원본레이블이면 {
                                                        명령인자1풀[복사위치] = 레이블매핑[레맵번호].
                                                    }
                                                    레맵번호++다.
                                                }
                                            }
                                            (명령인자2종류풀[복사위치] == 피연산자_레이블)이면 {
                                                정수 원본레이블2 = 명령인자2풀[복사위치].
                                                정수 레맵번호2 = 0.
                                                (레맵번호2 < 레이블매핑수)동안 {
                                                    레이블원본[레맵번호2] == 원본레이블2이면 {
                                                        명령인자2풀[복사위치] = 레이블매핑[레맵번호2].
                                                    }
                                                    레맵번호2++다.
                                                }
                                            }
                                            (* 조건분기의 거짓 레이블 매핑 *)
                                            (원본종류 == 명령_조건분기)이면 {
                                                정수 거짓레이블 = 명령타입풀[복사위치].
                                                정수 레맵번호3 = 0.
                                                (레맵번호3 < 레이블매핑수)동안 {
                                                    레이블원본[레맵번호3] == 거짓레이블이면 {
                                                        명령타입풀[복사위치] = 레이블매핑[레맵번호3].
                                                    }
                                                    레맵번호3++다.
                                                }
                                            }

                                            명령총수++다.
                                            복사번호++다.
                                        }
                                    }

                                    (* 호출자 함수의 명령 범위 확장 *)
                                    정수 추가수 = 명령총수 - (명령시작 + 명령수).
                                    중간함수명령수풀[함수번호] = 중간함수명령수풀[함수번호] + 추가수.
                                    명령수 = 중간함수명령수풀[함수번호].
                                }
                            }
                        }
                    }
                }
            }
            번호++다.
        }
        함수번호++다.
    }
}

(* ===== 루프 불변 코드 이동 (LICM) ===== *)
(* 루프 내부의 불변 명령을 루프 앞으로 이동한다.
   1단계: 상수 적재 (명령_상수정수, 명령_상수실수, 명령_상수문자열)
   2단계: 순수 연산 중 모든 피연산자가 루프 밖에서 정의된 것 *)

[정수 함수번호를 PE_루프불변이동]는 {
    정수 명령시작 = 중간함수명령시작풀[함수번호].
    정수 명령수 = 중간함수명령수풀[함수번호].

    (* 레이블 번호 → 명령 상대 인덱스 매핑 *)
    정수[256] 레이블위치풀.
    정수[256] 레이블유효풀.
    정수 레이블초기 = 0.
    (레이블초기 < 256)동안 {
        레이블위치풀[레이블초기] = -1.
        레이블유효풀[레이블초기] = 0.
        레이블초기++다.
    }

    정수 번호 = 0.
    (번호 < 명령수)동안 {
        정수 인덱스 = 명령시작 + 번호.
        (명령종류풀[인덱스] == 명령_레이블)이면 {
            정수 레이블번호 = 명령인자1풀[인덱스].
            정수 해시 = 레이블번호 % 256.
            해시 < 0이면 { 해시 = 해시 + 256. }
            레이블유효풀[해시] == 0이면 {
                레이블위치풀[해시] = 번호.
                레이블유효풀[해시] = 레이블번호 + 1.
            }
        }
        번호++다.
    }

    (* 1단계: 상수 적재 명령 이동 *)
    번호 = 0.
    (번호 < 명령수)동안 {
        정수 인덱스 = 명령시작 + 번호.
        (명령종류풀[인덱스] == 명령_이동)이면 {
            정수 대상레이블 = 명령인자1풀[인덱스].
            정수 해시 = 대상레이블 % 256.
            해시 < 0이면 { 해시 = 해시 + 256. }
            (레이블유효풀[해시] == 대상레이블 + 1)이면 {
                정수 루프시작 = 레이블위치풀[해시].
                정수 루프끝 = 번호.
                (루프시작 < 루프끝)이면 {
                    정수 루프번호 = 루프시작 + 1.
                    (루프번호 < 루프끝)동안 {
                        정수 루프인덱스 = 명령시작 + 루프번호.
                        정수 루프종류 = 명령종류풀[루프인덱스].

                        정수 불변임 = 0.
                        (루프종류 == 명령_상수정수)이면 { 불변임 = 1. }
                        (루프종류 == 명령_상수실수)이면 { 불변임 = 1. }
                        (루프종류 == 명령_상수문자열)이면 { 불변임 = 1. }

                        (불변임 != 0)이면 {
                            정수 상수결과 = 명령결과풀[루프인덱스].
                            정수 이동가능 = 1.
                            (상수결과 >= 0) * (임시변수종류풀[상수결과] != 0)이면 {
                                이동가능 = 0.
                            }
                            이동가능 != 0이면 {
                                정수 중복선언탐색 = 루프시작 + 1.
                                (중복선언탐색 < 루프끝) * (이동가능 != 0)동안 {
                                    정수 중복선언위치 = 명령시작 + 중복선언탐색.
                                    (중복선언탐색 != 루프번호) * (명령종류풀[중복선언위치] != 명령_없음)이면 {
                                        (명령결과풀[중복선언위치] == 상수결과)이면 {
                                            이동가능 = 0.
                                        }
                                    }
                                    중복선언탐색++다.
                                }
                            }

                            이동가능 != 0이면 {
                                정수 삽입위치 = 루프시작 - 1.
                                정수 빈슬롯찾음 = 0.
                                (삽입위치 >= 0) * (빈슬롯찾음 == 0)동안 {
                                    정수 삽입인덱스 = 명령시작 + 삽입위치.
                                    (명령종류풀[삽입인덱스] == 명령_없음)이면 {
                                        빈슬롯찾음 = 1.
                                    }
                                    아니면 { 삽입위치--다. }
                                }

                                빈슬롯찾음 != 0이면 {
                                    정수 삽입인덱스 = 명령시작 + 삽입위치.
                                    명령종류풀[삽입인덱스] = 루프종류.
                                    명령결과풀[삽입인덱스] = 명령결과풀[루프인덱스].
                                    명령인자1풀[삽입인덱스] = 명령인자1풀[루프인덱스].
                                    명령인자1종류풀[삽입인덱스] = 명령인자1종류풀[루프인덱스].
                                    명령인자2풀[삽입인덱스] = 명령인자2풀[루프인덱스].
                                    명령인자2종류풀[삽입인덱스] = 명령인자2종류풀[루프인덱스].
                                    명령이름풀[삽입인덱스] = 명령이름풀[루프인덱스].
                                    명령타입풀[삽입인덱스] = 명령타입풀[루프인덱스].
                                    명령정수값풀[삽입인덱스] = 명령정수값풀[루프인덱스].
                                    명령문자열값풀[삽입인덱스] = 명령문자열값풀[루프인덱스].
                                    명령종류풀[루프인덱스] = 명령_없음.
                                }
                            }
                        }
                        루프번호++다.
                    }
                }
            }
        }
        번호++다.
    }

    (* 2단계: 순수 연산 불변 이동 *)
    (* 루프 내 산술 명령 중 모든 피연산자가 루프 밖에서 정의된 것을 이동 *)
    (* 안전성: 피연산자가 루프 내 어떤 명령(인자, 결과 모두)에도 의해 쓰이지 않아야 함 *)
    번호 = 0.
    (번호 < 명령수)동안 {
        정수 인덱스 = 명령시작 + 번호.
        (명령종류풀[인덱스] == 명령_이동)이면 {
            정수 대상레이블 = 명령인자1풀[인덱스].
            정수 해시 = 대상레이블 % 256.
            해시 < 0이면 { 해시 = 해시 + 256. }
            (레이블유효풀[해시] == 대상레이블 + 1)이면 {
                정수 루프시작 = 레이블위치풀[해시].
                정수 루프끝 = 번호.
                (루프시작 < 루프끝)이면 {
                    정수 루프번호 = 루프시작 + 1.
                    (루프번호 < 루프끝)동안 {
                        정수 루프인덱스 = 명령시작 + 루프번호.
                        정수 루프종류 = 명령종류풀[루프인덱스].

                        정수 순수임 = 0.
                        (루프종류 == 명령_더하기)이면 { 순수임 = 1. }
                        (루프종류 == 명령_빼기)이면 { 순수임 = 1. }
                        (루프종류 == 명령_곱하기)이면 { 순수임 = 1. }
                        (루프종류 == 명령_나누기)이면 { 순수임 = 1. }
                        (루프종류 == 명령_나머지)이면 { 순수임 = 1. }
                        (루프종류 == 명령_비트와)이면 { 순수임 = 1. }
                        (루프종류 == 명령_비트또는)이면 { 순수임 = 1. }
                        (루프종류 == 명령_비트배타)이면 { 순수임 = 1. }
                        (루프종류 == 명령_왼쪽이동)이면 { 순수임 = 1. }
                        (루프종류 == 명령_오른쪽이동)이면 { 순수임 = 1. }

                        (순수임 != 0)이면 {
                            정수 연산결과 = 명령결과풀[루프인덱스].
                            정수 피연산자1 = 명령인자1풀[루프인덱스].
                            정수 피연산자2 = 명령인자2풀[루프인덱스].

                            (* 결과가 임시(종류0)인지 확인 *)
                            정수 이동가능 = 0.
                            (연산결과 >= 0) * (임시변수종류풀[연산결과] == 0)이면 {
                                이동가능 = 1.
                            }

                            (* 피연산자가 루프 내에서 어떤 방식으로든 쓰이는지 확인 *)
                            (* 결과, 인자1(저장 대상 포함)을 모두 검사 *)
                            이동가능 != 0이면 {
                                정수 확인번호 = 루프시작 + 1.
                                (확인번호 < 루프끝) * (이동가능 != 0)동안 {
                                    정수 확인인덱스 = 명령시작 + 확인번호.
                                    정수 확인종류 = 명령종류풀[확인인덱스].
                                    (확인종류 != 명령_없음) * (확인번호 != 루프번호)이면 {
                                        정수 확인결과 = 명령결과풀[확인인덱스].
                                        (* 피연산자가 루프 내에서 재정의되면 불변 아님 *)
                                        (확인결과 == 피연산자1)이면 { 이동가능 = 0. }
                                        (확인결과 == 피연산자2)이면 { 이동가능 = 0. }
                                        (* 결과가 루프 내 다른 곳에서 재정의되면 불변 아님 *)
                                        (확인결과 == 연산결과)이면 { 이동가능 = 0. }
                                        (* 증가/감소 명령은 인자1을 in-place 수정 *)
                                        (확인종류 == 명령_증가) + (확인종류 == 명령_감소) > 0이면 {
                                            정수 증감대상 = 명령인자1풀[확인인덱스].
                                            (증감대상 == 피연산자1)이면 { 이동가능 = 0. }
                                            (증감대상 == 피연산자2)이면 { 이동가능 = 0. }
                                        }
                                        (* 저장 명령은 인자1(변수)을 수정 *)
                                        (확인종류 == 명령_저장)이면 {
                                            정수 저장대상 = 명령인자1풀[확인인덱스].
                                            (저장대상 == 피연산자1)이면 { 이동가능 = 0. }
                                            (저장대상 == 피연산자2)이면 { 이동가능 = 0. }
                                        }
                                        (* 복사 명령의 결과도 확인 — 이미 확인결과로 커버됨 *)
                                    }
                                    확인번호++다.
                                }
                            }

                            이동가능 != 0이면 {
                                정수 삽입위치 = 루프시작 - 1.
                                정수 빈슬롯찾음 = 0.
                                (삽입위치 >= 0) * (빈슬롯찾음 == 0)동안 {
                                    정수 삽입인덱스 = 명령시작 + 삽입위치.
                                    (명령종류풀[삽입인덱스] == 명령_없음)이면 {
                                        빈슬롯찾음 = 1.
                                    }
                                    아니면 { 삽입위치--다. }
                                }

                                빈슬롯찾음 != 0이면 {
                                    정수 삽입인덱스 = 명령시작 + 삽입위치.
                                    명령종류풀[삽입인덱스] = 루프종류.
                                    명령결과풀[삽입인덱스] = 명령결과풀[루프인덱스].
                                    명령인자1풀[삽입인덱스] = 명령인자1풀[루프인덱스].
                                    명령인자1종류풀[삽입인덱스] = 명령인자1종류풀[루프인덱스].
                                    명령인자2풀[삽입인덱스] = 명령인자2풀[루프인덱스].
                                    명령인자2종류풀[삽입인덱스] = 명령인자2종류풀[루프인덱스].
                                    명령이름풀[삽입인덱스] = 명령이름풀[루프인덱스].
                                    명령타입풀[삽입인덱스] = 명령타입풀[루프인덱스].
                                    명령정수값풀[삽입인덱스] = 명령정수값풀[루프인덱스].
                                    명령문자열값풀[삽입인덱스] = 명령문자열값풀[루프인덱스].
                                    명령종류풀[루프인덱스] = 명령_없음.
                                }
                            }
                        }
                        루프번호++다.
                    }
                }
            }
        }
        번호++다.
    }
}

[정수 구문루트를 PE_프로그램인코딩]은 {
    PE_코드버퍼초기화().

    (* 0. 전역 변수 BSS 오프셋 할당 *)
    PE_전역변수할당().

    (* 0b. 피프홀 최적화 — 불필요한 복사 제거 *)
    정수 최적화번호 = 0.
    (최적화번호 < 중간함수총수)동안 {
        PE_피프홀최적화(최적화번호).
        최적화번호++다.
    }

    (* 0c. 죽은 저장 제거 — 결과가 사용되지 않는 명령 제거 *)
    정수 죽은저장번호 = 0.
    (죽은저장번호 < 중간함수총수)동안 {
        PE_죽은저장제거(죽은저장번호).
        죽은저장번호++다.
    }

    (* 0d. 인라이닝 분석 — 작은 함수 후보 식별 *)
    PE_인라이닝분석().

    (* 0e. 인라이닝 적용 — 래퍼 함수 호출 대상 교체 + 소함수 IR 복사 *)
    PE_인라이닝적용().

    (* 0f. 루프 불변 코드 이동 — 루프 내 상수/순수연산을 루프 밖으로 *)
    정수 불변이동번호 = 0.
    (불변이동번호 < 중간함수총수)동안 {
        PE_루프불변이동(불변이동번호).
        불변이동번호++다.
    }

    (* 1. 문자열 상수 사전 수집 *)
    PE_문자열사전수집().

    (* 1b. 실수 상수 사전 수집 *)
    PE_실수상수사전수집().

    (* 2. 문자열 데이터 생성 *)
    PE_문자열데이터생성().

    (* 2b. 실수 상수 데이터 생성 *)
    PE_실수데이터생성().

    (* 2c. CRT 스타트업: __getmainargs(&argc,&argv,&env,0,0) → main(argc,argv) *)
    "__startup"을 레이블등록다.
    (* sub rsp, 96 — 정렬유지(96%16=0이지만 call시 push로 8빠짐, 96에서 8빼면 88, 88%16=8 → call후 0 정렬) *)
    72를 코드바이트쓰기다.  131을 코드바이트쓰기다.  236을 코드바이트쓰기다.  96을 코드바이트쓰기다.
    (* lea rcx, [rsp+48] — &argc: 48 8D 4C 24 30 *)
    72를 코드바이트쓰기다.  141을 코드바이트쓰기다.  76을 코드바이트쓰기다.  36을 코드바이트쓰기다.  48을 코드바이트쓰기다.
    (* lea rdx, [rsp+56] — &argv: 48 8D 54 24 38 *)
    72를 코드바이트쓰기다.  141을 코드바이트쓰기다.  84을 코드바이트쓰기다.  36을 코드바이트쓰기다.  56을 코드바이트쓰기다.
    (* lea r8, [rsp+64] — &env: 4C 8D 44 24 40 *)
