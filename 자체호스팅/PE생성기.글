(*
 * PE생성기.글 — IR → x86-64 기계어 인코더
 *
 * ml64.exe / link.exe 의존성 없이 직접 기계어를 생성한다.
 * 이 파일은 바이트 버퍼, 레이블/패치 시스템, x86-64 명령어 인코더를 포함한다.
 * PE 파일 생성은 별도 파일에서 담당한다.
 *)

포함 "구문분석기.글"
포함 "IR변환기.글"

(* ===== 1. 바이트 버퍼 ===== *)
(* 코드(.text) 섹션용 바이트 버퍼 *)
정수 코드버퍼최대 = 1048576.
문자[1048576] 코드버퍼.
정수 코드버퍼위치 = 0.

(* 데이터(.rdata) 섹션용 바이트 버퍼 *)
정수 데이터버퍼최대 = 524288.
문자[524288] 데이터버퍼.
정수 데이터버퍼위치 = 0.

(* 코드 버퍼에 1바이트 쓰기 *)
[정수 바이트값을 코드바이트쓰기]는 {
    코드버퍼위치 < 코드버퍼최대이면 {
        코드버퍼[코드버퍼위치] = 바이트값.
        코드버퍼위치++다.
    }
}

(* 코드 버퍼에 리틀엔디안 32비트 정수 쓰기 *)
[정수 값을 코드리틀엔디안32쓰기]는 {
    (값 & 255)을 코드바이트쓰기다.
    ((값 >> 8) & 255)을 코드바이트쓰기다.
    ((값 >> 16) & 255)을 코드바이트쓰기다.
    ((값 >> 24) & 255)을 코드바이트쓰기다.
}

(* 데이터 버퍼에 1바이트 쓰기 *)
[정수 바이트값을 데이터바이트쓰기]는 {
    데이터버퍼위치 < 데이터버퍼최대이면 {
        데이터버퍼[데이터버퍼위치] = 바이트값.
        데이터버퍼위치++다.
    }
}

(* 데이터 버퍼에 리틀엔디안 32비트 정수 쓰기 *)
[정수 값을 데이터리틀엔디안32쓰기]는 {
    (값 & 255)을 데이터바이트쓰기다.
    ((값 >> 8) & 255)을 데이터바이트쓰기다.
    ((값 >> 16) & 255)을 데이터바이트쓰기다.
    ((값 >> 24) & 255)을 데이터바이트쓰기다.
}

(* ===== 2. 레이블 + 패치 시스템 ===== *)

(* 레이블: 이름 → 코드버퍼 내 오프셋 *)
정수 최대레이블수 = 65536.
문자열[65536] 레이블이름풀.
정수[65536] 레이블오프셋풀.
정수 레이블총수 = 0.

(* 패치: 나중에 해결할 점프/호출 대상 *)
(* 패치위치: 코드버퍼에서 rel32가 시작하는 오프셋 *)
(* 패치대상이름: 해결할 레이블 이름 *)
정수 최대패치수 = 65536.
정수[65536] 패치위치풀.
문자열[65536] 패치대상이름풀.
정수 패치총수 = 0.

(* 레이블 이름용 문자 버퍼 *)
문자[524288] 레이블문자버퍼.
정수 레이블문자위치 = 0.

(* 레이블 이름을 내부 버퍼에 복사하여 저장 *)
[문자열 이름을 레이블이름복사]는 → 문자열 {
    문자열 결과는 레이블문자버퍼 + 레이블문자위치.
    정수 길이는 글자수(이름).
    정수 번호 = 0.
    (번호 < 길이)동안 {
        레이블문자버퍼[레이블문자위치] = 이름[번호].
        레이블문자위치++다.
        번호++다.
    }
    레이블문자버퍼[레이블문자위치] = 0.
    레이블문자위치++다.
    반환 결과.
}

(* 레이블 등록: 현재 코드버퍼위치를 이름에 연결 *)
[문자열 이름을 레이블등록]은 {
    레이블총수 < 최대레이블수이면 {
        레이블이름풀[레이블총수] = 이름을 레이블이름복사다.
        레이블오프셋풀[레이블총수] = 코드버퍼위치.
        레이블총수++다.
    }
}

(* 레이블 이름으로 오프셋 검색 — 없으면 -1 *)
[문자열 이름으로 레이블검색]은 → 정수 {
    정수 번호 = 0.
    (번호 < 레이블총수)동안 {
        문자열_비교(이름, 레이블이름풀[번호]) == 0이면 {
            반환 레이블오프셋풀[번호].
        }
        번호++다.
    }
    반환 -1.
}

(* 패치 등록: 현재 코드버퍼위치에 rel32 자리를 표시 *)
(* 호출 시 코드버퍼위치는 rel32의 시작 위치여야 함 *)
[문자열 대상이름을 패치등록]은 {
    패치총수 < 최대패치수이면 {
        패치위치풀[패치총수] = 코드버퍼위치.
        패치대상이름풀[패치총수] = 대상이름을 레이블이름복사다.
        패치총수++다.
    }
}

(* 모든 패치 해결: rel32 = 대상오프셋 - (패치위치 + 4) *)
[패치모두해결]은 {
    정수 번호 = 0.
    (번호 < 패치총수)동안 {
        정수 위치는 패치위치풀[번호].
        문자열 대상이름은 패치대상이름풀[번호].
        정수 대상오프셋 = 대상이름으로 레이블검색다.
        대상오프셋 >= 0이면 {
            정수 상대값은 대상오프셋 - (위치 + 4).
            (* 리틀엔디안으로 코드버퍼에 직접 기록 *)
            코드버퍼[위치] = 상대값 & 255.
            코드버퍼[위치 + 1] = (상대값 >> 8) & 255.
            코드버퍼[위치 + 2] = (상대값 >> 16) & 255.
            코드버퍼[위치 + 3] = (상대값 >> 24) & 255.
        }
        번호++다.
    }
}

(* ===== 3. 함수 맹글링 (한글 → ASCII) ===== *)
(* 어셈블리생성기와 동일한 맹글링 체계 사용 *)

문자열[512] PE_맹글링원본풀.
문자열[512] PE_맹글링결과풀.
정수 PE_맹글링수 = 0.
문자[131072] PE_맹글링버퍼.
정수 PE_맹글링버퍼위치 = 0.

[문자열 이름을 PE_함수맹글링]은 → 문자열 {
    문자열_비교(이름, "시작하기") == 0이면 { 반환 "main". }
    (* 기존 맹글링 검색 *)
    정수 번호 = 0.
    (번호 < PE_맹글링수)동안 {
        문자열_비교(이름, PE_맹글링원본풀[번호]) == 0이면 {
            반환 PE_맹글링결과풀[번호].
        }
        번호++다.
    }
    (* 새 맹글링 생성: _fn0, _fn1, ... *)
    PE_맹글링원본풀[PE_맹글링수] = 이름.
    문자열 결과는 PE_맹글링버퍼 + PE_맹글링버퍼위치.
    버퍼에_쓰기(결과, 32, "_fn%d", PE_맹글링수).
    PE_맹글링버퍼위치 = PE_맹글링버퍼위치 + 글자수(결과) + 1.
    PE_맹글링결과풀[PE_맹글링수] = 결과.
    PE_맹글링수++다.
    반환 결과.
}

