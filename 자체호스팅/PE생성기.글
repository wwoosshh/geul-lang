(* ===== 6. 스택 오프셋 계산 ===== *)
(* 어셈블리생성기의 프레임 계산과 동일 *)

정수[65536] PE_임시오프셋.

(* ===== 6b. 전역 변수 BSS 섹션 ===== *)
정수[65536] PE_전역오프셋.       (* 전역 임시변수 → BSS 내 바이트 오프셋 *)
정수 PE_전역총크기 = 0.          (* BSS 섹션 총 바이트 크기 *)
정수 PE_BSS주소 = 0.             (* BSS 섹션의 가상 주소 — PE_파일쓰기에서 설정 *)

(* 전역 변수에 BSS 오프셋을 할당하는 함수 *)
[PE_전역변수할당]은 {
    PE_전역총크기 = 0.
    정수 번호 = 0.
    (번호 < 임시변수총수)동안 {
        임시변수종류풀[번호] == 2이면 {
            (* 8바이트 정렬 *)
            (PE_전역총크기 % 8) != 0이면 {
                PE_전역총크기 = PE_전역총크기 + (8 - (PE_전역총크기 % 8)).
            }
            PE_전역오프셋[번호] = PE_전역총크기.
            정수 슬롯바이트 = 임시변수크기풀[번호].
            슬롯바이트 <= 0이면 { 슬롯바이트 = 8. }
            PE_전역총크기 = PE_전역총크기 + 슬롯바이트.
        }
        번호++다.
    }
}

(* 전역 변수 RIP-상대 패치 테이블 *)
정수 PE_최대전역패치 = 262144.
정수[262144] PE_전역패치위치.   (* 코드버퍼 내 disp32 시작 위치 *)
정수[262144] PE_전역패치임시.   (* 대상 전역 임시변수 번호 *)
정수 PE_전역패치수 = 0.

(* 전역 패치 등록 — 현재 코드버퍼위치에 disp32 자리를 표시 *)
[정수 임시번호를 PE_전역패치추가]은 {
    (PE_전역패치수 < PE_최대전역패치)이면 {
        PE_전역패치위치[PE_전역패치수] = 코드버퍼위치.
        PE_전역패치임시[PE_전역패치수] = 임시번호.
        PE_전역패치수++다.
    }
}

[정수 함수번호를 PE_프레임계산]은 → 정수 {
    정수 임시시작 = 중간함수임시시작풀[함수번호].
    정수 임시수 = 중간함수임시수풀[함수번호].

    (* 각 임시변수에 슬롯 할당 — 묶음이면 크기만큼, 아니면 8바이트 *)
    정수 현재오프셋 = 8.  (* rbp-8부터 시작 *)
    정수 번호 = 0.
    (번호 < 임시수)동안 {
        정수 인덱스 = 임시시작 + 번호.
        정수 종류 = 임시변수종류풀[인덱스].
        (* 전역(2)은 스택 할당 안 함 *)
        종류 != 2이면 {
            정수 슬롯크기 = 8.
            정수 묶음크기 = 임시변수크기풀[인덱스].
            묶음크기 > 8이면 {
                슬롯크기 = 묶음크기.
            }
            PE_임시오프셋[인덱스] = 현재오프셋.
            현재오프셋 = 현재오프셋 + 슬롯크기.
        }
        번호++다.
    }

    (* 호출용 공간: 최소 32바이트 섀도 + 추가 인자 *)
    정수 최대인자 = 0.
    정수 호출있음 = 0.
    정수 명령시작 = 중간함수명령시작풀[함수번호].
    정수 명령수 = 중간함수명령수풀[함수번호].
    번호 = 0.
    (번호 < 명령수)동안 {
        정수 인덱스 = 명령시작 + 번호.
        (명령종류풀[인덱스] == 명령_호출)이면 {
            호출있음 = 1.
            정수 호출인자수 = 명령인자1풀[인덱스].
            호출인자수 > 최대인자이면 {
                최대인자 = 호출인자수.
            }
        }
        번호++다.
    }
    (* 잎함수 감지: 호출이 없으면 섀도 공간 불필요 *)
    PE_현재잎함수 = 0.
    호출있음 == 0이면 {
        PE_현재잎함수 = 1.
    }
    정수 호출공간 = 0.
    호출있음 != 0이면 {
        최대인자 < 4이면 { 최대인자 = 4. }
        호출공간 = 최대인자 * 8.
    }

    정수 총합은 현재오프셋 + 호출공간.
    (* 16바이트 정렬 — 핀된 레지스터 push 수 고려 *)
    (* 스택: ret(8) + 핀push(8*핀수) + push_rbp(8) + sub_rsp(총합) *)
    (* call 시점에 (8 + 8*핀수 + 8 + 총합) % 16 == 0 이어야 함 *)
    정수 전체크기는 8 + PE_핀수 * 8 + 8 + 총합.
    (전체크기 % 16) != 0이면 {
        총합 = 총합 + 8.
    }
    반환 총합.
}

(* ===== 7. 문자열 상수 데이터 생성 ===== *)

(* 문자열 상수 풀 *)
정수 PE_최대문자열수 = 4096.
문자열[4096] PE_문자열풀.
정수[4096] PE_문자열오프셋풀.    (* 데이터버퍼 내 오프셋 *)
정수 PE_문자열수 = 0.

(* 문자열 상수 등록 — 중복 검사 후 인덱스 반환 *)
[문자열 값을 PE_문자열등록]은 → 정수 {
    정수 번호 = 0.
    (번호 < PE_문자열수)동안 {
        문자열_비교(값, PE_문자열풀[번호]) == 0이면 {
            반환 번호.
        }
        번호++다.
    }
    (PE_문자열수 < PE_최대문자열수)이면 {
        PE_문자열풀[PE_문자열수] = 값.
        PE_문자열오프셋풀[PE_문자열수] = -1.  (* 나중에 설정 *)
        PE_문자열수++다.
    }
    반환 PE_문자열수 - 1.
}

(* 모든 함수의 IR을 스캔하여 문자열 상수를 사전 수집 *)
[PE_문자열사전수집]은 {
    PE_문자열수 = 0.
    정수 번호 = 0.
    (번호 < 명령총수)동안 {
        (명령종류풀[번호] == 명령_상수문자열)이면 {
            명령문자열값풀[번호] != 0이면 {
                PE_문자열등록(명령문자열값풀[번호]).
            }
        }
        번호++다.
    }
}

(* 모든 함수의 IR을 스캔하여 실수 상수를 사전 수집 *)
[PE_실수상수사전수집]은 {
    PE_실수상수수 = 0.
    정수 번호 = 0.
    (번호 < 명령총수)동안 {
        (명령종류풀[번호] == 명령_상수실수)이면 {
            명령문자열값풀[번호] != 0이면 {
                PE_실수상수등록(명령문자열값풀[번호]).
            }
        }
        번호++다.
    }
}

(* 문자열 값을 데이터 버퍼에 바이트 배열로 기록 *)
(* 따옴표 제거, 이스케이프 시퀀스 처리, 널 종단 추가 *)
[문자열 값을 PE_문자열바이트기록]은 {
    값 == 0이면 {
        0을 데이터바이트쓰기다.
        반환.
    }
    정수 길이는 글자수(값).
    정수 시작 = 0.
    정수 끝은 길이.

    (* 따옴표 제거 *)
    (길이 > 0) * (값[0] == 34)이면 { 시작 = 1. }
    (끝 > 시작) * (값[끝 - 1] == 34)이면 { 끝 = 끝 - 1. }

    정수 위치는 시작.
    (위치 < 끝)동안 {
        정수 현재는 값[위치].
        (* 이스케이프 시퀀스 *)
        (현재 == 92) * (위치 + 1 < 끝)이면 {
            정수 다음은 값[위치 + 1].
            (다음 == 110)이면 { 10을 데이터바이트쓰기다. }        (* \n *)
            아니면 (다음 == 116)이면 { 9를 데이터바이트쓰기다. }  (* \t *)
            아니면 (다음 == 48)이면 { 0을 데이터바이트쓰기다. }   (* \0 *)
            아니면 (다음 == 34)이면 { 34를 데이터바이트쓰기다. }  (* \" *)
            아니면 (다음 == 92)이면 { 92를 데이터바이트쓰기다. }  (* \\ *)
            아니면 { 다음을 데이터바이트쓰기다. }
            위치 = 위치 + 2.
        }
        아니면 {
            (* 부호 없는 바이트 변환 *)
            정수 바이트값은 현재.
            바이트값 < 0이면 { 바이트값 = 바이트값 + 256. }
            바이트값을 데이터바이트쓰기다.
            위치++다.
        }
    }
    (* 널 종단 *)
    0을 데이터바이트쓰기다.
}

(* 모든 문자열 상수를 데이터 버퍼에 기록하고 오프셋 설정 *)
[PE_문자열데이터생성]은 {
    정수 번호 = 0.
    (번호 < PE_문자열수)동안 {
        PE_문자열오프셋풀[번호] = 데이터버퍼위치.
        PE_문자열바이트기록(PE_문자열풀[번호]).
        번호++다.
    }
}

(* ===== 8. 호출 인자 버퍼 ===== *)

정수[64] PE_인자목록.
정수 PE_인자수 = 0.
정수[256] PE_인자저장.
정수[16] PE_인자수저장.
정수 PE_저장깊이 = 0.

(* ===== 9. 논리 레이블 카운터 ===== *)

정수 PE_논리레이블번호 = 0.

(* 논리 레이블 이름 생성 — 내부 버퍼에 저장 *)
문자[262144] PE_논리레이블버퍼.
정수 PE_논리레이블버퍼위치 = 0.

[정수 번호를 PE_논리레이블이름]은 → 문자열 {
    문자열 결과는 PE_논리레이블버퍼 + PE_논리레이블버퍼위치.
    버퍼에_쓰기(결과, 32, "__PLL%d", 번호).
    PE_논리레이블버퍼위치 = PE_논리레이블버퍼위치 + 글자수(결과) + 1.
    반환 결과.
}

(* IR 레이블 번호 → 레이블 이름 생성 *)
문자[262144] PE_IR레이블버퍼.
정수 PE_IR레이블버퍼위치 = 0.

[정수 번호를 PE_IR레이블이름]은 → 문자열 {
    문자열 결과는 PE_IR레이블버퍼 + PE_IR레이블버퍼위치.
    버퍼에_쓰기(결과, 32, "__L%d", 번호).
    PE_IR레이블버퍼위치 = PE_IR레이블버퍼위치 + 글자수(결과) + 1.
    반환 결과.
}

(* ===== 9b. 레지스터 핀 (루프 변수 최적화) ===== *)

정수 PE_최대핀수 = 5.
정수[5] PE_핀임시번호.     (* 핀된 임시변수 인덱스, -1이면 미사용 *)
정수[5] PE_핀레지번호.     (* 핀된 레지스터 번호: rbx=3, r12=12, r13=13, r14=14, r15=15 *)
정수 PE_핀수 = 0.           (* 실제 핀된 수 *)

(* 임시변수 사용 빈도 카운트용 *)
정수[65536] PE_사용빈도.

(* 임시변수가 핀된 레지스터 번호 반환, 핀 안됐으면 -1 *)
[정수 임시번호를 PE_핀레지스터]는 → 정수 {
    정수 번호 = 0.
    (번호 < PE_핀수)동안 {
        PE_핀임시번호[번호] == 임시번호이면 {
            반환 PE_핀레지번호[번호].
        }
        번호++다.
    }
    반환 -1.
}

(* 레지스터 분석: 함수 내 루프에서 자주 사용되는 임시변수를 핀 *)
[정수 함수번호를 PE_레지스터분석]은 {
    PE_핀수 = 0.
    PE_핀임시번호[0] = -1.
    PE_핀임시번호[1] = -1.
    PE_핀임시번호[2] = -1.
    PE_핀임시번호[3] = -1.
    PE_핀임시번호[4] = -1.
    PE_핀레지번호[0] = 3.    (* rbx *)
    PE_핀레지번호[1] = 12.   (* r12 *)
    PE_핀레지번호[2] = 13.   (* r13 *)
    PE_핀레지번호[3] = 14.   (* r14 *)
    PE_핀레지번호[4] = 15.   (* r15 *)

    정수 임시시작 = 중간함수임시시작풀[함수번호].
    정수 임시수 = 중간함수임시수풀[함수번호].
    정수 명령시작 = 중간함수명령시작풀[함수번호].
    정수 명령수 = 중간함수명령수풀[함수번호].

    (* 임시변수 사용 빈도 초기화 *)
    정수 초기번호 = 0.
    (초기번호 < 임시수)동안 {
        PE_사용빈도[임시시작 + 초기번호] = 0.
        초기번호++다.
    }

    (* 루프 깊이 추적: 레이블 이름에 기반 — 간소화: 전체 명령 스캔 *)
    (* 루프 내부인지 추적하는 간단한 방법: *)
    (* 이동(jmp) 명령이 뒤가 아닌 앞(이미 지난 레이블)을 가리키면 루프 *)
    (* 더 간단하게: 모든 인자1/인자2 사용 빈도를 세되, 루프 내부일 때 가중치 부여 *)
    (* 가장 간단한 접근: 그냥 모든 읽기 사용 빈도를 센다 *)
    정수 번호 = 0.
    (번호 < 명령수)동안 {
        정수 인덱스 = 명령시작 + 번호.
        정수 종류 = 명령종류풀[인덱스].
        (* 무효 명령은 건너뜀 *)
        (종류 != 명령_없음)이면 {
            정수 분석인자1 = 명령인자1풀[인덱스].
            정수 분석인자2 = 명령인자2풀[인덱스].
            (* 읽기 피연산자 빈도 증가 *)
            (분석인자1 >= 임시시작) * (분석인자1 < 임시시작 + 임시수) > 0이면 {
                PE_사용빈도[분석인자1] = PE_사용빈도[분석인자1] + 1.
            }
            (분석인자2 >= 임시시작) * (분석인자2 < 임시시작 + 임시수) > 0이면 {
                PE_사용빈도[분석인자2] = PE_사용빈도[분석인자2] + 1.
            }
            (* 축적자 보너스: 결과가 인자1 또는 인자2와 같으면 가중치 추가 *)
            정수 분석결과 = 명령결과풀[인덱스].
            (분석결과 >= 임시시작) * (분석결과 < 임시시작 + 임시수) > 0이면 {
                (분석결과 == 분석인자1) + (분석결과 == 분석인자2) > 0이면 {
                    PE_사용빈도[분석결과] = PE_사용빈도[분석결과] + 5.
                }
            }
        }
        번호++다.
    }

    (* 주소가 취해지는 변수 표시 — 핀에서 제외해야 함 *)
    정수 주소탐색 = 0.
    (주소탐색 < 명령수)동안 {
        정수 주소탐색위치 = 명령시작 + 주소탐색.
        (명령종류풀[주소탐색위치] == 명령_주소)이면 {
            정수 주소참조임시 = 명령인자1풀[주소탐색위치].
            (주소참조임시 >= 0) * (주소참조임시 < 65536) > 0이면 {
                PE_사용빈도[주소참조임시] = -1.  (* 음수로 표시하여 핀 제외 *)
            }
        }
        주소탐색++다.
    }

    (* 상위 5개 가장 많이 사용된 임시변수를 선택 *)
    (* 조건: 로컬(1) 또는 매개변수(3), 실수 아님, 사용 4회 이상, 주소 미취득 *)
    정수 핀번호 = 0.
    (핀번호 < 5)동안 {
        정수 최대빈도 = 3.   (* 최소 4회 이상이어야 하므로 임계값 3 *)
        정수 최대인덱스 = -1.
        정수 검사번호 = 0.
        (검사번호 < 임시수)동안 {
            정수 검사인덱스 = 임시시작 + 검사번호.
            정수 임시종류 = 임시변수종류풀[검사인덱스].
            (* 로컬(1) 또는 매개변수(3)만 *)
            (임시종류 == 1) + (임시종류 == 3) > 0이면 {
                (* 실수/배열/묶음 아닌 스칼라만 *)
                (PE_실수여부(검사인덱스) == 0) * (임시변수크기풀[검사인덱스] <= 8) > 0이면 {
                    (* 이미 핀된 것은 제외 *)
                    정수 이미핀됨 = 0.
                    정수 확인번호 = 0.
                    (확인번호 < 핀번호)동안 {
                        PE_핀임시번호[확인번호] == 검사인덱스이면 {
                            이미핀됨 = 1.
                        }
                        확인번호++다.
                    }
                    이미핀됨 == 0이면 {
                        PE_사용빈도[검사인덱스] > 최대빈도이면 {
                            최대빈도 = PE_사용빈도[검사인덱스].
                            최대인덱스 = 검사인덱스.
                        }
                    }
                }
            }
            검사번호++다.
        }
        최대인덱스 >= 0이면 {
            PE_핀임시번호[핀번호] = 최대인덱스.
            PE_핀수 = 핀번호 + 1.
        }
        아니면 {
            핀번호 = 5.  (* 더 이상 후보 없으면 중단 *)
        }
        핀번호++다.
    }
}

(* ===== 10. 피연산자 적재/저장 헬퍼 ===== *)

(* 임시변수를 r10에 적재 *)
[정수 임시번호를 PE_적재_r10]은 {
    임시번호 < 0이면 { 반환. }
    (* 캐시 확인: 이미 r10에 있으면 생략 *)
    (임시번호 == PE_캐시_r10임시)이면 { 반환. }
    (* 캐시 확인: r11에 있으면 레지스터간 복사 *)
    (임시번호 == PE_캐시_r11임시)이면 {
        인코딩_mov_reg_reg(레지_R10, 레지_R11).
        PE_캐시_r10임시 = 임시번호.
        반환.
    }
    (* 전역 변수(종류2)이면 RIP-상대 주소 사용 *)
    임시변수종류풀[임시번호] == 2이면 {
        임시변수크기풀[임시번호] > 8이면 {
            (* 배열/묶음 전역: lea r10, [rip+disp32] → 4C 8D 15 [disp32] *)
            76을 코드바이트쓰기다.    (* 0x4C *)
            141을 코드바이트쓰기다.   (* 0x8D *)
            21을 코드바이트쓰기다.    (* 0x15 *)
            PE_전역패치추가(임시번호).
            0을 코드리틀엔디안32쓰기다.
            PE_캐시_r10임시 = 임시번호.
            반환.
        }
        (* 스칼라 전역: mov r10, QWORD PTR [rip+disp32] → 4C 8B 15 [disp32] *)
        76을 코드바이트쓰기다.    (* 0x4C = REX.W + REX.R *)
        139를 코드바이트쓰기다.   (* 0x8B *)
        21을 코드바이트쓰기다.    (* 0x15 = ModRM(00,010,101) RIP-relative *)
        PE_전역패치추가(임시번호).
        0을 코드리틀엔디안32쓰기다.
        PE_캐시_r10임시 = 임시번호.
        반환.
    }
    (* 핀된 레지스터 확인 *)
