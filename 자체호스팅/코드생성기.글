(* 함수 이름 변환: 시작하기 → main *)
[문자열 이름을 함수이름변환]은 → 문자열 {
    문자열_비교(이름, "시작하기") == 0이면 { 반환 "main". }
    반환 이름.
}

(* ===== 연산자 → C 문자열 ===== *)

[정수 연산종류를 연산자문자열변환]은 → 문자열 {
    (연산종류 == 종류_더하기)이면    { 반환 "+". }
    (연산종류 == 종류_빼기)이면      { 반환 "-". }
    (연산종류 == 종류_곱하기)이면    { 반환 "*". }
    (연산종류 == 종류_나누기)이면    { 반환 "/". }
    (연산종류 == 종류_나머지)이면    { 반환 "%". }
    (연산종류 == 종류_같다)이면      { 반환 "==". }
    (연산종류 == 종류_다르다)이면    { 반환 "!=". }
    (연산종류 == 종류_크다)이면      { 반환 ">". }
    (연산종류 == 종류_작다)이면      { 반환 "<". }
    (연산종류 == 종류_크거나같다)이면 { 반환 ">=". }
    (연산종류 == 종류_작거나같다)이면 { 반환 "<=". }
    (연산종류 == 종류_그리고)이면    { 반환 "&&". }
    (연산종류 == 종류_또는)이면      { 반환 "||". }
    (연산종류 == 종류_아닌)이면      { 반환 "!". }
    (연산종류 == 종류_비트와)이면    { 반환 "&". }
    (연산종류 == 종류_비트또는)이면  { 반환 "|". }
    (연산종류 == 종류_비트배타)이면  { 반환 "^". }
    (연산종류 == 종류_왼쪽이동)이면  { 반환 "<<". }
    (연산종류 == 종류_오른쪽이동)이면 { 반환 ">>". }
    (연산종류 == 종류_대입)이면      { 반환 "=". }
    (연산종류 == 종류_비트아닌)이면  { 반환 "~". }
    반환 "/* ? */".
}

(* ===== 전방선언 ===== *)
외부 [정수 노드를 표현식코드생성]은.
외부 [정수 노드를 문장코드생성]은.
외부 [정수 노드를 블록코드생성]은.

(* ===== 타입 코드 생성 ===== *)

[정수 타입을 타입코드생성]은 {
    타입 < 0이면 {
        "void"를 쓰다.
        반환.
    }

    정수 종류 = 노드종류풀[타입].

    (종류 == 노드_기본타입)이면 {
        정수 원시 = 노드연산자풀[타입].
        (원시 == 종류_정수)이면       { "int"을 쓰다. 반환. }
        (원시 == 종류_긴정수)이면     { "long long"을 쓰다. 반환. }
        (원시 == 종류_실수)이면       { "double"을 쓰다. 반환. }
        (원시 == 종류_문자)이면       { "char"을 쓰다. 반환. }
        (원시 == 종류_문자열)이면     { "char*"를 쓰다. 반환. }
        (원시 == 종류_참거짓)이면     { "int"을 쓰다. 반환. }
        (원시 == 종류_공허)이면       { "void"를 쓰다. 반환. }
        (원시 == 종류_짧은정수)이면   { "short"를 쓰다. 반환. }
        (원시 == 종류_작은정수)이면   { "char"을 쓰다. 반환. }
        (원시 == 종류_부호없는)이면   { "unsigned int"를 쓰다. 반환. }
        (원시 == 종류_짧은실수)이면   { "float"를 쓰다. 반환. }
        (원시 == 종류_가변목록)이면   { "va_list"를 쓰다. 반환. }
        "int"을 쓰다.
        반환.
    }

    (종류 == 노드_참조타입)이면 {
        노드왼쪽풀[타입]을 타입코드생성다.
        "*"를 쓰다.
        반환.
    }

    (종류 == 노드_배열타입)이면 {
        노드왼쪽풀[타입]을 타입코드생성다.
        반환.
    }

    (종류 == 노드_묶음타입명)이면 {
        문자열 이름 = 노드이름풀[타입].
        별칭이름확인(이름) 이면 {
            "%s"를 이름을 쓰다.
        }
        아니면 나열이름확인(이름) 이면 {
            "enum %s"를 이름을 쓰다.
        }
        아니면 합침이름확인(이름) 이면 {
            "union %s"를 이름을 쓰다.
        }
        아니면 {
            "struct %s"를 이름을 쓰다.
        }
        반환.
    }

    "int"을 쓰다.
}

(* 배열 크기 접미사 *)
[정수 타입을 배열접미사생성]은 {
    타입 >= 0이면 {
        (노드종류풀[타입] == 노드_배열타입)이면 {
            "[%lld]"를 노드정수풀[타입]을 쓰다.
        }
    }
}

(* ===== 헤더 출력 ===== *)

[헤더출력]은 {
    "/* 글cc에 의해 생성됨 */\n"을 쓰다.
    "#include <stdio.h>\n"을 쓰다.
    "#include <stdlib.h>\n"을 쓰다.
    "#include <string.h>\n"을 쓰다.
    "#include <stdarg.h>\n"을 쓰다.
    "#include <locale.h>\n"을 쓰다.
    "#if defined(_WIN32) && !defined(__TINYC__)\n"을 쓰다.
    "#include <windows.h>\n"을 쓰다.
    "#endif\n"을 쓰다.
    "\n"을 쓰다.
}

(* ===== 런타임 출력 ===== *)

[런타임출력]은 {
    "/* ===== 글 런타임 함수 ===== */\n\n"을 쓰다.
    "#if defined(_WIN32) && !defined(__TINYC__)\n"을 쓰다.
    "static char* _ansi_to_utf8(const char* s) {\n"을 쓰다.
    "    int wl = MultiByteToWideChar(0, 0, s, -1, NULL, 0);\n"을 쓰다.
    "    wchar_t* ws = (wchar_t*)malloc(wl * sizeof(wchar_t));\n"을 쓰다.
    "    MultiByteToWideChar(0, 0, s, -1, ws, wl);\n"을 쓰다.
    "    int ul = WideCharToMultiByte(65001, 0, ws, -1, NULL, 0, NULL, NULL);\n"을 쓰다.
    "    char* u = (char*)malloc(ul);\n"을 쓰다.
    "    WideCharToMultiByte(65001, 0, ws, -1, u, ul, NULL, NULL);\n"을 쓰다.
    "    free(ws); return u;\n"을 쓰다.
    "}\n"을 쓰다.
    "#endif\n\n"을 쓰다.
    "static void 출력_정수(int v) { printf(\"%%d\\n\", v); }\n"을 쓰다.
    "static void 출력_긴정수(long long v) { printf(\"%%lld\\n\", v); }\n"을 쓰다.
    "static void 출력_실수(double v) { printf(\"%%f\\n\", v); }\n"을 쓰다.
    "static void 출력_문자열(char *v) { printf(\"%%s\\n\", v); }\n"을 쓰다.
    "static void 출력_문자(char v) { printf(\"%%c\\n\", v); }\n"을 쓰다.
    "\n"을 쓰다.
    "#define 출력(x) _Generic((0, (x)), \\\n"을 쓰다.
    "    int: 출력_정수, \\\n"을 쓰다.
    "    long long: 출력_긴정수, \\\n"을 쓰다.
    "    double: 출력_실수, \\\n"을 쓰다.
    "    float: 출력_실수, \\\n"을 쓰다.
    "    char: 출력_문자, \\\n"을 쓰다.
    "    char*: 출력_문자열 \\\n"을 쓰다.
    ")(x)\n\n"을 쓰다.
}

(* ===== 표현식 코드 생성 ===== *)

[정수 노드를 표현식코드생성]은 {
    노드 < 0이면 { 반환. }

    정수 종류 = 노드종류풀[노드].

    (종류 == 노드_정수리터럴)이면 {
        "%lld"를 노드정수풀[노드]를 쓰다.
        반환.
    }

    (종류 == 노드_실수리터럴)이면 {
        "%s"를 노드문자열풀[노드]를 쓰다.
        반환.
    }

    (종류 == 노드_문자열리터럴)이면 {
        "%s"를 노드문자열풀[노드]를 쓰다.
        반환.
    }

    (종류 == 노드_문자리터럴)이면 {
        "%s"를 노드문자열풀[노드]를 쓰다.
        반환.
    }

    (종류 == 노드_식별자)이면 {
        "%s"를 노드이름풀[노드]를 쓰다.
        반환.
    }

    (종류 == 노드_이항연산)이면 {
        "("를 쓰다.
        노드왼쪽풀[노드]를 표현식코드생성다.
        문자열 연산기호는 연산자문자열변환(노드연산자풀[노드]).
        " %s "를 연산기호를 쓰다.
        노드오른쪽풀[노드]를 표현식코드생성다.
        ")"를 쓰다.
        반환.
    }

    (종류 == 노드_단항연산)이면 {
        문자열 연산기호는 연산자문자열변환(노드연산자풀[노드]).
        "(%s"를 연산기호를 쓰다.
        노드왼쪽풀[노드]를 표현식코드생성다.
        ")"를 쓰다.
        반환.
    }

    (종류 == 노드_호출)이면 {
        "%s("를 노드이름풀[노드]를 쓰다.
        정수 인자 = 노드왼쪽풀[노드].
        정수 첫번째 = 1.
        (인자 >= 0)동안 {
            첫번째 == 0이면 { ", "를 쓰다. }
            인자값풀[인자]를 표현식코드생성다.
            첫번째 = 0.
            인자 = 인자다음풀[인자].
        }
        ")"를 쓰다.
        반환.
    }

    (종류 == 노드_대입)이면 {
        노드왼쪽풀[노드]를 표현식코드생성다.
        정수 연산 = 노드연산자풀[노드].
        (연산 == 종류_더하기대입)이면    { " += "를 쓰다. }
        아니면 (연산 == 종류_빼기대입)이면    { " -= "를 쓰다. }
        아니면 (연산 == 종류_곱하기대입)이면  { " *= "를 쓰다. }
        아니면 (연산 == 종류_나누기대입)이면  { " /= "를 쓰다. }
        아니면 (연산 == 종류_나머지대입)이면  { " %%= "를 쓰다. }
        아니면 { " = "를 쓰다. }
        노드오른쪽풀[노드]를 표현식코드생성다.
        반환.
    }

    (종류 == 노드_멤버접근)이면 {
        노드왼쪽풀[노드]를 표현식코드생성다.
        노드플래그풀[노드] == 1이면 {
            "->%s"를 노드이름풀[노드]를 쓰다.
        }
        아니면 {
            ".%s"를 노드이름풀[노드]를 쓰다.
        }
        반환.
    }

    (종류 == 노드_배열접근)이면 {
        노드왼쪽풀[노드]를 표현식코드생성다.
        "["를 쓰다.
        노드오른쪽풀[노드]를 표현식코드생성다.
        "]"를 쓰다.
        반환.
    }

    (종류 == 노드_형변환)이면 {
        "("를 쓰다.
        노드오른쪽풀[노드]를 타입코드생성다.
        ")("를 쓰다.
        노드왼쪽풀[노드]를 표현식코드생성다.
        ")"를 쓰다.
        반환.
    }

    (종류 == 노드_주소참조)이면 {
        "(&"를 쓰다.
        노드왼쪽풀[노드]를 표현식코드생성다.
        ")"를 쓰다.
        반환.
    }

    (종류 == 노드_역참조)이면 {
        "(*"를 쓰다.
        노드왼쪽풀[노드]를 표현식코드생성다.
        ")"를 쓰다.
        반환.
    }

    (종류 == 노드_크기)이면 {
        "sizeof("를 쓰다.
        정수 대상 = 노드왼쪽풀[노드].
        (* 타입 노드이면 타입코드생성, 아니면 표현식코드생성 *)
        대상 >= 0이면 {
            정수 대상종류 = 노드종류풀[대상].
            (대상종류 == 노드_기본타입) + (대상종류 == 노드_참조타입) + (대상종류 == 노드_배열타입) + (대상종류 == 노드_묶음타입명) > 0이면 {
                대상을 타입코드생성다.
            }
            아니면 {
                대상을 표현식코드생성다.
            }
        }
        ")"를 쓰다.
        반환.
    }

    (종류 == 노드_증감)이면 {
        정수 플래그 = 노드플래그풀[노드].
        (* 비트0: 증가(1)/감소(0), 비트1: 전위(1)/후위(0) *)
        문자열 연산 = "--".
        (플래그 & 1)이면 { 연산 = "++". }
        (플래그 & 2)이면 {
            "%s"를 연산을 쓰다.
            노드왼쪽풀[노드]를 표현식코드생성다.
        }
        아니면 {
            노드왼쪽풀[노드]를 표현식코드생성다.
            "%s"를 연산을 쓰다.
        }
        반환.
    }

    (종류 == 노드_삼항)이면 {
        "("를 쓰다.
        노드왼쪽풀[노드]를 표현식코드생성다.
        " ? "를 쓰다.
        노드오른쪽풀[노드]를 표현식코드생성다.
        " : "를 쓰다.
        노드추가풀[노드]를 표현식코드생성다.
        ")"를 쓰다.
        반환.
    }

    (종류 == 노드_배열리터럴)이면 {
        "{ "를 쓰다.
        정수 시작 = 노드목록시작풀[노드].
        정수 수 = 노드목록수풀[노드].
        정수 번호 = 0.
        (번호 < 수)동안 {
            번호 > 0이면 { ", "를 쓰다. }
            목록항목풀[시작 + 번호]를 표현식코드생성다.
            번호를 증가하다.
        }
        " }"를 쓰다.
        반환.
    }

    (종류 == 노드_묶음리터럴)이면 {
        "{ "를 쓰다.
        정수 시작 = 노드목록시작풀[노드].
        정수 수 = 노드목록수풀[노드].
        정수 번호 = 0.
        (번호 < 수)동안 {
            번호 > 0이면 { ", "를 쓰다. }
            목록항목풀[시작 + 번호]를 표현식코드생성다.
            번호를 증가하다.
        }
        " }"를 쓰다.
        반환.
    }

    (종류 == 노드_없음리터럴)이면 {
        "NULL"을 쓰다.
        반환.
    }

    (종류 == 노드_참거짓리터럴)이면 {
        "%lld"를 노드정수풀[노드]를 쓰다.
        반환.
    }

    (* 미지원 표현식 *)
    "/* 표현식? */"를 쓰다.
}

(* ===== 블록 코드 생성 ===== *)

[정수 노드를 블록코드생성]은 {
    노드 < 0이면 {
        "{ }\n"을 쓰다.
        반환.
    }
    (노드종류풀[노드] != 노드_블록)이면 {
        "{ }\n"을 쓰다.
        반환.
    }

    "{\n"을 쓰다.
    들여쓰기깊이를 증가하다.

    정수 시작 = 노드목록시작풀[노드].
    정수 수 = 노드목록수풀[노드].
    정수 번호 = 0.
    (번호 < 수)동안 {
        목록항목풀[시작 + 번호]를 문장코드생성다.
        번호를 증가하다.
    }

    들여쓰기깊이를 감소하다.
    들여쓰기출력_C().
    "}"를 쓰다.
}

(* ===== 문장 코드 생성 ===== *)

[정수 노드를 문장코드생성]은 {
    노드 < 0이면 { 반환. }

    정수 종류 = 노드종류풀[노드].

    (* 변수 선언 *)
    (종류 == 노드_변수선언)이면 {
        들여쓰기출력_C().
        (* 외부 플래그 *)
        (노드플래그풀[노드] & 1)이면 {
            "extern "을 쓰다.
        }
        (* 정적 플래그 *)
        (노드플래그풀[노드] & 2)이면 {
            "static "을 쓰다.
        }
        (* 상수 플래그 *)
        (노드플래그풀[노드] & 4)이면 {
            "const "을 쓰다.
        }
        노드왼쪽풀[노드]를 타입코드생성다.
        " %s"를 노드이름풀[노드]를 쓰다.
        노드왼쪽풀[노드]를 배열접미사생성다.
        노드오른쪽풀[노드] >= 0이면 {
            " = "를 쓰다.
            노드오른쪽풀[노드]를 표현식코드생성다.
        }
        ";\n"을 쓰다.
        반환.
    }

    (* 반환문 *)
    (종류 == 노드_반환문)이면 {
        들여쓰기출력_C().
        노드왼쪽풀[노드] >= 0이면 {
            "return "을 쓰다.
            노드왼쪽풀[노드]를 표현식코드생성다.
            ";\n"을 쓰다.
        }
        아니면 {
            "return;\n"을 쓰다.
        }
        반환.
    }

    (* 조건문 — else if 체이닝 지원 *)
    (종류 == 노드_조건문)이면 {
        들여쓰기출력_C().
        "if ("를 쓰다.
        노드왼쪽풀[노드]를 표현식코드생성다.
        ") "를 쓰다.
        노드오른쪽풀[노드]를 블록코드생성다.
        노드추가풀[노드] >= 0이면 {
            정수 거짓분기 = 노드추가풀[노드].
            (노드종류풀[거짓분기] == 노드_조건문)이면 {
                " else "를 쓰다.
                "\n"을 쓰다.
                거짓분기를 문장코드생성다.
                반환.
            }
            아니면 {
                " else "를 쓰다.
                거짓분기를 블록코드생성다.
            }
        }
        "\n"을 쓰다.
        반환.
    }

    (* 동안반복 *)
    (종류 == 노드_동안반복)이면 {
        들여쓰기출력_C().
        "while ("를 쓰다.
        노드왼쪽풀[노드]를 표현식코드생성다.
        ") "를 쓰다.
        노드오른쪽풀[노드]를 블록코드생성다.
        "\n"을 쓰다.
        반환.
    }

    (* 반복하기 (do-while) *)
    (종류 == 노드_반복하기)이면 {
        들여쓰기출력_C().
        "do "를 쓰다.
        노드오른쪽풀[노드]를 블록코드생성다.
        " while ("를 쓰다.
        노드왼쪽풀[노드]를 표현식코드생성다.
        ");\n"을 쓰다.
        반환.
    }

    (* 반복문 (C-style for) — 올바른 for(init;cond;incr) 생성 *)
    (종류 == 노드_반복문)이면 {
        들여쓰기출력_C().
        "for ("를 쓰다.
        (* 초기화 *)
        노드왼쪽풀[노드] >= 0이면 {
            정수 초기노드 = 노드왼쪽풀[노드].
            (노드종류풀[초기노드] == 노드_변수선언)이면 {
                노드왼쪽풀[초기노드]를 타입코드생성다.
                " %s"를 노드이름풀[초기노드]를 쓰다.
                노드왼쪽풀[초기노드]를 배열접미사생성다.
                노드오른쪽풀[초기노드] >= 0이면 {
                    " = "를 쓰다.
                    노드오른쪽풀[초기노드]를 표현식코드생성다.
                }
            }
            아니면 {
                초기노드를 표현식코드생성다.
            }
        }
        "; "를 쓰다.
        (* 조건 *)
        노드추가풀[노드] >= 0이면 {
            노드추가풀[노드]를 표현식코드생성다.
        }
        "; "를 쓰다.
        (* 증감 — 노드정수풀에 저장됨 *)
        정수 증감노드 = 노드정수풀[노드].
        증감노드 >= 0이면 {
            증감노드를 표현식코드생성다.
        }
        ") "를 쓰다.
        노드오른쪽풀[노드]를 블록코드생성다.
        "\n"을 쓰다.
        반환.
    }

    (* 갈래문 (switch) *)
    (종류 == 노드_갈래문)이면 {
        들여쓰기출력_C().
        "switch ("를 쓰다.
        노드왼쪽풀[노드]를 표현식코드생성다.
        ") {\n"을 쓰다.

        정수 경우시작 = 노드목록시작풀[노드].
        정수 경우수 = 노드목록수풀[노드].
        정수 경우번호 = 0.
        (경우번호 < 경우수)동안 {
            정수 경우값 = 목록항목풀[경우시작 + 경우번호 * 2].
            정수 경우본문 = 목록항목풀[경우시작 + 경우번호 * 2 + 1].

            경우값 >= 0이면 {
                들여쓰기출력_C().
                "case "를 쓰다.
                경우값을 표현식코드생성다.
                ": "를 쓰다.
            }
            아니면 {
                들여쓰기출력_C().
                "default: "를 쓰다.
            }

            경우본문를 블록코드생성다.
            "\n"을 쓰다.

            (* 자동 break 삽입 *)
            들여쓰기깊이를 증가하다.
            들여쓰기출력_C().
            "break;\n"을 쓰다.
            들여쓰기깊이를 감소하다.

            경우번호를 증가하다.
        }

        들여쓰기출력_C().
        "}\n"을 쓰다.
        반환.
    }

    (* 탈출문 *)
    (종류 == 노드_탈출문)이면 {
        들여쓰기출력_C().
        "break;\n"을 쓰다.
        반환.
    }

    (* 계속문 *)
    (종류 == 노드_계속문)이면 {
        들여쓰기출력_C().
        "continue;\n"을 쓰다.
        반환.
    }

    (* 표현식문 *)
    (종류 == 노드_표현식문)이면 {
        들여쓰기출력_C().
        노드왼쪽풀[노드]를 표현식코드생성다.
        ";\n"을 쓰다.
        반환.
    }

    (* 대입문 (문장 위치) *)
    (종류 == 노드_대입)이면 {
        들여쓰기출력_C().
        노드를 표현식코드생성다.
        ";\n"을 쓰다.
        반환.
    }

    (* 호출문 (문장 위치) *)
    (종류 == 노드_호출)이면 {
        들여쓰기출력_C().
        노드를 표현식코드생성다.
        ";\n"을 쓰다.
        반환.
    }

    (* 블록 *)
    (종류 == 노드_블록)이면 {
        들여쓰기출력_C().
        노드를 블록코드생성다.
        "\n"을 쓰다.
        반환.
    }

    (* 증감문 (문장 위치) *)
    (종류 == 노드_증감)이면 {
        들여쓰기출력_C().
        노드를 표현식코드생성다.
        ";\n"을 쓰다.
        반환.
    }

    (* 기본: 표현식으로 처리 *)
    들여쓰기출력_C().
    노드를 표현식코드생성다.
    ";\n"을 쓰다.
}

(* ===== 매개변수 목록 출력 (공통) ===== *)

[정수 노드를 매개변수목록출력]은 {
    정수 매개 = 노드왼쪽풀[노드].
    정수 가변 = 노드플래그풀[노드] & 4.

    매개 < 0이면 {
        가변이면 { "..."를 쓰다. }
        아니면 { "void"를 쓰다. }
        반환.
    }

    정수 첫번째 = 1.
    (매개 >= 0)동안 {
        첫번째 == 0이면 { ", "를 쓰다. }
        매개타입풀[매개]를 타입코드생성다.
        " %s"를 매개이름풀[매개]를 쓰다.
        매개타입풀[매개]를 배열접미사생성다.
        첫번째 = 0.
        매개 = 매개다음풀[매개].
    }

    가변이면 { ", ..."를 쓰다. }
}

(* ===== 함수 전방선언 생성 ===== *)

[정수 노드를 전방선언코드생성]은 {
    (노드종류풀[노드] != 노드_함수정의)이면 { 반환. }

    문자열 이름 = 노드이름풀[노드]를 함수이름변환다.

    (* C 표준 함수는 스킵 *)
    씨표준함수인가(이름) 이면 { 반환. }

    (* 외부 선언 *)
    (노드플래그풀[노드] & 1)이면 {
        "extern "을 쓰다.
    }

    (* 반환 타입 *)
    문자열_비교(이름, "main") == 0이면 {
        "int"을 쓰다.
    }
    아니면 {
        노드추가풀[노드]를 타입코드생성다.
    }

    " %s("를 이름을 쓰다.
    노드를 매개변수목록출력다.
    ");\n"을 쓰다.
}

(* ===== 함수 정의 생성 ===== *)

[정수 노드를 함수정의코드생성]은 {
    (* 외부 선언은 본문 없음 *)
    (노드플래그풀[노드] & 1)이면 { 반환. }

    문자열 이름 = 노드이름풀[노드]를 함수이름변환다.
    정수 메인함수 = 문자열_비교(이름, "main") == 0.

    (* 반환 타입 *)
    메인함수이면 {
        "int"을 쓰다.
    }
    아니면 {
        노드추가풀[노드]를 타입코드생성다.
    }

    " %s("를 이름을 쓰다.
    노드를 매개변수목록출력다.
    ") "를 쓰다.

    (* 본문 *)
    메인함수이면 {
        정수 본문 = 노드오른쪽풀[노드].
        정수 매개있음 = 노드왼쪽풀[노드] >= 0.
        "{\n"을 쓰다.
        들여쓰기깊이를 증가하다.
        들여쓰기출력_C().
        "setlocale(LC_ALL, \".UTF-8\");\n"을 쓰다.
        매개있음이면 {
            들여쓰기출력_C().
            "#ifdef _WIN32\n"을 쓰다.
            들여쓰기출력_C().
            "for(int _i=0;_i<argc;_i++){argv[_i]=_ansi_to_utf8(argv[_i]);}\n"을 쓰다.
            들여쓰기출력_C().
            "#endif\n"을 쓰다.
        }
        본문 >= 0이면 {
            정수 시작 = 노드목록시작풀[본문].
            정수 수 = 노드목록수풀[본문].
            정수 번호 = 0.
            (번호 < 수)동안 {
                목록항목풀[시작 + 번호]를 문장코드생성다.
                번호를 증가하다.
            }
        }
        들여쓰기출력_C().
        "return 0;\n"을 쓰다.
        들여쓰기깊이를 감소하다.
        "}"를 쓰다.
    }
    아니면 {
        노드오른쪽풀[노드]를 블록코드생성다.
    }
    "\n\n"을 쓰다.
}

(* ===== 나열 정의 코드 생성 ===== *)

[정수 노드를 나열정의코드생성]은 {
    문자열 이름 = 노드이름풀[노드].

    (* 나열 이름 등록 *)
    나열이름수 < 128이면 {
        나열이름목록[나열이름수] = 이름.
        나열이름수를 증가하다.
    }

    "enum %s {\n"을 이름을 쓰다.
    들여쓰기깊이를 증가하다.

    정수 값시작 = 노드목록시작풀[노드].
    정수 값수 = 노드목록수풀[노드].
    정수 번호 = 0.
    (번호 < 값수)동안 {
        들여쓰기출력_C().
        "%s = %d"를 나열값이름풀[값시작 + 번호]를 나열값정수풀[값시작 + 번호]를 쓰다.
        번호 < 값수 - 1이면 {
            ","를 쓰다.
        }
        "\n"을 쓰다.
        번호를 증가하다.
    }

    들여쓰기깊이를 감소하다.
    "};\n\n"을 쓰다.
}

(* ===== 묶음 정의 코드 생성 ===== *)

[정수 노드를 묶음정의코드생성]은 {
    문자열 이름 = 노드이름풀[노드].
    "struct %s {\n"을 이름을 쓰다.
    들여쓰기깊이를 증가하다.

    정수 필드 = 노드왼쪽풀[노드].
    (필드 >= 0)동안 {
        들여쓰기출력_C().
        필드타입풀[필드]를 타입코드생성다.
        " %s"를 필드이름풀[필드]를 쓰다.
        필드타입풀[필드]를 배열접미사생성다.
        ";\n"을 쓰다.
        필드 = 필드다음풀[필드].
    }

    들여쓰기깊이를 감소하다.
    "};\n\n"을 쓰다.
}

(* ===== 합침 정의 코드 생성 ===== *)

[정수 노드를 합침정의코드생성]은 {
    문자열 이름 = 노드이름풀[노드].

    합침이름수 < 128이면 {
        합침이름목록[합침이름수] = 이름.
        합침이름수를 증가하다.
    }

    "union %s {\n"을 이름을 쓰다.
    들여쓰기깊이를 증가하다.

    정수 필드 = 노드왼쪽풀[노드].
    (필드 >= 0)동안 {
        들여쓰기출력_C().
        필드타입풀[필드]를 타입코드생성다.
        " %s"를 필드이름풀[필드]를 쓰다.
        필드타입풀[필드]를 배열접미사생성다.
        ";\n"을 쓰다.
        필드 = 필드다음풀[필드].
    }

    들여쓰기깊이를 감소하다.
    "};\n\n"을 쓰다.
}

(* ===== 별칭 정의 코드 생성 ===== *)

[정수 노드를 별칭정의코드생성]은 {
    문자열 이름 = 노드이름풀[노드].

    별칭이름수 < 128이면 {
        별칭이름목록[별칭이름수] = 이름.
        별칭이름수를 증가하다.
    }

    "typedef "를 쓰다.
    노드왼쪽풀[노드]를 타입코드생성다.
    " %s;\n\n"을 이름을 쓰다.
}

(* ===== 메인: 프로그램 코드 생성 ===== *)

[정수 프로그램을 프로그램코드생성]은 {
    씨표준함수등록초기화().

    (* 1. 헤더 *)
    헤더출력().

    (* 2. 런타임 *)
    런타임출력().

    정수 시작 = 노드목록시작풀[프로그램].
    정수 수 = 노드목록수풀[프로그램].
    정수 번호 = 0.

    (* 3. 묶음/나열/합침/별칭 정의 먼저 *)
    번호 = 0.
    (번호 < 수)동안 {
        정수 선언 = 목록항목풀[시작 + 번호].
        정수 선언종류 = 노드종류풀[선언].
        (선언종류 == 노드_나열정의)이면 {
            선언을 나열정의코드생성다.
        }
        아니면 (선언종류 == 노드_묶음정의)이면 {
            선언을 묶음정의코드생성다.
        }
        아니면 (선언종류 == 노드_합침정의)이면 {
            선언을 합침정의코드생성다.
        }
        아니면 (선언종류 == 노드_별칭정의)이면 {
            선언을 별칭정의코드생성다.
        }
        아니면 (선언종류 == 노드_매크로정의)이면 {
            문자열 매이름은 노드이름풀[선언].
            문자열 매값은 노드문자열풀[선언].
            매값 != 0이면 {
                "#define %s %s\n"을 매이름을 매값을 쓰다.
            } 아니면 {
                "#define %s\n"을 매이름을 쓰다.
            }
        }
        번호를 증가하다.
    }

    (* 4. 전역 변수 선언 *)
    번호 = 0.
    (번호 < 수)동안 {
        정수 선언 = 목록항목풀[시작 + 번호].
        (노드종류풀[선언] == 노드_변수선언)이면 {
            선언을 문장코드생성다.
        }
        번호를 증가하다.
    }

    (* 5. 함수 전방 선언 *)
    "/* 함수 전방 선언 */\n"을 쓰다.
    번호 = 0.
    (번호 < 수)동안 {
        정수 선언 = 목록항목풀[시작 + 번호].
        (노드종류풀[선언] == 노드_함수정의)이면 {
            선언을 전방선언코드생성다.
        }
        번호를 증가하다.
    }
    "\n"을 쓰다.

    (* 6. 함수 정의 *)
    번호 = 0.
    (번호 < 수)동안 {
        정수 선언 = 목록항목풀[시작 + 번호].
        (노드종류풀[선언] == 노드_함수정의)이면 {
            선언을 함수정의코드생성다.
        }
        번호를 증가하다.
    }
}
