(*
 * 구문분석기.글 - 글 컴파일러 파서
 * 부트스트랩/src/구문분석기.c 의 글 포팅
 *
 * 재귀 하향 파서 + Pratt 파싱 (우선순위 오름)
 * SOV(주어-목적어-동사) 어순에 기반한 함수 호출
 *)

포함 "구문트리.글"
포함 "형태소분석기.글"

(* ===== 파서 상태 (SoA) ===== *)

(* 현재 토큰 *)
정수 현재종류.
문자열 현재텍스트.
정수 현재줄.
정수 현재열.
정수 현재역할.
정수 현재기능.

(* 이전 토큰 *)
정수 이전종류.
문자열 이전텍스트.
정수 이전줄.
정수 이전열.

(* 오류 *)
정수 최대오류수 = 64.
정수 오류수 = 0.
참거짓 패닉모드 = 0.

(* 타입 이름 등록 *)
정수 최대타입이름수 = 128.
문자열[128] 타입이름목록.
정수 타입이름수 = 0.

(* 함수 이름 등록 — 동사어근→명사형 폴백용 *)
문자열[256] 함수이름목록.
정수 함수이름수 = 0.

[문자열 이름을 함수이름등록]은 {
    (함수이름수 < 256)이면 {
        함수이름목록[함수이름수] = 이름.
        함수이름수를 증가하다.
    }
}

(* 동사어근→함수이름 폴백: "쓰"→"쓰기", "더"→"더하기" *)
문자[256] 동사폴백버퍼.

[문자열 동사이름을 동사폴백]은 → 문자열 {
    정수 검색번호 = 0.
    (* 원본 이름이 등록되어 있으면 그대로 *)
    (검색번호 < 함수이름수)동안 {
        (문자열_비교(함수이름목록[검색번호], 동사이름) == 0)이면 { 반환 동사이름. }
        검색번호를 증가하다.
    }
    (* "어근" + "기" 시도 *)
    버퍼에_쓰기(동사폴백버퍼, 256, "%s기", 동사이름).
    검색번호 = 0.
    (검색번호 < 함수이름수)동안 {
        (문자열_비교(함수이름목록[검색번호], 동사폴백버퍼) == 0)이면 { 반환 문자열_복제(동사폴백버퍼). }
        검색번호를 증가하다.
    }
    (* "어근" + "하기" 시도 *)
    버퍼에_쓰기(동사폴백버퍼, 256, "%s하기", 동사이름).
    검색번호 = 0.
    (검색번호 < 함수이름수)동안 {
        (문자열_비교(함수이름목록[검색번호], 동사폴백버퍼) == 0)이면 { 반환 문자열_복제(동사폴백버퍼). }
        검색번호를 증가하다.
    }
    반환 동사이름.
}

(* ===== 유틸리티 ===== *)

외부 [문자열 형식을 정수 값을 정수 값2를 문자열 메시지를 fprintf_stderr]는 → 정수.

[문자열 메시지를 파서오류]는 {
    오류수 < 최대오류수이면 {
        fprintf_stderr("%d:%d: 오류: %s\n", 현재줄, 현재열, 메시지).
    }
    오류수를 증가하다.
    패닉모드 = 1.
}

(* 다음 토큰으로 전진 (줄바꿈 건너뜀) *)
[전진]은 {
    이전종류 = 현재종류.
    이전텍스트 = 현재텍스트.
    이전줄 = 현재줄.
    이전열 = 현재열.

    정수 종류 = 다음토큰읽기().
    (종류 == 종류_줄바꿈)동안 {
        종류 = 다음토큰읽기().
    }
    현재종류 = 종류.
    현재텍스트 = 현재토큰텍스트().
    현재줄 = 현재토큰줄().
    현재열 = 현재토큰열().
    현재역할 = 현재토큰역할().
    현재기능 = 현재토큰기능().
}

(* 현재 토큰이 특정 종류인지 확인 *)
[정수 종류를 확인]은 → 참거짓 {
    반환 (현재종류 == 종류).
}

(* 현재 토큰이 종류와 일치하면 소비하고 1 반환 *)
[정수 종류를 일치]는 → 참거짓 {
    (현재종류 == 종류)이면 {
        전진().
        반환 1.
    }
    반환 0.
}

(* 오류 메시지 버퍼 *)
문자[256] 기대오류버퍼.

(* 특정 토큰을 기대 — 없으면 오류 *)
[정수 종류를 문자열 메시지로 기대]는 {
    (현재종류 == 종류)이면 {
        전진().
        반환.
    }
    (현재종류 == 종류_파일끝)이면 {
        버퍼에_쓰기(기대오류버퍼, 256, "%s — 파일이 예상보다 일찍 끝났습니다", 메시지).
    }
    아니면 (현재종류 == 종류_식별자)이면 {
        버퍼에_쓰기(기대오류버퍼, 256, "%s — '%s'이(가) 있습니다", 메시지, 현재텍스트).
    }
    아니면 {
        문자열 종류텍스트 = 현재종류를 토큰종류이름다.
        버퍼에_쓰기(기대오류버퍼, 256, "%s — '%s'이(가) 있습니다", 메시지, 종류텍스트).
    }
    기대오류버퍼를 파서오류다.
}

(* 조사를 소비하고 역할 반환 *)
[조사소비]는 → 정수 {
    정수 종류 = 현재종류.

    ((종류 == 종류_을))이면 { 전진(). 반환 역할_목적어. }
    ((종류 == 종류_를))이면 { 전진(). 반환 역할_목적어. }
    (* "이"/"가" 뒤에 어미가 오면 서술격 패턴이므로 조사로 소비 안 함 *)
    ((종류 == 종류_이))이면 {
        전진().
        어미인가(현재종류) 이면 { 반환 역할_없음. }
        반환 역할_주어.
    }
    ((종류 == 종류_가))이면 { 전진(). 반환 역할_주어. }
    ((종류 == 종류_은))이면 { 전진(). 반환 역할_주제. }
    ((종류 == 종류_는))이면 { 전진(). 반환 역할_주제. }
    ((종류 == 종류_에))이면 { 전진(). 반환 역할_목적지. }
    ((종류 == 종류_로))이면 { 전진(). 반환 역할_수단. }
    ((종류 == 종류_으로))이면 { 전진(). 반환 역할_수단. }
    ((종류 == 종류_에서))이면 { 전진(). 반환 역할_출처. }
    ((종류 == 종류_부터))이면 { 전진(). 반환 역할_시작. }
    ((종류 == 종류_까지))이면 { 전진(). 반환 역할_종점. }
    ((종류 == 종류_와))이면 { 전진(). 반환 역할_공동. }
    ((종류 == 종류_과))이면 { 전진(). 반환 역할_공동. }
    ((종류 == 종류_의))이면 { 전진(). 반환 역할_소유. }
    ((종류 == 종류_보다))이면 { 전진(). 반환 역할_비교. }

    반환 역할_없음.
}

(* 어미를 소비하고 기능 반환 *)
[어미소비]는 → 정수 {
    정수 종류 = 현재종류.

    ((종류 == 종류_면))이면 { 전진(). 반환 어미_면. }
    ((종류 == 종류_다))이면 { 전진(). 반환 어미_다. }
    ((종류 == 종류_동안))이면 { 전진(). 반환 어미_동안. }
    ((종류 == 종류_고))이면 { 전진(). 반환 어미_고. }
    ((종류 == 종류_서))이면 { 전진(). 반환 어미_서. }

    (* "이면" 패턴: 서술격 조사 "이" + 어미 "면"/"다" → 어미로 처리 *)
    ((종류 == 종류_이))이면 {
        전진().
        ((현재종류 == 종류_면))이면 { 전진(). 반환 어미_면. }
        ((현재종류 == 종류_다))이면 { 전진(). 반환 어미_다. }
    }

    반환 어미_없음.
}

(* 오류 복구: 문장 경계까지 건너뜀 *)
[동기화]는 {
    패닉모드 = 0.
    (현재종류 != 종류_파일끝)동안 {
        (* 마침표 뒤면 다음 문장 *)
        ((이전종류 == 종류_마침표))이면 { 반환. }

        (* 새 문장/선언 시작점 *)
        ((현재종류 == 종류_정수))이면 { 반환. }
        ((현재종류 == 종류_실수))이면 { 반환. }
        ((현재종류 == 종류_문자열))이면 { 반환. }
        ((현재종류 == 종류_문자))이면 { 반환. }
        ((현재종류 == 종류_참거짓))이면 { 반환. }
        ((현재종류 == 종류_공허))이면 { 반환. }
        ((현재종류 == 종류_반환))이면 { 반환. }
        ((현재종류 == 종류_반복))이면 { 반환. }
        ((현재종류 == 종류_반복하기))이면 { 반환. }
        ((현재종류 == 종류_묶음))이면 { 반환. }
        ((현재종류 == 종류_나열))이면 { 반환. }
        ((현재종류 == 종류_외부))이면 { 반환. }
        ((현재종류 == 종류_여는대괄호))이면 { 반환. }
        ((현재종류 == 종류_닫는중괄호))이면 { 반환. }
        ((현재종류 == 종류_갈래))이면 { 반환. }
        ((현재종류 == 종류_상수))이면 { 반환. }
        ((현재종류 == 종류_정적))이면 { 반환. }

        전진().
    }
}

(* 타입 이름 등록 *)
[문자열 이름을 타입이름등록]은 {
    타입이름수 < 최대타입이름수이면 {
        타입이름목록[타입이름수] = 이름.
        타입이름수를 증가하다.
    }
}


(* 타입 이름인지 확인 *)
[문자열 이름을 타입이름인가]는 → 참거짓 {
    정수 번호 = 0.
    (번호 < 타입이름수)동안 {
        문자열_비교(이름, 타입이름목록[번호]) == 0이면 {
            반환 1.
        }
        번호를 증가하다.
    }
    반환 0.
}

(* 현재 토큰이 타입 시작인지 확인 *)
[타입시작인가]는 → 참거짓 {
    타입키워드인가(현재종류) 이면 { 반환 1. }
    ((현재종류 == 종류_묶음))이면 { 반환 1. }
    ((현재종류 == 종류_합침))이면 { 반환 1. }
    ((현재종류 == 종류_나열))이면 { 반환 1. }
    ((현재종류 == 종류_상수))이면 { 반환 1. }
    ((현재종류 == 종류_정적))이면 { 반환 1. }
    ((현재종류 == 종류_가변목록))이면 { 반환 1. }
    (* 등록된 타입 이름 확인 *)
    ((현재종류 == 종류_식별자))이면 {
        타입이름인가(현재텍스트) 이면 { 반환 1. }
    }
    반환 0.
}

(* 조사가 SOV 패턴인지 *)
[정수 종류를 SOV_조사인가]는 → 참거짓 {
    ((종류 == 종류_을))이면 { 반환 1. }
    ((종류 == 종류_를))이면 { 반환 1. }
    ((종류 == 종류_에))이면 { 반환 1. }
    ((종류 == 종류_로))이면 { 반환 1. }
    ((종류 == 종류_으로))이면 { 반환 1. }
    ((종류 == 종류_에서))이면 { 반환 1. }
    ((종류 == 종류_부터))이면 { 반환 1. }
    ((종류 == 종류_까지))이면 { 반환 1. }
    ((종류 == 종류_와))이면 { 반환 1. }
    ((종류 == 종류_과))이면 { 반환 1. }
    ((종류 == 종류_보다))이면 { 반환 1. }
    반환 0.
}

(* ===== 타입 파싱 ===== *)

[타입파싱]은 → 정수 {
    정수 줄 = 현재줄.
    정수 열 = 현재열.

    (* 참조 (포인터) *)
    ((현재종류 == 종류_참조))이면 {
        전진().
        정수 대상 = 타입파싱().
        반환 대상을 줄을 열로 참조타입생성다.
    }

    (* 기본 타입 키워드 *)
    타입키워드인가(현재종류) 이면 {
        정수 타입종류 = 현재종류.
        전진().
        (* 참조(포인터): 타입 뒤에 "참조" (다중 가능) *)
        정수 결과 = 타입종류를 줄을 열로 기본타입생성다.
        ((현재종류 == 종류_참조))동안 {
            전진().
            결과 = 결과를 줄을 열로 참조타입생성다.
        }
        (* 배열 타입: 타입[크기] *)
        ((현재종류 == 종류_여는대괄호))이면 {
            전진().
            정수 배열크기 = 0.
            ((현재종류 == 종류_정수리터럴))이면 {
                배열크기 = 현재토큰정수().
                전진().
            }
            기대(종류_닫는대괄호, "\"]\" 필요").
            반환 결과를 배열크기를 줄을 열로 배열타입생성다.
        }
        반환 결과.
    }

    (* 등록된 타입 이름 *)
    ((현재종류 == 종류_식별자))이면 {
        타입이름인가(현재텍스트) 이면 {
            문자열 이름 = 현재텍스트.
            전진().
            정수 노드 = 노드생성(노드_묶음타입명, 줄, 열).
            노드이름풀[노드] = 이름.
            (* 참조(포인터): 타입이름 뒤에 "참조" *)
            ((현재종류 == 종류_참조))동안 {
                전진().
                노드 = 노드를 줄을 열로 참조타입생성다.
            }
            (* 배열 타입: 이름[크기] *)
            ((현재종류 == 종류_여는대괄호))이면 {
                전진().
                정수 배열크기 = 0.
                ((현재종류 == 종류_정수리터럴))이면 {
                    배열크기 = 현재토큰정수().
                    전진().
                }
                기대(종류_닫는대괄호, "\"]\" 필요").
                반환 노드를 배열크기를 줄을 열로 배열타입생성다.
            }
            반환 노드.
        }
    }

    문자열 타입오류텍스트 = 현재종류를 토큰종류이름다.
    버퍼에_쓰기(기대오류버퍼, 256, "타입이 필요합니다 (현재: %s)", 타입오류텍스트).
    기대오류버퍼를 파서오류다.
    반환 -1.
}

(* ===== 우선순위 ===== *)

[정수 종류를 이항우선순위]는 → 정수 {
    ((종류 == 종류_또는))이면      { 반환 1. }
    ((종류 == 종류_그리고))이면    { 반환 2. }
    ((종류 == 종류_비트또는))이면  { 반환 3. }
    ((종류 == 종류_비트배타))이면  { 반환 4. }
    ((종류 == 종류_비트와))이면    { 반환 5. }
    ((종류 == 종류_같다))이면      { 반환 6. }
    ((종류 == 종류_다르다))이면    { 반환 6. }
    ((종류 == 종류_크다))이면      { 반환 7. }
    ((종류 == 종류_작다))이면      { 반환 7. }
    ((종류 == 종류_크거나같다))이면 { 반환 7. }
    ((종류 == 종류_작거나같다))이면 { 반환 7. }
    ((종류 == 종류_왼쪽이동))이면  { 반환 8. }
    ((종류 == 종류_오른쪽이동))이면 { 반환 8. }
    ((종류 == 종류_더하기))이면    { 반환 9. }
    ((종류 == 종류_빼기))이면      { 반환 9. }
    ((종류 == 종류_곱하기))이면    { 반환 10. }
    ((종류 == 종류_나누기))이면    { 반환 10. }
    ((종류 == 종류_나머지))이면    { 반환 10. }
    반환 0.
}

(* ===== 표현식 파싱 ===== *)

(* 전방선언: 표현식파싱, 블록파싱 *)
외부 [표현식파싱]은 → 정수.
외부 [블록파싱]은 → 정수.

(* 기본 표현식 (원자) *)
[기본표현식]은 → 정수 {
    정수 줄 = 현재줄.
    정수 열 = 현재열.

    (* 정수 리터럴 *)
    ((현재종류 == 종류_정수리터럴))이면 {
        긴정수 값 = 현재토큰정수().
        전진().
        반환 값을 줄을 열로 정수리터럴생성다.
    }

    (* 실수 리터럴 *)
    ((현재종류 == 종류_실수리터럴))이면 {
        문자열 값텍스트 = 현재텍스트.
        전진().
        정수 노드 = 노드생성(노드_실수리터럴, 줄, 열).
        노드문자열풀[노드] = 값텍스트.
        반환 노드.
    }

    (* 문자열 리터럴 *)
    ((현재종류 == 종류_문자열리터럴))이면 {
        문자열 값 = 현재텍스트.
        전진().
        반환 값을 줄을 열로 문자열리터럴생성다.
    }

    (* 문자 리터럴 *)
    ((현재종류 == 종류_문자리터럴))이면 {
        문자열 값 = 현재텍스트.
        전진().
        정수 노드 = 노드생성(노드_문자리터럴, 줄, 열).
        노드문자열풀[노드] = 값.
        반환 노드.
    }

    (* 참/거짓 *)
    ((현재종류 == 종류_참))이면 {
        전진().
        정수 노드 = 노드생성(노드_참거짓리터럴, 줄, 열).
        노드정수풀[노드] = 1.
        반환 노드.
    }
    ((현재종류 == 종류_거짓))이면 {
        전진().
        정수 노드 = 노드생성(노드_참거짓리터럴, 줄, 열).
        노드정수풀[노드] = 0.
        반환 노드.
    }

    (* 없음 (NULL) *)
    ((현재종류 == 종류_없음))이면 {
        전진().
        반환 노드생성(노드_없음리터럴, 줄, 열).
    }

    (* 크기 (sizeof) *)
    ((현재종류 == 종류_크기))이면 {
        전진().
        기대(종류_여는괄호, "\"(\" 필요").
        정수 대상 = -1.
        (* 타입 키워드이면 타입으로 파싱 *)
        타입키워드인가(현재종류) 이면 {
            대상 = 타입파싱().
        }
        아니면 (현재종류 == 종류_식별자) * (타입이름인가(현재텍스트))이면 {
            대상 = 타입파싱().
        }
        아니면 (현재종류 == 종류_묶음)이면 {
            대상 = 타입파싱().
        }
        아니면 {
            대상 = 표현식파싱().
        }
        기대(종류_닫는괄호, "\")\" 필요").
        정수 노드 = 노드생성(노드_크기, 줄, 열).
        노드왼쪽풀[노드] = 대상.
        반환 노드.
    }

    (* 식별자 *)
    ((현재종류 == 종류_식별자))이면 {
        문자열 이름 = 현재텍스트.
        전진().

        (* 직접호출: 식별자(...) *)
        ((현재종류 == 종류_여는괄호))이면 {
            전진().
            정수 첫인자 = -1.
            정수 마지막인자 = -1.

            (현재종류 != 종류_닫는괄호)동안 {
                정수 인자값 = 표현식파싱().
                정수 새인자 = 인자생성(인자값, 역할_없음).
                첫인자 < 0이면 {
                    첫인자 = 새인자.
                }
                마지막인자 >= 0이면 {
                    인자다음풀[마지막인자] = 새인자.
                }
                마지막인자 = 새인자.

                정수 매치 = 일치(종류_쉼표).
                (매치 == 0)이면 { 탈출. }
            }
            기대(종류_닫는괄호, "\")\" 필요").
            반환 이름을 첫인자를 줄을 열로 호출생성다.
        }

        반환 이름을 줄을 열로 식별자생성다.
    }

    (* 괄호 표현식 *)
    ((현재종류 == 종류_여는괄호))이면 {
        전진().
        정수 표현 = 표현식파싱().
        기대(종류_닫는괄호, "\")\" 필요").
        반환 표현.
    }

    (* 단항 연산자: -, !, ~ *)
    ((현재종류 == 종류_빼기))이면 {
        전진().
        정수 피연산 = 기본표현식().
        반환 단항연산생성(종류_빼기, 피연산, 줄, 열).
    }
    ((현재종류 == 종류_아닌))이면 {
        전진().
        정수 피연산 = 기본표현식().
        반환 단항연산생성(종류_아닌, 피연산, 줄, 열).
    }

    (* 주소참조: &식별자 *)
    ((현재종류 == 종류_비트와))이면 {
        전진().
        정수 대상 = 기본표현식().
        정수 노드 = 노드생성(노드_주소참조, 줄, 열).
        노드왼쪽풀[노드] = 대상.
        반환 노드.
    }

    (* 역참조: *표현식 *)
    ((현재종류 == 종류_곱하기))이면 {
        전진().
        정수 대상 = 기본표현식().
        정수 노드 = 노드생성(노드_역참조, 줄, 열).
        노드왼쪽풀[노드] = 대상.
        반환 노드.
    }

    (* 비트NOT: ~표현식 *)
    ((현재종류 == 종류_비트아닌))이면 {
        전진().
        정수 피연산 = 기본표현식().
        반환 단항연산생성(종류_비트아닌, 피연산, 줄, 열).
    }

    (* 전위 증감 *)
    ((현재종류 == 종류_증가))이면 {
        전진().
        정수 대상 = 기본표현식().
        정수 노드 = 노드생성(노드_증감, 줄, 열).
        노드왼쪽풀[노드] = 대상.
        노드플래그풀[노드] = 3. (* 비트0=증가, 비트1=전위 *)
        반환 노드.
    }
    ((현재종류 == 종류_감소))이면 {
        전진().
        정수 대상 = 기본표현식().
        정수 노드 = 노드생성(노드_증감, 줄, 열).
        노드왼쪽풀[노드] = 대상.
        노드플래그풀[노드] = 2. (* 비트0=감소, 비트1=전위 *)
        반환 노드.
    }

    문자열 표현오류텍스트 = 현재종류를 토큰종류이름다.
    버퍼에_쓰기(기대오류버퍼, 256, "표현식이 필요합니다 (현재: %s)", 표현오류텍스트).
    기대오류버퍼를 파서오류다.
    반환 -1.
}

(* 접미 표현식: 배열접근, 멤버접근, 후위 증감 *)
[접미표현식]은 → 정수 {
    정수 왼쪽 = 기본표현식().

    정수 진행중 = 1.
    (진행중)동안 {
        정수 줄 = 현재줄.
        정수 열 = 현재열.

        (* 배열 접근: [인덱스] *)
        ((현재종류 == 종류_여는대괄호))이면 {
            전진().
            정수 인덱스 = 표현식파싱().
            기대(종류_닫는대괄호, "\"]\" 필요").
            정수 노드 = 노드생성(노드_배열접근, 줄, 열).
            노드왼쪽풀[노드] = 왼쪽.
            노드오른쪽풀[노드] = 인덱스.
            왼쪽 = 노드.
        }
        (* 멤버 접근: 의 *)
        아니면 ((현재종류 == 종류_의))이면 {
            전진().
            문자열 멤버 = 현재텍스트.
            전진().
            정수 노드 = 노드생성(노드_멤버접근, 줄, 열).
            노드왼쪽풀[노드] = 왼쪽.
            노드이름풀[노드] = 멤버.
            노드플래그풀[노드] = 0.
            왼쪽 = 노드.
        }
        (* 포인터 멤버: → *)
        아니면 ((현재종류 == 종류_화살표))이면 {
            전진().
            문자열 멤버 = 현재텍스트.
            전진().
            정수 노드 = 노드생성(노드_멤버접근, 줄, 열).
            노드왼쪽풀[노드] = 왼쪽.
            노드이름풀[노드] = 멤버.
            노드플래그풀[노드] = 1.
            왼쪽 = 노드.
        }
        (* 후위 증감 *)
        아니면 ((현재종류 == 종류_증가))이면 {
            전진().
            정수 노드 = 노드생성(노드_증감, 줄, 열).
            노드왼쪽풀[노드] = 왼쪽.
            노드플래그풀[노드] = 1. (* 비트0=증가, 비트1=후위 *)
            왼쪽 = 노드.
        }
        아니면 ((현재종류 == 종류_감소))이면 {
            전진().
            정수 노드 = 노드생성(노드_증감, 줄, 열).
            노드왼쪽풀[노드] = 왼쪽.
            노드플래그풀[노드] = 0. (* 감소, 후위 *)
            왼쪽 = 노드.
        }
        아니면 {
            진행중 = 0.
        }
    }
    반환 왼쪽.
}

(* 이항 표현식: Pratt 파싱 *)
[정수 최소우선을 이항표현식]은 → 정수 {
    정수 왼쪽 = 접미표현식().

    정수 진행중 = 1.
    (진행중)동안 {
        정수 우선 = 현재종류를 이항우선순위다.
        우선 <= 최소우선이면 { 진행중 = 0. }
        아니면 {
            정수 줄 = 현재줄.
            정수 열 = 현재열.
            정수 연산종류 = 현재종류.
            전진().
            정수 오른쪽 = 우선을 이항표현식다.
            왼쪽 = 연산종류를 왼쪽을 오른쪽을 줄을 열로 이항연산생성다.
        }
    }
    반환 왼쪽.
}

(* SOV 호출 파싱: 값(조사) ... 값(조사) 동사 *)
[정수 첫값을 정수 첫역할로 SOV_호출파싱]은 → 정수 {
    정수 줄 = 노드줄풀[첫값].
    정수 열 = 노드열풀[첫값].

    정수 첫인자 = 첫값을 첫역할로 인자생성다.
    정수 마지막인자 = 첫인자.

    (* 추가 인자 수집 *)
    정수 진행중 = 1.
    (진행중)동안 {
        (* 현재 토큰이 조사이면 SOV 계속 *)
        SOV_조사인가(현재종류) 이면 {
            진행중 = 0.
        }
        아니면 {
            (* SOV 동사 위치에 '반환' 키워드/식별자 → 반환문 생성 *)
            (* 예: 결과를 반환하다. → return 결과; *)
            (* 동사형 분리("반환하다" → "반환"+"다")에서 어근이 식별자로 나올 수 있음 *)
            ((현재종류 == 종류_반환) + ((현재종류 == 종류_식별자) * (문자열_비교(현재텍스트, "반환") == 0)) > 0)이면 {
                전진(). (* '반환' 소비 *)
                (* 첫 번째 인자의 값을 반환값으로 사용 *)
                정수 반환값 = 인자값풀[첫인자].
                반환 반환값을 줄을 열로 반환문생성다.
            }

            (* SOV 동사 위치에 '증가'/'감소' 식별자 → 증감문 생성 *)
            (* 예: 번호를 증가하다. → 번호++; *)
            ((현재종류 == 종류_식별자))이면 {
                (문자열_비교(현재텍스트, "증가") == 0)이면 {
                    전진(). (* '증가' 소비 *)
                    정수 대상 = 인자값풀[첫인자].
                    정수 노드 = 노드생성(노드_증감, 줄, 열).
                    노드왼쪽풀[노드] = 대상.
                    노드플래그풀[노드] = 1. (* 비트0=증가, 후위 *)
                    반환 노드.
                }
                (문자열_비교(현재텍스트, "감소") == 0)이면 {
                    전진(). (* '감소' 소비 *)
                    정수 대상 = 인자값풀[첫인자].
                    정수 노드 = 노드생성(노드_증감, 줄, 열).
                    노드왼쪽풀[노드] = 대상.
                    노드플래그풀[노드] = 0. (* 감소, 후위 *)
                    반환 노드.
                }
            }

            (* 값 파싱 *)
            정수 값 = 0을 이항표현식다.

            (* "이"/"가" 뒤에 어미_다나 마침표면 동사로 처리 *)
            ((현재종류 == 종류_이) + (현재종류 == 종류_가) > 0)이면 {
                정수 다음 = 0.
                버퍼위치 < 버퍼수이면 {
                    다음 = 버퍼종류배열[버퍼위치].
                }
                ((다음 == 종류_다) + (다음 == 종류_마침표) > 0)이면 {
                    전진().
                    문자열 함수이름 = 동사폴백(노드이름풀[값]).
                    반환 함수이름을 첫인자를 줄을 열로 호출생성다.
                }
            }

            정수 역할 = 조사소비().
            (역할 == 역할_없음)이면 {
                (* 조사가 없으면 이것이 동사 — 동사어근→명사형 폴백 *)
                문자열 함수이름 = 동사폴백(노드이름풀[값]).
                반환 함수이름을 첫인자를 줄을 열로 호출생성다.
            }
            정수 새인자 = 값을 역할로 인자생성다.
            인자다음풀[마지막인자] = 새인자.
            마지막인자 = 새인자.
        }
    }

    (* 도달하지 않아야 함 *)
    반환 첫값.
}

(* 최상위 표현식 파싱 *)
[표현식파싱]은 → 정수 {
    정수 값 = 0을 이항표현식다.

    (* 삼항 연산자: ? : *)
    ((현재종류 == 종류_물음표))이면 {
        정수 줄 = 현재줄.
        정수 열 = 현재열.
        전진().
        정수 참값 = 표현식파싱().
        기대(종류_쌍점, "\":\" 필요").
        정수 거짓값 = 표현식파싱().
        정수 노드 = 노드생성(노드_삼항, 줄, 열).
        노드왼쪽풀[노드] = 값.
        노드오른쪽풀[노드] = 참값.
        노드추가풀[노드] = 거짓값.
        반환 노드.
    }

    (* "이"/"가" 뒤에 어미(면, 동안, 고, 서, 다)나 마침표가 오면 SOV가 아님 *)
    (* 예: 파일 == 없음이면 → 파일 == 없음 + 이(소비) + 면(조건) *)
    ((현재종류 == 종류_이) + (현재종류 == 종류_가) > 0)이면 {
        정수 다음 = 0.
        버퍼위치 < 버퍼수이면 {
            다음 = 버퍼종류배열[버퍼위치].
        }
        ((다음 == 종류_면) + (다음 == 종류_동안) + (다음 == 종류_고) + (다음 == 종류_서) + (다음 == 종류_다) + (다음 == 종류_마침표) + (다음 == 종류_없으면) + (다음 == 종류_있으면) > 0)이면 {
            전진().
            반환 값.
        }
    }

    (* SOV 호출 감지: 값 뒤에 조사가 오면 *)
    정수 역할 = 조사소비().
    (역할 != 역할_없음)이면 {
        (* 형변환: 값을 타입으로 *)
        ((역할 == 역할_수단))이면 {
            타입시작인가() 이면 {
                정수 캐줄 = 현재줄.
                정수 캐열 = 현재열.
                정수 대상타입 = 타입파싱().
                정수 캐노드 = 노드생성(노드_형변환, 캐줄, 캐열).
                노드왼쪽풀[캐노드] = 값.
                노드오른쪽풀[캐노드] = 대상타입.
                (* 뒤에 조사가 있으면 SOV 계속, 아니면 반환 *)
                정수 다음역할 = 조사소비().
                (다음역할 != 역할_없음)이면 {
                    반환 SOV_호출파싱(캐노드, 다음역할).
                }
                반환 캐노드.
            }
        }

        (* SOV 호출 *)
        반환 SOV_호출파싱(값, 역할).
    }

    반환 값.
}

(* ===== 문장 파싱 ===== *)

(* 중괄호 리터럴 파싱: { 값1, 값2, ... } *)
[중괄호리터럴파싱]은 → 정수 {
    정수 줄 = 현재줄.
    정수 열 = 현재열.
    기대(종류_여는중괄호, "\"{\" 필요").

    정수 노드 = 노드생성(노드_배열리터럴, 줄, 열).
    정수 시작 = 목록시작().
    정수 원소수 = 0.

    (현재종류 != 종류_닫는중괄호) * (현재종류 != 종류_파일끝)동안 {
        (* 진행 감지용 *)
        정수 이전줄값 = 현재줄.
        정수 이전열값 = 현재열.

        (* 지정 초기화: 필드이름: 값 패턴 *)
        (* 형태소분석기가 필드이름을 조사로 분리할 수 있으므로 *)
        (* 쌍점(:) 전까지 식별자/조사 토큰을 건너뛴다 *)
        정수 지정탐색 = 1.
        정수 탐색수 = 0.
        정수 조사여부 = 조사인가(현재종류).
        ((현재종류 == 종류_식별자) + (조사여부 > 0) > 0) * (탐색수 < 10) * (지정탐색 == 1)동안 {
            ((현재종류 == 종류_쌍점))이면 {
                전진().
                지정탐색 = 0.
            }
            아니면 {
                정수 버퍼다음 = 0.
                (버퍼위치 < 버퍼수)이면 { 버퍼다음 = 버퍼종류배열[버퍼위치]. }
                ((버퍼다음 == 종류_쌍점))이면 {
                    전진().
                    전진().
                    지정탐색 = 0.
                }
                아니면 {
                    전진().
                    탐색수를 증가하다.
                    조사여부 = 조사인가(현재종류).
                }
            }
        }
        ((현재종류 == 종류_쌍점))이면 { 전진(). }

        정수 원소 = 표현식파싱().
        목록_추가(원소).
        원소수를 증가하다.
        일치(종류_쉼표).

        (* 무한루프 방지 *)
        (현재줄 == 이전줄값) * (현재열 == 이전열값) > 0이면 {
            전진().
        }
    }

    기대(종류_닫는중괄호, "\"}\" 필요").
    노드목록시작풀[노드] = 시작.
    노드목록수풀[노드] = 원소수.
    반환 노드.
}

(* 변수 선언 파싱 *)
[변수선언파싱]은 → 정수 {
    정수 줄 = 현재줄.
    정수 열 = 현재열.

    (* 정적/상수 접두사 *)
    정수 정적플래그 = 0.
    정수 상수플래그 = 0.
    ((현재종류 == 종류_정적) + (현재종류 == 종류_상수) > 0)동안 {
        (현재종류 == 종류_정적)이면 { 정적플래그 = 1. }
        (현재종류 == 종류_상수)이면 { 상수플래그 = 1. }
        전진().
    }

    선언이름모드 = 1.
    정수 타입 = 타입파싱().
    문자열 이름 = 현재텍스트.
    선언이름모드 = 0.
    (* 심볼 등록 *)
    심볼등록(이름).
    전진().

    정수 초기값 = -1.

    (* 은/는 → 초기값 *)
    정수 역할 = 조사소비().
    ((역할 == 역할_주제))이면 {
        (* 배열/묶음 초기화 리터럴: = { ... } 또는 은/는 { ... } *)
        (현재종류 == 종류_여는중괄호)이면 {
            초기값 = 중괄호리터럴파싱().
        }
        아니면 {
            초기값 = 표현식파싱().
        }
        정수 어미 = 어미소비().
        기대(종류_마침표, "\".\" 필요").
    }
    아니면 {
        (* 대입 연산자 *)
        ((현재종류 == 종류_대입))이면 {
            전진().
            (현재종류 == 종류_여는중괄호)이면 {
                초기값 = 중괄호리터럴파싱().
            }
            아니면 {
                초기값 = 표현식파싱().
            }
            정수 어미 = 어미소비().
            기대(종류_마침표, "\".\" 필요").
        }
        아니면 {
            정수 어미 = 어미소비().
            기대(종류_마침표, "\".\" 필요").
        }
    }

    정수 결과 = 타입을 이름을 초기값을 줄을 열로 변수선언생성다.
    (* 플래그: 비트0=외부, 비트1=정적, 비트2=상수 *)
    정적플래그이면 { 노드플래그풀[결과] = 노드플래그풀[결과] | 2. }
    상수플래그이면 { 노드플래그풀[결과] = 노드플래그풀[결과] | 4. }
    반환 결과.
}

(* 블록 파싱: { 문장들 } *)
[블록파싱]은 → 정수 {
    정수 줄 = 현재줄.
    정수 열 = 현재열.

    기대(종류_여는중괄호, "\"{\" 필요").

    정수 노드 = 노드생성(노드_블록, 줄, 열).

    (* 임시 배열에 먼저 수집 — 중첩 블록의 목록 인터리브 방지 *)
    (* 크기 축소: 스택 guard page 우회 — 네이티브 PE에 __chkstk 미지원 *)
    정수[256] 문장임시.
    정수 문장수 = 0.

    (현재종류 != 종류_닫는중괄호) * (현재종류 != 종류_파일끝)동안 {
        정수 이전줄기록 = 현재줄.
        정수 이전열기록 = 현재열.
        정수 문장 = 문장파싱().
        (문장 >= 0) * (문장수 < 256) > 0이면 {
            문장임시[문장수] = 문장.
            문장수를 증가하다.
        }
        패닉모드이면 { 동기화(). }
        (* 진행 감지: 토큰이 소비되지 않았으면 강제 전진 *)
        (현재줄 == 이전줄기록) * (현재열 == 이전열기록) > 0이면 {
            "오류: 블록 파싱 진행 없음 (줄 %d, 열 %d) — 건너뜀\n"을 현재줄을 현재열을 쓰다.
            전진().
        }
    }

    기대(종류_닫는중괄호, "\"}\" 필요").

    (* 수집한 문장들을 한꺼번에 목록 풀에 추가 *)
    정수 시작인덱스 = 목록시작().
    정수 복사번호 = 0.
    (복사번호 < 문장수)동안 {
        목록_추가(문장임시[복사번호]).
        복사번호를 증가하다.
    }

    노드목록시작풀[노드] = 시작인덱스.
    노드목록수풀[노드] = 문장수.
    반환 노드.
}

(* 조건문 파싱 (-면) *)
[정수 조건을 조건문파싱]은 → 정수 {
    정수 줄 = 노드줄풀[조건].
    정수 열 = 노드열풀[조건].

    정수 참블록 = 블록파싱().
    정수 거짓블록 = -1.

    (* 아니면 (else) / 아니면 ... 이면 (else if) *)
    ((현재종류 == 종류_아니면))이면 {
        전진().
        ((현재종류 == 종류_여는중괄호))이면 {
            거짓블록 = 블록파싱().
        }
        아니면 {
            (* else if: 표현식 파싱 → 어미 소비 → 재귀 조건문 *)
            정수 다음조건 = 표현식파싱().
            정수 어미 = 어미소비().
            거짓블록 = 다음조건을 조건문파싱다.
        }
    }

    반환 조건을 참블록을 거짓블록을 줄을 열로 조건문생성다.
}

(* 동안 반복 파싱 (-동안) *)
[정수 조건을 동안반복파싱]은 → 정수 {
    정수 줄 = 노드줄풀[조건].
    정수 열 = 노드열풀[조건].
    정수 본문 = 블록파싱().
    반환 조건을 본문을 줄을 열로 동안반복생성다.
}

(* 반환문 파싱 *)
[반환문파싱]은 → 정수 {
    정수 줄 = 현재줄.
    정수 열 = 현재열.
    전진(). (* '반환' 소비 *)

    정수 값 = -1.
    ((현재종류 != 종류_마침표))이면 {
        값 = 표현식파싱().
        정수 어미 = 어미소비().
    }
    기대(종류_마침표, "\".\" 필요").

    반환 값을 줄을 열로 반환문생성다.
}

(* 메인 문장 파싱 디스패처 *)
외부 [문장파싱]은 → 정수.

[문장파싱]은 → 정수 {
    정수 줄 = 현재줄.
    정수 열 = 현재열.

    (* 반환문 *)
    ((현재종류 == 종류_반환))이면 {
        반환 반환문파싱().
    }

    (* 탈출문 *)
    ((현재종류 == 종류_탈출))이면 {
        전진().
        기대(종류_마침표, "\".\" 필요").
        반환 노드생성(노드_탈출문, 줄, 열).
    }

    (* 계속문 *)
    ((현재종류 == 종류_계속))이면 {
        전진().
        기대(종류_마침표, "\".\" 필요").
        반환 노드생성(노드_계속문, 줄, 열).
    }

    (* 반복하기 (do-while): 반복하기 { 본문 } 조건 동안. *)
    ((현재종류 == 종류_반복하기))이면 {
        전진().
        정수 본문 = 블록파싱().
        정수 조건 = 표현식파싱().
        어미소비().
        기대(종류_마침표, "\".\" 필요").
        정수 노드 = 노드생성(노드_반복하기, 줄, 열).
        노드왼쪽풀[노드] = 조건.
        노드오른쪽풀[노드] = 본문.
        반환 노드.
    }

    (* N번 반복 { 본문 } — 정수 소비 후 "번" 확인 *)
    ((현재종류 == 종류_정수리터럴))이면 {
        정수 횟수줄 = 현재줄.
        정수 횟수열 = 현재열.
        정수 횟수값 = 정수로_변환(현재텍스트).
        전진(). (* 숫자 소비 *)
        ((현재종류 == 종류_식별자) * (문자열_비교(현재텍스트, "번") == 0))이면 {
            전진(). (* '번' 소비 *)
            ((현재종류 == 종류_반복))이면 { 전진(). }
            어미소비().
            정수 본문 = 블록파싱().
            정수 노드 = 노드생성(노드_반복문, 횟수줄, 횟수열).
            정수 초기화타입 = 노드생성(노드_기본타입, 횟수줄, 횟수열).
            노드정수풀[초기화타입] = 종류_정수.
            정수 초기화 = 노드생성(노드_변수선언, 횟수줄, 횟수열).
            노드이름풀[초기화] = "_n반복".
            노드왼쪽풀[초기화] = 초기화타입.
            정수 영 = 노드생성(노드_정수리터럴, 횟수줄, 횟수열).
            노드정수풀[영] = 0.
            노드오른쪽풀[초기화] = 영.
            정수 카운터 = 노드생성(노드_식별자, 횟수줄, 횟수열).
            노드이름풀[카운터] = "_n반복".
            정수 한계 = 노드생성(노드_정수리터럴, 횟수줄, 횟수열).
            노드정수풀[한계] = 횟수값.
            정수 조건 = 노드생성(노드_이항연산, 횟수줄, 횟수열).
            노드왼쪽풀[조건] = 카운터.
            노드오른쪽풀[조건] = 한계.
            노드연산자풀[조건] = 종류_작다.
            정수 증감카운터 = 노드생성(노드_식별자, 횟수줄, 횟수열).
            노드이름풀[증감카운터] = "_n반복".
            정수 증감 = 노드생성(노드_증감, 횟수줄, 횟수열).
            노드왼쪽풀[증감] = 증감카운터.
            노드플래그풀[증감] = 1. (* 비트0=1: 증가 *)
            노드왼쪽풀[노드] = 초기화.
            노드오른쪽풀[노드] = 본문.
            노드추가풀[노드] = 조건.
            노드정수풀[노드] = 증감.
            반환 노드.
        }
        (* "번"이 아님 — 정수를 표현식 문장으로 *)
        정수 숫자노드 = 노드생성(노드_정수리터럴, 횟수줄, 횟수열).
        노드정수풀[숫자노드] = 횟수값.
        어미소비().
        기대(종류_마침표, "\".\" 필요").
        반환 표현식문생성(숫자노드, 어미_없음, 횟수줄, 횟수열).
    }

    (* 반복 (C-style for): 반복 (초기화: 조건: 증감) { 본문 } *)
    ((현재종류 == 종류_반복))이면 {
        전진().
        기대(종류_여는괄호, "\"(\" 필요").
        (* 초기화 — 마침표 없이 파싱 *)
        정수 초기화 = -1.
        타입시작인가() 이면 {
            선언이름모드 = 1.
            정수 타입 = 타입파싱().
            문자열 이름 = 현재텍스트.
            선언이름모드 = 0.
            (* 심볼 테이블에 반복 변수명 등록 *)
            심볼등록(이름).
            전진().
            정수 초기값 = -1.
            정수 역할 = 조사소비().
            ((현재종류 == 종류_대입) + (역할 == 역할_주제))이면 {
                (현재종류 == 종류_대입)이면 { 전진(). }
                초기값 = 표현식파싱().
                어미소비().
            }
            초기화 = 타입을 이름을 초기값을 줄을 열로 변수선언생성다.
        }
        기대(종류_쌍점, "\":\" 필요").
        (* 조건 *)
        정수 포조건 = -1.
        (현재종류 != 종류_쌍점)이면 {
            포조건 = 표현식파싱().
        }
        기대(종류_쌍점, "\":\" 필요").
        (* 증감 *)
        정수 증감 = -1.
        (현재종류 != 종류_닫는괄호)이면 {
            증감 = 표현식파싱().
        }
        기대(종류_닫는괄호, "\")\" 필요").
        정수 본문 = 블록파싱().

        정수 노드 = 노드생성(노드_반복문, 줄, 열).
        노드왼쪽풀[노드] = 초기화.
        노드오른쪽풀[노드] = 본문.
        노드추가풀[노드] = 포조건.
        (* 증감부를 노드정수풀에 저장 — for(;;incr) 생성용 *)
        노드정수풀[노드] = 증감.
        반환 노드.
    }

    (* 갈래문 (switch): 갈래 대상 { 경우 값: { ... } 기본: { ... } } *)
    ((현재종류 == 종류_갈래))이면 {
        전진(). (* '갈래' 소비 *)
        정수 대상표현 = 표현식파싱().
        기대(종류_여는중괄호, "\"{\" 필요").

        정수 갈래노드 = 노드생성(노드_갈래문, 줄, 열).
        노드왼쪽풀[갈래노드] = 대상표현.

        (* 경우 목록을 임시 배열에 먼저 수집 — 인터리브 방지 *)
        (* 각 경우: 값 노드 + 본문 블록을 쌍으로 저장 *)
        정수[128] 경우임시. (* 최대 64개 경우 * 2 *)
        정수 경우수 = 0.

        (현재종류 != 종류_닫는중괄호) * (현재종류 != 종류_파일끝)동안 {
            (현재종류 == 종류_경우)이면 {
                전진(). (* '경우' 소비 *)
                정수 경우값 = 표현식파싱().
                일치(종류_쌍점). (* 콜론은 선택적 *)

                (* 경우 본문 파싱 *)
                정수 경우본문 = -1.
                (현재종류 == 종류_여는중괄호)이면 {
                    경우본문 = 블록파싱().
                }
                아니면 {
                    (* 중괄호 없으면 다음 경우/기본까지 문장 수집 *)
                    정수[64] 경우문임시.
                    정수 문수 = 0.
                    ((현재종류 != 종류_경우) * (현재종류 != 종류_기본) * (현재종류 != 종류_닫는중괄호) * (현재종류 != 종류_파일끝))동안 {
                        정수 경이전줄 = 현재줄.
                        정수 경이전열 = 현재열.
                        정수 문장결과 = 문장파싱().
                        문장결과 >= 0이면 {
                            경우문임시[문수] = 문장결과.
                            문수를 증가하다.
                        }
                        패닉모드이면 { 동기화(). }
                        (현재줄 == 경이전줄) * (현재열 == 경이전열) > 0이면 { 전진(). }
                    }
                    정수 경우블록 = 노드생성(노드_블록, 현재줄, 현재열).
                    정수 문시작 = 목록시작().
                    정수 복사번호 = 0.
                    (복사번호 < 문수)동안 {
                        목록_추가(경우문임시[복사번호]).
                        복사번호를 증가하다.
                    }
                    노드목록시작풀[경우블록] = 문시작.
                    노드목록수풀[경우블록] = 문수.
                    경우본문 = 경우블록.
                }
                경우임시[경우수 * 2] = 경우값.
                경우임시[경우수 * 2 + 1] = 경우본문.
                경우수를 증가하다.
            }
            아니면 (현재종류 == 종류_기본)이면 {
                전진(). (* '기본' 소비 *)
                일치(종류_쌍점). (* 콜론은 선택적 *)

                정수 기본본문 = -1.
                (현재종류 == 종류_여는중괄호)이면 {
                    기본본문 = 블록파싱().
                }
                아니면 {
                    정수[64] 기본문임시.
                    정수 문수 = 0.
                    ((현재종류 != 종류_경우) * (현재종류 != 종류_기본) * (현재종류 != 종류_닫는중괄호) * (현재종류 != 종류_파일끝))동안 {
                        정수 기이전줄 = 현재줄.
                        정수 기이전열 = 현재열.
                        정수 문장결과 = 문장파싱().
                        문장결과 >= 0이면 {
                            기본문임시[문수] = 문장결과.
                            문수를 증가하다.
                        }
                        패닉모드이면 { 동기화(). }
                        (현재줄 == 기이전줄) * (현재열 == 기이전열) > 0이면 { 전진(). }
                    }
                    정수 기본블록 = 노드생성(노드_블록, 현재줄, 현재열).
                    정수 문시작 = 목록시작().
                    정수 복사번호 = 0.
                    (복사번호 < 문수)동안 {
                        목록_추가(기본문임시[복사번호]).
                        복사번호를 증가하다.
                    }
                    노드목록시작풀[기본블록] = 문시작.
                    노드목록수풀[기본블록] = 문수.
                    기본본문 = 기본블록.
                }
                (* 기본은 값을 -1로 표시 *)
                경우임시[경우수 * 2] = -1.
                경우임시[경우수 * 2 + 1] = 기본본문.
                경우수를 증가하다.
            }
            아니면 {
                "'경우' 또는 '기본'이 필요합니다"를 파서오류다.
                탈출.
            }
        }

        기대(종류_닫는중괄호, "\"}\" 필요").

        (* 수집한 경우들을 한꺼번에 목록 풀에 추가 *)
        정수 경우시작 = 목록시작().
        정수 복사번호 = 0.
        (복사번호 < 경우수 * 2)동안 {
            목록_추가(경우임시[복사번호]).
            복사번호를 증가하다.
        }

        노드목록시작풀[갈래노드] = 경우시작.
        노드목록수풀[갈래노드] = 경우수.
        반환 갈래노드.
    }

    (* 타입 추론 변수 선언: 식별자 + 은/는 + 값 → 타입 생략 선언 *)
    (현재종류 == 종류_식별자)이면 {
        정수 다음종류 = 0.
        버퍼위치 < 버퍼수이면 { 다음종류 = 버퍼종류배열[버퍼위치]. }
        ((다음종류 == 종류_은) + (다음종류 == 종류_는) > 0)이면 {
            (* 심볼 테이블에 없는 새 이름이면 타입 추론 *)
            정수 이름길이 = 글자수(현재텍스트).
            심볼인가(현재텍스트, 이름길이) == 0이면 {
                정수 줄 = 현재줄.
                정수 열 = 현재열.
                문자열 이름 = 현재텍스트.
                심볼등록(이름).
                전진().  (* 식별자 소비 *)
                전진().  (* 은/는 소비 *)
                정수 초기값 = 표현식파싱().
                (* 초기값의 노드 종류에서 타입 추론 *)
                정수 추론타입종류 = 종류_정수.  (* 기본값: 정수 *)
                초기값 >= 0이면 {
                    정수 초종류 = 노드종류풀[초기값].
                    (초종류 == 노드_실수리터럴)이면 { 추론타입종류 = 종류_실수. }
                    (초종류 == 노드_문자열리터럴)이면 { 추론타입종류 = 종류_문자열. }
                    (초종류 == 노드_문자리터럴)이면 { 추론타입종류 = 종류_문자. }
                }
                정수 타입 = 추론타입종류를 줄을 열로 기본타입생성다.
                어미소비().
                기대(종류_마침표, "\".\" 필요").
                반환 타입을 이름을 초기값을 줄을 열로 변수선언생성다.
            }
        }
    }

    (* 변수 선언: 타입으로 시작 *)
    타입시작인가() 이면 {
        반환 변수선언파싱().
    }

    (* 표현식 문장 *)
    정수 표현 = 표현식파싱().

    (* SOV 파싱에서 반환문이 생성된 경우 직접 반환 *)
    (표현 >= 0) * (노드종류풀[표현] == 노드_반환문) > 0이면 {
        어미소비().
        일치(종류_마침표).
        반환 표현.
    }

    (* 대입문: 표현식 = 값. 또는 복합대입 +=, -= 등 *)
    ((현재종류 == 종류_대입) + (현재종류 == 종류_더하기대입) + (현재종류 == 종류_빼기대입) + (현재종류 == 종류_곱하기대입) + (현재종류 == 종류_나누기대입) + (현재종류 == 종류_나머지대입) > 0)이면 {
        정수 연산종류 = 현재종류.
        전진().
        정수 값 = 표현식파싱().
        어미소비(). (* SOV 호출의 종결 어미 소비 *)
        기대(종류_마침표, "\".\" 필요").
        반환 표현을 값을 연산종류를 줄을 열로 대입생성다.
    }

    (* 없으면 → 표현 == 0 조건문 (null/zero 검사) *)
    ((현재종류 == 종류_없으면))이면 {
        전진().  (* "없으면" 소비 *)
        정수 영 = 0을 줄을 열로 정수리터럴생성다.
        정수 비교 = 이항연산생성(종류_같다, 표현, 영, 줄, 열).
        반환 비교를 조건문파싱다.
    }

    (* 있으면 → 표현 != 0 조건문 (non-null/nonzero 검사) *)
    ((현재종류 == 종류_있으면))이면 {
        전진().  (* "있으면" 소비 *)
        정수 영 = 0을 줄을 열로 정수리터럴생성다.
        정수 비교 = 이항연산생성(종류_다르다, 표현, 영, 줄, 열).
        반환 비교를 조건문파싱다.
    }

    (* 어미에 따른 분기 *)
    정수 어미 = 어미소비().

    (* -면 → 조건문 *)
    ((어미 == 어미_면))이면 {
        반환 표현을 조건문파싱다.
    }

    (* -동안 → 반복문 *)
    ((어미 == 어미_동안))이면 {
        반환 표현을 동안반복파싱다.
    }

    (* -고 → 문장 연결: 현재 문장 완료 후 다음 문장 파싱 *)
    ((어미 == 어미_고))이면 {
        정수 첫문장은 표현을 어미를 줄을 열로 표현식문생성다.
        정수 둘째문장은 문장파싱().
        (* 블록으로 묶음 *)
        정수 연결블록은 노드생성(노드_블록, 줄, 열).
        정수 연결시작 = 목록시작().
        정수 연결수 = 1.
        목록_추가(첫문장).
        둘째문장 >= 0이면 { 목록_추가(둘째문장). 연결수 = 2. }
        노드목록시작풀[연결블록] = 연결시작.
        노드목록수풀[연결블록] = 연결수.
        반환 연결블록.
    }

    (* -다 또는 어미없음 → 표현식 문장 *)
    기대(종류_마침표, "\".\" 필요").
    반환 표현을 어미를 줄을 열로 표현식문생성다.
}

(* ===== 나열(enum) 풀 ===== *)
(* 나열 값을 저장할 병렬 배열 *)
정수 최대나열값수 = 2048.
문자열[2048] 나열값이름풀.
정수[2048] 나열값정수풀.
정수 나열값총수 = 0.

(* ===== 나열 정의 파싱 ===== *)
[나열정의파싱]은 → 정수 {
    정수 줄 = 현재줄.
    정수 열 = 현재열.
    전진(). (* '나열' 소비 *)

    문자열 이름 = 현재텍스트.
    전진(). (* 이름 소비 *)

    (* 타입 등록 *)
    이름을 타입이름등록다.
    (* 심볼 테이블에 나열 이름 등록 *)
    심볼등록(이름).

    (* 은/는 소비 *)
    조사소비().

    (* { 값1, 값2 = N, ... } *)
    기대(종류_여는중괄호, "\"{\" 필요").

    정수 노드 = 노드생성(노드_나열정의, 줄, 열).
    노드이름풀[노드] = 이름.

    (* 나열 값 수집 — 나열값풀에 저장 *)
    정수 값시작 = 나열값총수.
    정수 자동값 = 0.

    (현재종류 != 종류_닫는중괄호) * (현재종류 != 종류_파일끝)동안 {
        (* 값 이름 *)
        문자열 값이름 = 현재텍스트.
        전진().

        (* 명시적 값: = 숫자 *)
        일치(종류_대입) 이면 {
            (현재종류 == 종류_정수리터럴)이면 {
                자동값 = 현재토큰정수().
                전진().
            }
        }

        (* 심볼 테이블에 나열 값 이름 등록 *)
        심볼등록(값이름).
        나열값이름풀[나열값총수] = 값이름.
        나열값정수풀[나열값총수] = 자동값.
        나열값총수를 증가하다.
        자동값를 증가하다.

        일치(종류_쉼표).
    }

    기대(종류_닫는중괄호, "\"}\" 필요").

    (* 나열 값 목록을 목록풀에 저장 (인덱스 범위) *)
    노드목록시작풀[노드] = 값시작.
    노드목록수풀[노드] = 나열값총수 - 값시작.

    (* 종결 어미 + 마침표 (선택적) *)
    정수 어미 = 어미소비().
    일치(종류_마침표).

    반환 노드.
}

(* ===== 묶음(struct) 정의 파싱 ===== *)
[묶음정의파싱]은 → 정수 {
    정수 줄 = 현재줄.
    정수 열 = 현재열.
    전진(). (* '묶음' 소비 *)

    문자열 이름 = 현재텍스트.
    전진(). (* 이름 소비 *)

    (* 타입 등록 *)
    이름을 타입이름등록다.
    (* 심볼 테이블에 묶음 이름 등록 *)
    심볼등록(이름).

    (* 은/는 소비 *)
    조사소비().

    정수 노드 = 노드생성(노드_묶음정의, 줄, 열).
    노드이름풀[노드] = 이름.

    (* 필드 목록: 타입1 이름1, 타입2 이름2. *)
    정수 첫필드 = -1.
    정수 마지막필드 = -1.

    (타입시작인가())동안 {
        선언이름모드 = 1.
        정수 타입 = 타입파싱().
        문자열 필드이름 = 현재텍스트.
        선언이름모드 = 0.
        (* 심볼 테이블에 필드명 등록 *)
        심볼등록(필드이름).
        전진().

        정수 필드 = 타입을 필드이름을 필드생성다.
        첫필드 < 0이면 { 첫필드 = 필드. }
        마지막필드 >= 0이면 { 필드다음풀[마지막필드] = 필드. }
        마지막필드 = 필드.

        (* 쉼표가 있으면 소비, 없으면 루프 종료 *)
        ((현재종류 == 종류_쉼표))이면 {
            전진().
        }
    }

    노드왼쪽풀[노드] = 첫필드.

    (* 마침표 소비 *)
    일치(종류_마침표).

    반환 노드.
}

(* ===== 최상위 선언 파싱 ===== *)

(* 함수 정의: [매개변수목록 함수이름]은/는 → 반환타입 { 본문 } *)
[함수정의파싱]은 → 정수 {
    정수 줄 = 현재줄.
    정수 열 = 현재열.

    기대(종류_여는대괄호, "\"[\" 필요").

    정수 첫매개 = -1.
    정수 마지막매개 = -1.
    문자열 함수이름 = 0.
    정수 가변인자플래그 = 0.

    (* 매개변수와 함수이름 파싱 *)
    (현재종류 != 종류_닫는대괄호) * (현재종류 != 종류_파일끝)동안 {
        (* 가변인자 ... (마침표 3개) *)
        ((현재종류 == 종류_마침표))이면 {
            가변인자플래그 = 1.
            전진().
            일치(종류_마침표).
            일치(종류_마침표).
        }
        (* 타입이 오면 매개변수 *)
        아니면 타입시작인가() 이면 {
            선언이름모드 = 1.
            정수 타입 = 타입파싱().
            문자열 이름 = 현재텍스트.
            선언이름모드 = 0.
            전진().
            정수 역할 = 조사소비().
            정수 매개 = 타입을 이름을 역할로 매개변수생성다.
            첫매개 < 0이면 { 첫매개 = 매개. }
            마지막매개 >= 0이면 { 매개다음풀[마지막매개] = 매개. }
            마지막매개 = 매개.
        }
        아니면 {
            (* 타입이 아니면 함수 이름 — 식별자/키워드/조사/어미만 허용 *)
            (현재종류 == 종류_식별자) + 조사인가(현재종류) + 어미인가(현재종류) + 타입키워드인가(현재종류) > 0이면 {
                함수이름 = 현재텍스트.
                (* 심볼 테이블에 함수명 등록 *)
                심볼등록(함수이름).
                함수이름을 함수이름등록다.
                전진().
            }
            아니면 {
                "함수 이름이 필요합니다"를 파서오류다.
                전진().
            }
        }
    }

    기대(종류_닫는대괄호, "\"]\" 필요").

    (* 은/는 소비 *)
    조사소비().

    (* 반환 타입 *)
    정수 반환타입 = -1.
    ((현재종류 == 종류_화살표))이면 {
        전진().
        반환타입 = 타입파싱().
    }

    (* 본문 — 외부 선언이면 본문 없음 *)
    정수 본문 = -1.
    ((현재종류 == 종류_여는중괄호))이면 {
        본문 = 블록파싱().
    }
    아니면 {
        (* 전방선언 / 외부선언: 마침표 소비 *)
        일치(종류_마침표).
    }

    정수 노드 = 노드생성(노드_함수정의, 줄, 열).
    노드이름풀[노드] = 함수이름.
    노드왼쪽풀[노드] = 첫매개.
    노드오른쪽풀[노드] = 본문.
    노드추가풀[노드] = 반환타입.
    가변인자플래그이면 { 노드플래그풀[노드] = 노드플래그풀[노드] | 4. }
    반환 노드.
}

(* 외부 선언 파싱 *)
[외부선언파싱]은 → 정수 {
    정수 줄 = 현재줄.
    정수 열 = 현재열.
    전진(). (* '외부' 소비 *)

    (* 함수 선언: 외부 [매개변수 함수이름]은 → 반환타입. *)
    ((현재종류 == 종류_여는대괄호))이면 {
        정수 노드 = 함수정의파싱().
        노드플래그풀[노드] = 노드플래그풀[노드] | 1. (* 외부 플래그 *)
        반환 노드.
    }

    (* 전역변수 외부선언: 외부 타입 이름. *)
    타입시작인가() 이면 {
        선언이름모드 = 1.
        정수 타입 = 타입파싱().
        문자열 이름 = 현재텍스트.
        선언이름모드 = 0.
        (* 심볼 테이블에 외부 변수명 등록 *)
        심볼등록(이름).
        전진().
        정수 어미 = 어미소비().
        일치(종류_마침표).
        정수 노드 = 타입을 이름을 -1을 줄을 열로 변수선언생성다.
        노드플래그풀[노드] = 1. (* 외부 플래그 *)
        반환 노드.
    }

    "외부 선언에서 \"[\" 또는 타입이 필요합니다"를 파서오류다.
    반환 -1.
}

(* 최상위 선언 디스패처 *)
[최상위선언파싱]은 → 정수 {
    (* 외부 선언 *)
    ((현재종류 == 종류_외부))이면 {
        반환 외부선언파싱().
    }

    (* 함수 정의: [ 로 시작 *)
    ((현재종류 == 종류_여는대괄호))이면 {
        반환 함수정의파싱().
    }

    (* 묶음(struct) 정의 *)
    ((현재종류 == 종류_묶음))이면 {
        반환 묶음정의파싱().
    }

    (* 나열(enum) 정의 *)
    ((현재종류 == 종류_나열))이면 {
        반환 나열정의파싱().
    }

    (* 별칭(typedef) 정의 *)
    ((현재종류 == 종류_별칭))이면 {
        정수 줄 = 현재줄.
        정수 열 = 현재열.
        전진(). (* '별칭' 소비 *)
        문자열 이름 = 현재텍스트.
        전진().
        조사소비(). (* 은/는 *)
        정수 타입 = 타입파싱().
        정수 어미 = 어미소비().
        일치(종류_마침표).
        이름을 타입이름등록다.
        (* 심볼 테이블에 별칭 이름 등록 *)
        심볼등록(이름).
        정수 노드 = 노드생성(노드_별칭정의, 줄, 열).
        노드이름풀[노드] = 이름.
        노드왼쪽풀[노드] = 타입.
        반환 노드.
    }

    (* 합침(union) 정의 *)
    ((현재종류 == 종류_합침))이면 {
        정수 줄 = 현재줄.
        정수 열 = 현재열.
        전진(). (* '합침' 소비 *)
        문자열 이름 = 현재텍스트.
        전진().
        이름을 타입이름등록다.
        (* 심볼 테이블에 합침 이름 등록 *)
        심볼등록(이름).
        조사소비().
        정수 노드 = 노드생성(노드_합침정의, 줄, 열).
        노드이름풀[노드] = 이름.
        (* 필드 목록 — 묶음과 동일한 구조 *)
        정수 첫필드 = -1.
        정수 마지막필드 = -1.
        (타입시작인가())동안 {
            선언이름모드 = 1.
            정수 타입 = 타입파싱().
            문자열 필드이름 = 현재텍스트.
            선언이름모드 = 0.
            (* 심볼 테이블에 합침 필드명 등록 *)
            심볼등록(필드이름).
            전진().
            정수 필드 = 타입을 필드이름을 필드생성다.
            첫필드 < 0이면 { 첫필드 = 필드. }
            마지막필드 >= 0이면 { 필드다음풀[마지막필드] = 필드. }
            마지막필드 = 필드.
            일치(종류_쉼표).
        }
        노드왼쪽풀[노드] = 첫필드.
        정수 어미 = 어미소비().
        일치(종류_마침표).
        반환 노드.
    }

    (* 정의(#define): 정의 이름 값. *)
    ((현재종류 == 종류_정의))이면 {
        정수 줄 = 현재줄.
        정수 열 = 현재열.
        전진(). (* '정의' 소비 *)

        문자열 이름 = 현재텍스트.
        이름을 함수이름등록다.
        전진().

        (* 값이 있으면 읽기 — 식별자, 정수리터럴, 실수리터럴, 문자열리터럴 *)
        문자열 값 = 0.
        (현재종류 == 종류_식별자) + (현재종류 == 종류_정수리터럴) + (현재종류 == 종류_실수리터럴) + (현재종류 == 종류_문자열리터럴) > 0이면 {
            값 = 현재텍스트.
            전진().
        }

        어미소비().
        일치(종류_마침표).

        정수 노드 = 노드생성(노드_매크로정의, 줄, 열).
        노드이름풀[노드] = 이름.
        노드문자열풀[노드] = 값.
        반환 노드.
    }

    (* 포함: 전처리기가 이미 처리 — 건너뛰기 *)
    ((현재종류 == 종류_포함))이면 {
        전진(). (* '포함' 소비 *)
        (현재종류 == 종류_문자열리터럴)이면 { 전진(). }
        반환 -1.
    }

    (* 변수 선언: 타입으로 시작 *)
    타입시작인가() 이면 {
        반환 변수선언파싱().
    }

    (현재종류 == 종류_닫는중괄호)이면 {
        "'}'가 너무 많습니다 — 여는 '{'와 짝이 맞는지 확인하세요"를 파서오류다.
    }
    아니면 (현재종류 == 종류_식별자)이면 {
        버퍼에_쓰기(기대오류버퍼, 256, "최상위에서 '%s'을(를) 사용할 수 없습니다 — 함수 안에서 사용하세요", 현재텍스트).
        기대오류버퍼를 파서오류다.
    }
    아니면 {
        문자열 선언오류텍스트 = 현재종류를 토큰종류이름다.
        버퍼에_쓰기(기대오류버퍼, 256, "함수 정의, 변수 선언, 또는 정의가 필요합니다 — '%s'이(가) 있습니다", 선언오류텍스트).
        기대오류버퍼를 파서오류다.
    }
    동기화().
    반환 -1.
}

(* ===== 프로그램 파싱 (진입점) ===== *)

[문자열 소스를 정수 길이를 문자열 파일명으로 파서초기화]는 {
    렉서초기화(소스, 길이, 파일명).
    전진().
}

(* 프로그램파싱 전용 — 전역으로 이동: 스택 guard page 우회 *)
정수[4096] 선언임시.

[프로그램파싱]은 → 정수 {
    정수 줄 = 1.
    정수 열 = 1.
    정수 프로그램 = 노드생성(노드_프로그램, 줄, 열).
    정수 선언수 = 0.

    (현재종류 != 종류_파일끝)동안 {
        정수 이전줄기록 = 현재줄.
        정수 이전열기록 = 현재열.
        정수 선언 = 최상위선언파싱().
        (선언 >= 0) * (선언수 < 4096) > 0이면 {
            선언임시[선언수] = 선언.
            선언수를 증가하다.
        }
        (* 진행 감지: 토큰이 소비되지 않았으면 강제 전진 *)
        (현재줄 == 이전줄기록) * (현재열 == 이전열기록) > 0이면 {
            "오류: 파싱 진행 없음 (줄 %d, 열 %d) — 건너뜀\n"을 현재줄을 현재열을 쓰다.
            전진().
        }
    }

    (* 수집한 선언들을 한꺼번에 목록 풀에 추가 *)
    정수 시작인덱스 = 목록시작().
    정수 복사번호 = 0.
    (복사번호 < 선언수)동안 {
        목록_추가(선언임시[복사번호]).
        복사번호를 증가하다.
    }

    노드목록시작풀[프로그램] = 시작인덱스.
    노드목록수풀[프로그램] = 선언수.
    반환 프로그램.
}

[파서_오류있는가]는 → 참거짓 {
    반환 오류수 > 0.
}
