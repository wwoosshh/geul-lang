{
  "시작하기 (메인 함수)": {
    "prefix": "시작",
    "body": [
      "[시작하기]는 {",
      "    $0",
      "}"
    ],
    "description": "프로그램 시작점"
  },
  "함수 정의": {
    "prefix": "함수",
    "body": [
      "[${1:정수} ${2:값을} ${3:함수이름}]은 → ${4:정수} {",
      "    $0",
      "}"
    ],
    "description": "새 함수 정의"
  },
  "조건문": {
    "prefix": "이면",
    "body": [
      "${1:조건}이면 {",
      "    $0",
      "}"
    ],
    "description": "조건문 (if)"
  },
  "조건-아니면": {
    "prefix": "아니면",
    "body": [
      "${1:조건}이면 {",
      "    $2",
      "}",
      "아니면 {",
      "    $0",
      "}"
    ],
    "description": "조건-아니면 (if-else)"
  },
  "동안 반복": {
    "prefix": "동안",
    "body": [
      "(${1:조건})동안 {",
      "    $0",
      "}"
    ],
    "description": "반복문 (while)"
  },
  "반복문 (for)": {
    "prefix": "반복",
    "body": [
      "반복 (${1:정수 번호 = 0}: ${2:번호 < 10}: ${3:번호++}) {",
      "    $0",
      "}"
    ],
    "description": "반복문 (for)"
  },
  "변수 선언": {
    "prefix": "정수",
    "body": "정수 ${1:이름} = ${2:0}.",
    "description": "정수 변수 선언"
  },
  "출력": {
    "prefix": "쓰기",
    "body": "\"${1:%d}\\n\"을 ${2:값을} 쓰기다.",
    "description": "printf 출력"
  },
  "표준 포함": {
    "prefix": "포함",
    "body": "포함 \"표준/기본.글\"",
    "description": "표준 라이브러리 포함"
  },
  "묶음 (구조체)": {
    "prefix": "묶음",
    "body": [
      "묶음 ${1:이름}은",
      "    ${2:정수} ${3:필드1},",
      "    ${4:정수} ${5:필드2}."
    ],
    "description": "구조체 정의"
  }
}
