포함 "std.gl"

(* 검증: 1B / 2B 배열 읽기·쓰기 (pe_gen의 movzx/mov_word 인코딩 경로) *)
[시작하기]는 -> 정수 {
    정수 실패 = 0.

    (* 부호없는 작은정수 배열 (1바이트씩) *)
    부호없는 작은정수[8] 바이트배열.
    정수 i = 0.
    (i < 8)동안 {
        바이트배열[i] = i * 30.  (* 0, 30, 60, ... 210 *)
        i = i + 1.
    }
    (* 재검증 *)
    i = 0.
    (i < 8)동안 {
        정수 기대 = i * 30.
        바이트배열[i] != 기대이면 {
            쓰기("바이트 [%d]: got %d, want %d\n", i, 바이트배열[i], 기대).
            실패 = 실패 + 1.
        }
        i = i + 1.
    }

    (* 부호없는 짧은정수 배열 (2바이트씩) *)
    부호없는 짧은정수[6] 워드배열.
    정수 j = 0.
    (j < 6)동안 {
        워드배열[j] = 10000 + j * 1000.
        j = j + 1.
    }
    j = 0.
    (j < 6)동안 {
        정수 기대2 = 10000 + j * 1000.
        워드배열[j] != 기대2이면 {
            쓰기("워드 [%d]: got %d, want %d\n", j, 워드배열[j], 기대2).
            실패 = 실패 + 100.
        }
        j = j + 1.
    }

    실패 == 0이면 {
        쓰기("sign_3_array_rw: OK\n").
        반환 0.
    }
    쓰기("sign_3_array_rw: FAIL (총 %d)\n", 실패).
    반환 1.
}
