포함 "std.gl"

(* 검증: 부호있는 짧은정수/작은정수 배열 — 부호 확장(movsx) 경로 *)
[시작하기]는 -> 정수 {
    정수 실패 = 0.

    (* 짧은정수(signed 2B) — 음수 저장/로드 시 부호확장 *)
    짧은정수[4] s_arr.
    s_arr[0] = -1.
    s_arr[1] = -30000.
    s_arr[2] = 0.
    s_arr[3] = 32767.

    s_arr[0] != -1이면 {
        쓰기("s_arr[0]=%d, want -1\n", s_arr[0]).
        실패 = 실패 + 1.
    }
    s_arr[1] != -30000이면 {
        쓰기("s_arr[1]=%d, want -30000\n", s_arr[1]).
        실패 = 실패 + 2.
    }
    s_arr[3] != 32767이면 { 실패 = 실패 + 4. }

    (* 작은정수(signed 1B) — 음수 저장/로드 *)
    작은정수[4] t_arr.
    t_arr[0] = -1.
    t_arr[1] = -128.
    t_arr[2] = 0.
    t_arr[3] = 127.

    t_arr[0] != -1이면 {
        쓰기("t_arr[0]=%d, want -1\n", t_arr[0]).
        실패 = 실패 + 8.
    }
    t_arr[1] != -128이면 {
        쓰기("t_arr[1]=%d, want -128\n", t_arr[1]).
        실패 = 실패 + 16.
    }
    t_arr[3] != 127이면 { 실패 = 실패 + 32. }

    실패 == 0이면 {
        쓰기("sign_5_signed_extend: OK\n").
        반환 0.
    }
    쓰기("sign_5_signed_extend: FAIL (코드=%d)\n", 실패).
    반환 1.
}
