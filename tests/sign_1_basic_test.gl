포함 "std.gl"

(* 검증: "부호없는" 수정자 + 정수/긴정수 기본 동작 *)
[시작하기]는 -> 정수 {
    정수 실패 = 0.

    (* 1. 부호없는 단독 (64비트) — 기존 동작 유지 *)
    부호없는 a = 18446744073709551615.
    a != 18446744073709551615이면 { 실패 = 실패 + 1. }

    (* 2. 부호없는 정수 (64비트 unsigned) *)
    부호없는 정수 b = 10000000000.
    b != 10000000000이면 { 실패 = 실패 + 2. }

    (* 3. 부호없는 긴정수 *)
    부호없는 긴정수 c = 12345678901234.
    c != 12345678901234이면 { 실패 = 실패 + 4. }

    (* 4. 단순 산술이 부호없음 의미대로 동작 *)
    부호없는 정수 d = a / 10.
    d != 1844674407370955161이면 { 실패 = 실패 + 8. }

    실패 == 0이면 {
        쓰기("sign_1_basic: OK\n").
        반환 0.
    }
    쓰기("sign_1_basic: FAIL (코드=%d)\n", 실패).
    반환 1.
}
