포함 "std.gl"

(* 검증: pe_gen.gl 스택 슬롯 할당 수정 — 작은 배열이 인접 스칼라를 덮는 버그 회귀 *)
(* 과거 동작: 묶음크기≤8인 배열도 1차 패스(스칼라)로 할당되어 인접 슬롯 덮어씀 *)
(* 현재 동작: 원소크기>0 또는 크기>8이면 반드시 2차 패스로 분리 *)
[시작하기]는 -> 정수 {
    정수 실패 = 0.

    (* 스칼라-배열-스칼라 배치로 버그 재현 *)
    정수 앞 = 1111111.
    부호없는 작은정수[4] 배1.  (* 총 4바이트, 과거엔 1차로 가던 위험 크기 *)
    정수 뒤 = 2222222.

    배1[0] = 11.
    배1[1] = 22.
    배1[2] = 33.
    배1[3] = 44.

    (* 인접 스칼라 손상 여부 *)
    앞 != 1111111이면 {
        쓰기("앞 손상: got %d\n", 앞).
        실패 = 실패 + 1.
    }
    뒤 != 2222222이면 {
        쓰기("뒤 손상: got %d\n", 뒤).
        실패 = 실패 + 2.
    }

    (* 배열 값도 보존되어야 *)
    배1[0] != 11이면 { 실패 = 실패 + 4. }
    배1[1] != 22이면 { 실패 = 실패 + 8. }
    배1[2] != 33이면 { 실패 = 실패 + 16. }
    배1[3] != 44이면 { 실패 = 실패 + 32. }

    (* 짧은정수 배열 (총 8바이트, 또다른 경계) *)
    정수 앞2 = 7777777.
    부호없는 짧은정수[4] 배2.
    정수 뒤2 = 8888888.
    배2[0] = 1000. 배2[1] = 2000. 배2[2] = 3000. 배2[3] = 4000.
    앞2 != 7777777이면 { 실패 = 실패 + 64. }
    뒤2 != 8888888이면 { 실패 = 실패 + 128. }
    배2[2] != 3000이면 { 실패 = 실패 + 256. }

    실패 == 0이면 {
        쓰기("sign_4_stack_slot: OK\n").
        반환 0.
    }
    쓰기("sign_4_stack_slot: FAIL (코드=%d)\n", 실패).
    반환 1.
}
