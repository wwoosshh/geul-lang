포함 "std.gl"

(* 검증: 부호없는 작은정수(1B) / 짧은정수(2B) 스칼라 저장·로드 *)
[시작하기]는 -> 정수 {
    정수 실패 = 0.

    (* 작은정수 (1바이트) 경계값 *)
    부호없는 작은정수 t1 = 0.
    부호없는 작은정수 t2 = 200.
    부호없는 작은정수 t3 = 255.
    t1 != 0이면 { 실패 = 실패 + 1. }
    t2 != 200이면 { 실패 = 실패 + 2. }
    t3 != 255이면 { 실패 = 실패 + 4. }

    (* 짧은정수 (2바이트) 경계값 *)
    부호없는 짧은정수 s1 = 0.
    부호없는 짧은정수 s2 = 50000.
    부호없는 짧은정수 s3 = 65535.
    s1 != 0이면 { 실패 = 실패 + 8. }
    s2 != 50000이면 { 실패 = 실패 + 16. }
    s3 != 65535이면 { 실패 = 실패 + 32. }

    실패 == 0이면 {
        쓰기("sign_2_small_types: OK (%d %d %d %d %d %d)\n", t1, t2, t3, s1, s2, s3).
        반환 0.
    }
    쓰기("sign_2_small_types: FAIL (코드=%d) t=%d,%d,%d s=%d,%d,%d\n", 실패, t1, t2, t3, s1, s2, s3).
    반환 1.
}
