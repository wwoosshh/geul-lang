{
  "name": "geul-language",
  "displayName": "글 프로그래밍 언어",
  "description": "한글로 프로그래밍하는 글(Geul) 언어 — 문법 강조, F5 실행, 빌드",
  "version": "0.2.0",
  "publisher": "geul-lang",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Programming Languages", "Snippets"],
  "activationEvents": ["onLanguage:geul"],
  "main": "./extension.js",
  "icon": "icon.png",
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "contributes": {
    "languages": [
      {
        "id": "geul",
        "aliases": ["글", "Geul"],
        "extensions": [".글"],
        "filenamePatterns": ["*.글"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "geul",
        "scopeName": "source.geul",
        "path": "./syntaxes/geul.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "geul",
        "path": "./snippets.json"
      }
    ],
    "commands": [
      {
        "command": "geul.run",
        "title": "글: 실행 (F5)"
      },
      {
        "command": "geul.build",
        "title": "글: 빌드"
      },
      {
        "command": "geul.check",
        "title": "글: 검사"
      }
    ],
    "keybindings": [
      {
        "command": "geul.run",
        "key": "f5",
        "when": "editorLangId == geul && !inDebugMode"
      },
      {
        "command": "geul.build",
        "key": "ctrl+shift+b",
        "when": "editorLangId == geul"
      }
    ],
    "configuration": {
      "title": "글 언어",
      "properties": {
        "geul.toolPath": {
          "type": "string",
          "default": "",
          "description": "글도구.exe 경로 (비워두면 확장에 포함된 것을 사용)"
        }
      }
    }
  }
}
