(* ===== 문법 검사 ===== *)

[문자열 소스파일을 문법검사]는 → 정수 {
    문자열 소스원본은 파일읽기(소스파일).
    소스원본 == 0이면 {
        파일에_쓰기(표준오류, "오류: 파일을 열 수 없습니다: %s\n", 소스파일).
        반환 1.
    }
    정수 원본길이는 글자수(소스원본).
    문자열 소스디렉은 디렉토리추출(소스파일).

    포함된파일수 = 0.
    포함등록(문자열_복제(소스파일)).
    문자열 소스는 포함전처리(소스원본, 원본길이, 소스디렉).
    해제(소스원본).

    정수 소스길이는 글자수(소스).
    파서초기화(소스, 소스길이, 소스파일).
    프로그램파싱().

    파서_오류있는가() 이면 {
        파일에_쓰기(표준오류, "검사 결과: %d개 오류 발견\n", 오류수).
        해제(소스).
        해제(소스디렉).
        반환 1.
    }

    파일에_쓰기(표준오류, "검사 완료: 오류 없음\n").
    해제(소스).
    해제(소스디렉).
    반환 0.
}

(* ===== 메인 진입점 ===== *)

[정수 argc를 문자열 참조 argv를 시작하기]는 {
    (* 도구 경로 설정 *)
    도구경로 = argv[0]을 도구디렉토리추출다.

    (* C 컴파일러 탐색 *)
    씨컴파일러탐색().

    (* 인자 없으면 도움말 *)
    argc < 2이면 {
        도움말출력().
        반환.
    }

    문자열 명령은 argv[1].

    (* 도움 *)
    문자열_비교(명령, "도움") == 0이면 {
        도움말출력().
        반환.
    }
    문자열_비교(명령, "--help") == 0이면 {
        도움말출력().
        반환.
    }

    (* 소스 파일이 필요한 명령들 *)
    argc < 3이면 {
        파일에_쓰기(표준오류, "오류: 소스 파일을 지정하세요\n").
        파일에_쓰기(표준오류, "  사용법: 글도구 %s <소스.글>\n", 명령).
        반환.
    }

    문자열 소스파일은 argv[2].

    (* 검사 *)
    문자열_비교(명령, "검사") == 0이면 {
        소스파일을 문법검사다.
        반환.
    }

    (* 실행 *)
    문자열_비교(명령, "실행") == 0이면 {
        씨컴파일러종류 == 0이면 {
            파일에_쓰기(표준오류, "오류: C 컴파일러를 찾을 수 없습니다.\n").
            반환.
        }
        글컴파일(소스파일, 0, 1).
        반환.
    }

    (* 빌드 *)
    문자열_비교(명령, "빌드") == 0이면 {
        씨컴파일러종류 == 0이면 {
            파일에_쓰기(표준오류, "오류: C 컴파일러를 찾을 수 없습니다.\n").
            반환.
        }
        (* 출력 이름 확인 *)
        문자열 출력이름은 0.
        정수 인자번호 = 3.
        (인자번호 < argc)동안 {
            (문자열_비교(argv[인자번호], "-출력") == 0) * (인자번호 + 1 < argc)이면 {
                출력이름 = argv[인자번호 + 1].
                인자번호 = 인자번호 + 2.
            }
            아니면 {
                인자번호++다.
            }
        }
        정수 결과는 글컴파일(소스파일, 출력이름, 0).
        결과 == 0이면 {
            출력이름 != 0이면 {
                파일에_쓰기(표준오류, "빌드 완료: %s\n", 출력이름).
            }
            아니면 {
                문자열 기본이름은 기본이름추출(소스파일).
                파일에_쓰기(표준오류, "빌드 완료: %s.exe\n", 기본이름).
                해제(기본이름).
            }
        }
        반환.
    }

    (* 알 수 없는 명령 *)
    파일에_쓰기(표준오류, "알 수 없는 명령: %s\n", 명령).
    도움말출력().
}
