(*
 * 묶음 + 배열 테스트 - 자체 호스팅 4단계
 * 개별 배열(SoA)로 토큰 버퍼 관리 패턴 검증
 *)

포함 "표준/입출력.글"
포함 "표준/문자열.글"

(* 토큰 데이터를 개별 배열로 관리 *)
정수[50] 종류배열.
정수[50] 위치배열.
정수[50] 값배열.
정수 항목수.

(* 항목 추가 *)
[정수 종류를 정수 위치를 정수 값을 항목넣기]는 {
    항목수 < 50이면 {
        종류배열[항목수] = 종류.
        위치배열[항목수] = 위치.
        값배열[항목수] = 값.
        항목수++다.
    }
}

(* 렉서 상태 *)
문자열 원본.
정수 읽기위치.
정수 입력크기.

[문자열 소스를 렉싱시작]은 {
    원본 = 소스.
    읽기위치 = 0.
    입력크기 = strlen(소스).
    항목수 = 0.
}

(* 간단한 렉서 *)
[렉싱하기]는 {
    (읽기위치 < 입력크기)동안 {
        정수 지금 = 원본[읽기위치].

        (* 공백 *)
        지금 == 32이면 {
            읽기위치++다.
        } 아니면 {
            (* 숫자 *)
            (지금 >= 48) * (지금 <= 57)이면 {
                정수 시작 = 읽기위치.
                정수 합계 = 0.
                (읽기위치 < 입력크기)동안 {
                    정수 코드 = 원본[읽기위치].
                    코드 < 48이면 { 탈출. }
                    코드 > 57이면 { 탈출. }
                    합계 = 합계 * 10 + (코드 - 48).
                    읽기위치++다.
                }
                1을 시작을 합계를 항목넣기다.
            } 아니면 {
                (* 연산자 *)
                지금 == 43이면 { 2를 읽기위치를 0을 항목넣기다. }
                지금 == 45이면 { 3을 읽기위치를 0을 항목넣기다. }
                지금 == 42이면 { 4를 읽기위치를 0을 항목넣기다. }
                지금 == 47이면 { 5를 읽기위치를 0을 항목넣기다. }
                읽기위치++다.
            }
        }
    }
}

(* 결과 출력 *)
[결과보기]는 {
    "토큰 %d개:\n"를 항목수를 쓰기다.
    정수 번호 = 0.
    (번호 < 항목수)동안 {
        정수 종류 = 종류배열[번호].
        정수 위치 = 위치배열[번호].
        정수 값 = 값배열[번호].
        종류 == 1이면 {
            "  [숫자] 위치=%d 값=%d\n"를 위치를 값을 쓰기다.
        } 아니면 {
            종류 == 2이면 { "  [+] 위치=%d\n"를 위치를 쓰기다. }
            종류 == 3이면 { "  [-] 위치=%d\n"를 위치를 쓰기다. }
            종류 == 4이면 { "  [*] 위치=%d\n"를 위치를 쓰기다. }
            종류 == 5이면 { "  [/] 위치=%d\n"를 위치를 쓰기다. }
        }
        번호++다.
    }
}

(* 버퍼 기반 간단 계산 (좌→우, 우선순위 무시) *)
[간단계산]은 -> 정수 {
    정수 결과 = 0.
    정수 연산 = 2.
    정수 번호 = 0.
    (번호 < 항목수)동안 {
        정수 종류 = 종류배열[번호].
        종류 == 1이면 {
            정수 값 = 값배열[번호].
            연산 == 2이면 { 결과 = 결과 + 값. }
            연산 == 3이면 { 결과 = 결과 - 값. }
            연산 == 4이면 { 결과 = 결과 * 값. }
            연산 == 5이면 { 결과 = 결과 / 값. }
        }
        (종류 >= 2) * (종류 <= 5)이면 {
            연산 = 종류.
        }
        번호++다.
    }
    반환 결과.
}

[시작하기]는 {
    "=== 묶음 배열 테스트 ===\n\n"을 쓰기다.

    (* 테스트 1: 단순 덧셈 *)
    "100 + 200 + 300"을 렉싱시작다.
    렉싱하기().
    결과보기().
    정수 결과 = 간단계산().
    "계산: %d (기대: 600)\n\n"를 결과를 쓰기다.

    (* 테스트 2: 혼합 연산 *)
    "50 - 10 + 5"를 렉싱시작다.
    렉싱하기().
    결과보기().
    결과 = 간단계산().
    "계산: %d (기대: 45)\n\n"를 결과를 쓰기다.

    (* 테스트 3: 곱셈 *)
    "3 * 7"을 렉싱시작다.
    렉싱하기().
    결과보기().
    결과 = 간단계산().
    "계산: %d (기대: 21)\n\n"를 결과를 쓰기다.

    "완료!\n"을 쓰기다.
}
