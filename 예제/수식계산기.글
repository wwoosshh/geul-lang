(*
 * 수식 계산기 - 자체 호스팅 2단계
 * 재귀 하강 파서로 사칙연산 수식을 계산
 * 우선순위: * / > + -
 *)

포함 "std.gl"


(* === 토큰 종류 === *)
(* 0=끝, 1=숫자, 2=더하기, 3=빼기, 4=곱하기, 5=나누기, 6=여는괄호, 7=닫는괄호 *)

(* === 렉서 전역 상태 === *)
문자열 원본.
정수 위치값.
정수 전체길이.
정수 종류값.
정수 숫자값.

(* 렉서 초기화 *)
[문자열 소스를 분석시작]은 {
    원본 = 소스.
    위치값 = 0.
    전체길이 = strlen(소스).
}

(* 다음 토큰 읽기 *)
[다음읽기]는 {
    (* 공백 건너뛰기 *)
    (위치값 < 전체길이)동안 {
        정수 지금 = 원본[위치값].
        지금 != 32이면 { 탈출. }
        위치값++다.
    }

    (* 끝 확인 *)
    (위치값 >= 전체길이)이면 {
        종류값 = 0.
        숫자값 = 0.
        반환.
    }

    정수 지금 = 원본[위치값].

    (* 숫자 *)
    지금 >= 48이면 {
        지금 <= 57이면 {
            정수 합계 = 0.
            (위치값 < 전체길이)동안 {
                정수 코드 = 원본[위치값].
                코드 < 48이면 { 탈출. }
                코드 > 57이면 { 탈출. }
                합계 = 합계 * 10 + (코드 - 48).
                위치값++다.
            }
            종류값 = 1.
            숫자값 = 합계.
            반환.
        }
    }

    (* 연산자와 괄호 *)
    위치값++다.
    지금 == 43이면 { 종류값 = 2. 반환. }
    지금 == 45이면 { 종류값 = 3. 반환. }
    지금 == 42이면 { 종류값 = 4. 반환. }
    지금 == 47이면 { 종류값 = 5. 반환. }
    지금 == 40이면 { 종류값 = 6. 반환. }
    지금 == 41이면 { 종류값 = 7. 반환. }

    종류값 = 9.
}

(* === 재귀 하강 파서 === *)

(* 원자값: 숫자 또는 괄호로 묶인 수식 *)
[원자파싱]은 -> 정수 {
    (* 음수 처리 *)
    종류값 == 3이면 {
        다음읽기().
        정수 값 = 원자파싱().
        반환 0 - 값.
    }

    (* 괄호 *)
    종류값 == 6이면 {
        다음읽기().
        정수 값 = 수식파싱().
        (* 닫는 괄호 소비 *)
        종류값 == 7이면 {
            다음읽기().
        }
        반환 값.
    }

    (* 숫자 *)
    정수 값 = 숫자값.
    다음읽기().
    반환 값.
}

(* 항: 곱셈/나눗셈 처리 *)
[항파싱]은 -> 정수 {
    정수 왼쪽 = 원자파싱().

    ((종류값 == 4) + (종류값 == 5))동안 {
        정수 연산 = 종류값.
        다음읽기().
        정수 오른쪽 = 원자파싱().
        연산 == 4이면 {
            왼쪽 = 왼쪽 * 오른쪽.
        } 아니면 {
            왼쪽 = 왼쪽 / 오른쪽.
        }
    }

    반환 왼쪽.
}

(* 수식: 덧셈/뺄셈 처리 *)
[수식파싱]은 -> 정수 {
    정수 왼쪽 = 항파싱().

    ((종류값 == 2) + (종류값 == 3))동안 {
        정수 연산 = 종류값.
        다음읽기().
        정수 오른쪽 = 항파싱().
        연산 == 2이면 {
            왼쪽 = 왼쪽 + 오른쪽.
        } 아니면 {
            왼쪽 = 왼쪽 - 오른쪽.
        }
    }

    반환 왼쪽.
}

(* === 테스트 함수 === *)
[문자열 수식을 테스트계산]은 {
    수식을 분석시작다.
    다음읽기().
    정수 결과 = 수식파싱().
    "\"%s\" = %d\n"를 수식을 결과를 쓰기다.
}

[시작하기]는 {
    "=== 수식 계산기 ===\n"을 쓰기다.

    "42"를 테스트계산다.
    "1 + 2"를 테스트계산다.
    "10 - 3"를 테스트계산다.
    "4 * 5"를 테스트계산다.
    "100 / 4"를 테스트계산다.
    "2 + 3 * 4"를 테스트계산다.
    "(2 + 3) * 4"를 테스트계산다.
    "10 + 20 + 30"를 테스트계산다.
    "100 - 50 + 25"를 테스트계산다.

    "\n완료!\n"을 쓰기다.
}
