(*
 * 분리 제외 사전 테스트
 * 나이, 인자, 글자 등이 올바르게 식별자로 인식되는지 확인
 *)

포함 "표준/입출력.글"

[시작하기]는 {
    정수 나이 = 25.
    정수 인자 = 3.
    정수 글자 = 65.
    정수 가로 = 100.
    정수 세로 = 200.

    "나이=%d\n"을 나이를 쓰기다.
    "인자=%d\n"을 인자를 쓰기다.
    "글자=%d\n"을 글자를 쓰기다.
    "가로=%d, 세로=%d\n"을 가로를 세로를 쓰기다.

    나이 = 나이 + 1.
    "나이+1=%d\n"을 나이를 쓰기다.
}
