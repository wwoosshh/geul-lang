포함 "표준/입출력.글"

(* 검사 패턴 테스트: 없으면/있으면 *)

[시작하기]는 {
    (* 테스트 1: 없으면 — 값이 0일 때 *)
    정수 값은 0.
    값이 없으면 {
        "테스트1 통과: 값이 없습니다\n"을 쓰기하다.
    }

    (* 테스트 2: 있으면 — 값이 0이 아닐 때 *)
    정수 존재는 42.
    존재가 있으면 {
        "테스트2 통과: 존재합니다 %d\n"을 존재를 쓰기하다.
    }

    (* 테스트 3: 없으면 with 아니면 *)
    정수 포인터는 0.
    포인터가 없으면 {
        "테스트3 통과: 포인터가 없습니다\n"을 쓰기하다.
    }
    아니면 {
        "테스트3 실패\n"을 쓰기하다.
    }

    (* 테스트 4: 있으면 with 아니면 *)
    정수 데이터는 100.
    데이터가 있으면 {
        "테스트4 통과: 데이터가 있습니다 %d\n"을 데이터를 쓰기하다.
    }
    아니면 {
        "테스트4 실패\n"을 쓰기하다.
    }

    (* 테스트 5: 없으면 — 0이 아닌 값은 통과 안함 *)
    정수 유효는 1.
    유효가 없으면 {
        "테스트5 실패\n"을 쓰기하다.
    }
    아니면 {
        "테스트5 통과: 유효값은 없으면을 통과하지 않습니다\n"을 쓰기하다.
    }

    "모든 테스트 완료\n"을 쓰기하다.
}
