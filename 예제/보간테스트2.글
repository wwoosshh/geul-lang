    "=== 보간 종합 테스트 ===\n"을 쓰다.

    (* 정수 보간 *)
    정수 나이 = 30.
    정수 점수 = 100.
    "나이: {나이}, 점수: {점수}\n"을 쓰다.

    (* 문자열 보간 *)
    문자열 이름 = "홍길동".
    문자열 도시 = "서울".
    "{이름}은 {도시}에 삽니다\n"을 쓰다.

    (* 혼합 보간 *)
    정수 인원 = 5.
    "{이름}의 팀은 {인원}명입니다\n"을 쓰다.

    (* 보간 없는 일반 출력 *)
