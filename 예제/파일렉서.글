(*
 * 파일 렉서 - 자체 호스팅 5단계
 * 파일에서 소스코드를 읽고 토큰화
 * 파일 I/O + 렉서 + 배열 버퍼 종합
 *)

포함 "표준/입출력.글"
포함 "표준/문자열.글"

(* === 토큰 버퍼 (SoA) === *)
정수[500] 종류배열.
정수[500] 시작배열.
정수[500] 크기배열.
정수 토큰수.

(* === 소스 버퍼 === *)
정수[4096] 소스버퍼.
정수 소스크기.
정수 읽기위치.

(* 종류: 0=끝, 1=숫자, 2=기호, 3=한글, 4=영문, 5=문자열, 6=주석, 7=공백 *)

(* 토큰 추가 *)
[정수 종류를 정수 시작을 정수 크기를 토큰넣기]는 {
    토큰수 < 500이면 {
        종류배열[토큰수] = 종류.
        시작배열[토큰수] = 시작.
        크기배열[토큰수] = 크기.
        토큰수++다.
    }
}

(* 소스 읽기: char 배열을 int 배열로 복사 *)
[문자열 소스를 소스읽기]는 {
    소스크기 = strlen(소스).
    정수 번호 = 0.
    (번호 < 소스크기)동안 {
        소스버퍼[번호] = 소스[번호].
        번호++다.
    }
    읽기위치 = 0.
    토큰수 = 0.
}

(* 토큰화 *)
[토큰화하기]는 {
    (읽기위치 < 소스크기)동안 {
        정수 지금 = 소스버퍼[읽기위치].

        (* 공백/줄바꿈 건너뛰기 *)
        (지금 == 32) + (지금 == 9) + (지금 == 10) + (지금 == 13)이면 {
            읽기위치++다.
        } 아니면 {

        (* 주석: (* ... *) *)
        (지금 == 40)이면 {
            (읽기위치 + 1 < 소스크기)이면 {
                소스버퍼[읽기위치 + 1] == 42이면 {
                    정수 시작 = 읽기위치.
                    읽기위치 += 2.
                    (* 닫는 *) 찾기 *)
                    (읽기위치 + 1 < 소스크기)동안 {
                        (소스버퍼[읽기위치] == 42) * (소스버퍼[읽기위치 + 1] == 41)이면 {
                            읽기위치 += 2.
                            탈출.
                        }
                        읽기위치++다.
                    }
                    6을 시작을 (읽기위치 - 시작)을 토큰넣기다.
                } 아니면 {
                    (* 그냥 여는 괄호 *)
                    2를 읽기위치를 1을 토큰넣기다.
                    읽기위치++다.
                }
            } 아니면 {
                2를 읽기위치를 1을 토큰넣기다.
                읽기위치++다.
            }
        } 아니면 {

        (* 문자열 리터럴: "..." *)
        지금 == 34이면 {
            정수 시작 = 읽기위치.
            읽기위치++다.
            (읽기위치 < 소스크기)동안 {
                소스버퍼[읽기위치] == 34이면 { 탈출. }
                (* 이스케이프: \x *)
                소스버퍼[읽기위치] == 92이면 { 읽기위치++다. }
                읽기위치++다.
            }
            읽기위치++다.
            5를 시작을 (읽기위치 - 시작)을 토큰넣기다.
        } 아니면 {

        (* 숫자 *)
        (지금 >= 48) * (지금 <= 57)이면 {
            정수 시작 = 읽기위치.
            (읽기위치 < 소스크기)동안 {
                정수 코드 = 소스버퍼[읽기위치].
                코드 < 48이면 { 탈출. }
                코드 > 57이면 { 탈출. }
                읽기위치++다.
            }
            1을 시작을 (읽기위치 - 시작)을 토큰넣기다.
        } 아니면 {

        (* 한글: UTF-8 첫 바이트 0xE0~0xEF *)
        정수 무부호 = 지금.
        지금 < 0이면 { 무부호 = 지금 + 256. }
        (무부호 >= 224) * (무부호 <= 239)이면 {
            정수 시작 = 읽기위치.
            (읽기위치 < 소스크기)동안 {
                정수 현재 = 소스버퍼[읽기위치].
                현재 < 0이면 { 현재 = 현재 + 256. }
                (현재 >= 224) * (현재 <= 239)이면 {
                    읽기위치 += 3.
                } 아니면 {
                    (* 밑줄이나 숫자도 한글 식별자에 포함 *)
                    (현재 == 95) + ((현재 >= 48) * (현재 <= 57))이면 {
                        읽기위치++다.
                    } 아니면 {
                        탈출.
                    }
                }
            }
            3을 시작을 (읽기위치 - 시작)을 토큰넣기다.
        } 아니면 {

        (* 영문 *)
        정수 대문 = (지금 >= 65) * (지금 <= 90).
        정수 소문 = (지금 >= 97) * (지금 <= 122).
        (대문 + 소문)이면 {
            정수 시작 = 읽기위치.
            (읽기위치 < 소스크기)동안 {
                정수 현재 = 소스버퍼[읽기위치].
                정수 영문 = (현재 >= 65) * (현재 <= 90) + (현재 >= 97) * (현재 <= 122).
                정수 숫자 = (현재 >= 48) * (현재 <= 57).
                정수 밑줄 = (현재 == 95).
                (영문 + 숫자 + 밑줄) == 0이면 { 탈출. }
                읽기위치++다.
            }
            4를 시작을 (읽기위치 - 시작)을 토큰넣기다.
        } 아니면 {

        (* 기호 *)
        2를 읽기위치를 1을 토큰넣기다.
        읽기위치++다.

        } } } } } }
    }
}

(* 종류 이름 *)
[정수 종류를 종류이름]은 -> 문자열 {
    종류 == 1이면 { 반환 "숫자". }
    종류 == 2이면 { 반환 "기호". }
    종류 == 3이면 { 반환 "한글". }
    종류 == 4이면 { 반환 "영문". }
    종류 == 5이면 { 반환 "문자열". }
    종류 == 6이면 { 반환 "주석". }
    반환 "모름".
}

(* 통계 출력 *)
[통계출력]은 {
    정수 한글수 = 0.
    정수 영문수 = 0.
    정수 숫자수 = 0.
    정수 기호수 = 0.
    정수 문자열수 = 0.
    정수 주석수 = 0.

    정수 번호 = 0.
    (번호 < 토큰수)동안 {
        정수 종류 = 종류배열[번호].
        종류 == 1이면 { 숫자수++다. }
        종류 == 2이면 { 기호수++다. }
        종류 == 3이면 { 한글수++다. }
        종류 == 4이면 { 영문수++다. }
        종류 == 5이면 { 문자열수++다. }
        종류 == 6이면 { 주석수++다. }
        번호++다.
    }

    "총 토큰: %d\n"를 토큰수를 쓰기다.
    "  한글:   %d\n"를 한글수를 쓰기다.
    "  영문:   %d\n"를 영문수를 쓰기다.
    "  숫자:   %d\n"를 숫자수를 쓰기다.
    "  기호:   %d\n"를 기호수를 쓰기다.
    "  문자열: %d\n"를 문자열수를 쓰기다.
    "  주석:   %d\n"를 주석수를 쓰기다.
}

[시작하기]는 {
    "=== 파일 렉서 테스트 ===\n\n"을 쓰기다.

    (* 글 소스코드 샘플 토큰화 *)
    문자열 샘플 = "(* 간단한 테스트 *)\n포함 \"표준/입출력.글\"\n\n정수 값 = 42.\n\n[시작하기]는 {\n    \"%d\\n\"를 값을 쓰기다.\n}\n".

    "입력 소스:\n%s\n"를 샘플을 쓰기다.

    샘플을 소스읽기다.
    토큰화하기().

    "--- 토큰 목록 ---\n"을 쓰기다.
    정수 번호 = 0.
    (번호 < 토큰수)동안 {
        정수 종류 = 종류배열[번호].
        문자열 이름 = 종류를 종류이름다.
        "  [%s]\n"를 이름을 쓰기다.
        번호++다.
    }

    "\n--- 통계 ---\n"을 쓰기다.
    통계출력().

    "\n완료!\n"을 쓰기다.
}
