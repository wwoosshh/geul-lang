(*
 * 간단한 수식 렉서 - 자체 호스팅 기초 테스트
 *)

포함 "표준/입출력.글"
포함 "표준/문자열.글"

(* 전역 상태 *)
문자열 원본.
정수 위치값.
정수 전체길이.
정수 종류값.
정수 숫자값.

(* 렉서 초기화 *)
[문자열 소스를 분석시작]은 {
    원본 = 소스.
    위치값 = 0.
    전체길이 = strlen(소스).
}

(* 다음 토큰 읽기 *)
[다음읽기]는 {
    (* 공백 건너뛰기 *)
    (위치값 < 전체길이)동안 {
        정수 지금 = 원본[위치값].
        지금 != 32이면 { 탈출. }
        위치값++다.
    }

    (* 끝 확인 *)
    (위치값 >= 전체길이)이면 {
        종류값 = 0.
        숫자값 = 0.
        반환.
    }

    정수 지금 = 원본[위치값].

    (* 숫자: '0'=48, '9'=57 *)
    지금 >= 48이면 {
        지금 <= 57이면 {
            정수 합계 = 0.
            (위치값 < 전체길이)동안 {
                정수 코드 = 원본[위치값].
                코드 < 48이면 { 탈출. }
                코드 > 57이면 { 탈출. }
                합계 = 합계 * 10 + (코드 - 48).
                위치값++다.
            }
            종류값 = 1.
            숫자값 = 합계.
            반환.
        }
    }

    (* 연산자 *)
    위치값++다.
    지금 == 43이면 { 종류값 = 2. 반환. }
    지금 == 45이면 { 종류값 = 3. 반환. }
    지금 == 42이면 { 종류값 = 4. 반환. }
    지금 == 47이면 { 종류값 = 5. 반환. }

    종류값 = 9.
}

[시작하기]는 {
    "=== 간단 렉서 ===\n"을 쓰기다.
    "123 + 456 * 7"를 분석시작다.

    다음읽기().
    종류값이 0보다 큰동안 {
        종류값 == 1이면 {
            "%d "를 숫자값을 쓰기다.
        } 아니면 {
            종류값 == 2이면 { "+ "를 쓰기다. }
            종류값 == 3이면 { "- "를 쓰기다. }
            종류값 == 4이면 { "* "를 쓰기다. }
            종류값 == 5이면 { "/ "를 쓰기다. }
        }
        다음읽기().
    }
    "\n완료!\n"을 쓰기다.
}
