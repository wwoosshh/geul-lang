(*
 * 토큰 처리기 - 자체 호스팅 3단계
 * 문자열에서 숫자/기호/한글단어/영문단어를 인식
 *)

포함 "표준/입출력.글"
포함 "표준/문자열.글"

(* === 전역 상태 === *)
문자열 원본.
정수 위치값.
정수 전체길이.
정수 토큰종류.
정수 토큰시작.
정수 토큰크기.
정수 토큰숫자.
정수 발견수.

(* 종류: 0=끝, 1=숫자, 2=기호, 3=한글, 4=영문, 5=문자열 *)

[문자열 소스를 처리시작]은 {
    원본 = 소스.
    위치값 = 0.
    전체길이 = strlen(소스).
    발견수 = 0.
}

(* 다음 토큰 읽기 *)
[다음토큰]은 {
    (* 공백 건너뛰기 *)
    (위치값 < 전체길이)동안 {
        정수 지금 = 원본[위치값].
        (지금 != 32) * (지금 != 9) * (지금 != 10)이면 { 탈출. }
        위치값++다.
    }

    (* 끝 확인 *)
    (위치값 >= 전체길이)이면 {
        토큰종류 = 0.
        반환.
    }

    정수 지금 = 원본[위치값].

    (* 숫자: 0=48 ~ 9=57 *)
    (지금 >= 48) * (지금 <= 57)이면 {
        토큰시작 = 위치값.
        정수 합계 = 0.
        (위치값 < 전체길이)동안 {
            정수 코드 = 원본[위치값].
            코드 < 48이면 { 탈출. }
            코드 > 57이면 { 탈출. }
            합계 = 합계 * 10 + (코드 - 48).
            위치값++다.
        }
        토큰종류 = 1.
        토큰크기 = 위치값 - 토큰시작.
        토큰숫자 = 합계.
        발견수++다.
        반환.
    }

    (* 문자열: 따옴표(34) *)
    지금 == 34이면 {
        토큰시작 = 위치값.
        위치값++다.
        (위치값 < 전체길이)동안 {
            원본[위치값] == 34이면 { 탈출. }
            위치값++다.
        }
        위치값++다.
        토큰종류 = 5.
        토큰크기 = 위치값 - 토큰시작.
        발견수++다.
        반환.
    }

    (* 한글: UTF-8 3바이트, 첫 바이트 0xE0~0xEF *)
    정수 무부호 = 지금.
    지금 < 0이면 { 무부호 = 지금 + 256. }
    (무부호 >= 224) * (무부호 <= 239)이면 {
        토큰시작 = 위치값.
        (위치값 < 전체길이)동안 {
            정수 현재 = 원본[위치값].
            현재 < 0이면 { 현재 = 현재 + 256. }
            (현재 >= 224) * (현재 <= 239)이면 {
                위치값 += 3.
            } 아니면 {
                탈출.
            }
        }
        토큰종류 = 3.
        토큰크기 = 위치값 - 토큰시작.
        발견수++다.
        반환.
    }

    (* 영문: A=65~Z=90, a=97~z=122 *)
    정수 대문여부 = (지금 >= 65) * (지금 <= 90).
    정수 소문여부 = (지금 >= 97) * (지금 <= 122).
    (대문여부 + 소문여부)이면 {
        토큰시작 = 위치값.
        (위치값 < 전체길이)동안 {
            정수 현재 = 원본[위치값].
            정수 영문 = (현재 >= 65) * (현재 <= 90) + (현재 >= 97) * (현재 <= 122).
            정수 숫자 = (현재 >= 48) * (현재 <= 57).
            정수 밑줄 = (현재 == 95).
            (영문 + 숫자 + 밑줄) == 0이면 { 탈출. }
            위치값++다.
        }
        토큰종류 = 4.
        토큰크기 = 위치값 - 토큰시작.
        발견수++다.
        반환.
    }

    (* 기호 *)
    토큰시작 = 위치값.
    토큰종류 = 2.
    토큰크기 = 1.
    위치값++다.
    발견수++다.
}

(* 토큰 텍스트 출력 *)
[토큰출력]은 {
    토큰종류 == 1이면 { "  [숫자]   "을 쓰기다. }
    토큰종류 == 2이면 { "  [기호]   "을 쓰기다. }
    토큰종류 == 3이면 { "  [한글]   "을 쓰기다. }
    토큰종류 == 4이면 { "  [영문]   "을 쓰기다. }
    토큰종류 == 5이면 { "  [문자열] "을 쓰기다. }

    정수 번호 = 0.
    (번호 < 토큰크기)동안 {
        "%c"를 원본[토큰시작 + 번호]를 쓰기다.
        번호++다.
    }
    "\n"을 쓰기다.
}

[문자열 입력을 분석하고출력]은 {
    "--- 입력: \"%s\" ---\n"를 입력을 쓰기다.
    입력을 처리시작다.
    다음토큰().
    (토큰종류 > 0)동안 {
        토큰출력().
        다음토큰().
    }
    "토큰 수: %d\n\n"를 발견수를 쓰기다.
}

[시작하기]는 {
    "=== 토큰 처리기 ===\n\n"을 쓰기다.

    "정수 값 = 42"를 분석하고출력다.
    "10 + 20 * 3"을 분석하고출력다.
    "strlen 함수"를 분석하고출력다.
    "반환 결과"를 분석하고출력다.

    "완료!\n"을 쓰기다.
}
