(* === 보드 관리 === *)

[보드초기화]는 {
    정수 번호 = 0.
    (번호 < 264)동안 {
        정수 행 = 번호 / 12.
        정수 열 = 번호 % 12.
        (* 벽: 첫열, 마지막열, 마지막행 *)
        열 == 0이면 { 보드[번호] = 1. }
        아니면 { 열 == 11이면 { 보드[번호] = 1. }
        아니면 { 행 == 21이면 { 보드[번호] = 1. }
        아니면 { 보드[번호] = 0. } } }
        번호++다.
    }
}

(* 블록이 해당 위치에 놓일 수 있는지 확인 *)
[정수 종류를 정수 회전을 정수 행위치를 정수 열위치를 놓을수있나]는 -> 정수 {
    정수 기점 = 종류 * 16 + (회전 % 2) * 4.
    정수 번호 = 0.
    (번호 < 4)동안 {
        정수 행 = 행위치 + 블록행[기점 + 번호].
        정수 열 = 열위치 + 블록열[기점 + 번호].
        행 < 0이면 { 반환 0. }
        행 >= 22이면 { 반환 0. }
        열 < 0이면 { 반환 0. }
        열 >= 12이면 { 반환 0. }
        정수 셀 = 행 * 12 + 열.
        보드[셀] != 0이면 { 반환 0. }
        번호++다.
    }
    반환 1.
}

(* 블록을 보드에 고정 *)
[고정하기]는 {
    정수 기점 = 현재블록 * 16 + (현재회전 % 2) * 4.
    정수 번호 = 0.
    (번호 < 4)동안 {
        정수 행 = 블록와이 + 블록행[기점 + 번호].
        정수 열 = 블록엑스 + 블록열[기점 + 번호].
        정수 셀 = 행 * 12 + 열.
        보드[셀] = 2.
        번호++다.
    }
}

(* 완성된 줄 제거 *)
[줄제거]는 -> 정수 {
    정수 제거수 = 0.
    정수 행 = 20.
    (행 >= 0)동안 {
        정수 꽉참 = 1.
        정수 열 = 1.
        (열 < 11)동안 {
            정수 셀 = 행 * 12 + 열.
            보드[셀] == 0이면 { 꽉참 = 0. }
            열++다.
        }
        꽉참 != 0이면 {
            (* 위의 모든 줄을 한 칸씩 내리기 *)
            정수 이동행 = 행.
            (이동행 > 0)동안 {
                열 = 1.
                (열 < 11)동안 {
                    정수 대상 = 이동행 * 12 + 열.
                    정수 원본 = (이동행 - 1) * 12 + 열.
                    보드[대상] = 보드[원본].
                    열++다.
                }
                이동행--다.
            }
            (* 맨 위 줄 비우기 *)
            열 = 1.
            (열 < 11)동안 {
                보드[열] = 0.
                열++다.
            }
            제거수++다.
        } 아니면 {
            행--다.
        }
    }
    반환 제거수.
}

(* 새 블록 생성 *)
[새블록]는 {
    현재블록 = rand() % 7.
    현재회전 = 0.
    블록와이 = 0.
    블록엑스 = 4.

    정수 가능 = 현재블록을 현재회전을 블록와이를 블록엑스를 놓을수있나하다.
    가능 == 0이면 {
        게임끝 = 1.
    }
}

(* === 화면 출력 === *)

[화면그리기]는 {
    system("cls").

    "=== TETRIS === Score: %d  Lines: %d\n"를 점수를 줄수를 쓰다.
    "  a=Left d=Right w=Rotate s=Drop q=Quit\n\n"을 쓰다.

    (* 현재 블록 위치를 임시로 보드에 표시 *)
    정수 기점 = 현재블록 * 16 + (현재회전 % 2) * 4.
    정수[4] 블록셀.
    정수 번호 = 0.
    (번호 < 4)동안 {
        정수 행 = 블록와이 + 블록행[기점 + 번호].
        정수 열 = 블록엑스 + 블록열[기점 + 번호].
        블록셀[번호] = 행 * 12 + 열.
        번호++다.
    }

    (* 보드 출력 *)
    정수 행 = 0.
    (행 < 22)동안 {
        정수 열 = 0.
        (열 < 12)동안 {
            정수 셀 = 행 * 12 + 열.
            정수 활성 = 0.

            (* 현재 블록인지 확인 *)
            번호 = 0.
            (번호 < 4)동안 {
                블록셀[번호] == 셀이면 { 활성 = 1. }
                번호++다.
            }

            보드[셀] == 1이면 {
                putchar(35).   (* # 벽 *)
            } 아니면 {
                보드[셀] == 2이면 {
                    putchar(79). (* O 고정블록 *)
                } 아니면 {
                    활성 != 0이면 {
                        putchar(64). (* @ 현재블록 *)
                    } 아니면 {
                        putchar(46). (* . 빈칸 *)
                    }
                }
            }
            열++다.
        }
        putchar(10).
        행++다.
    }
}

(* === 게임 루프 === *)

[시작하기]는 -> 정수 {
    srand(42).
    블록정의초기화().
    보드초기화().
    점수 = 0.
    줄수 = 0.
    게임끝 = 0.

    새블록().

    정수 턴 = 0.

    (턴 < 60)동안 {
        게임끝 != 0이면 { 탈출. }
        (* 매 턴 진행 표시 *)
        "."을 쓰다.

        (* 자동 시뮬레이션: 간단한 AI *)
        (* 홀수 턴: 왼쪽, 짝수 턴: 오른쪽, 매 5턴: 회전 *)
        정수 동작 = 턴 % 6.

        동작 == 0이면 {
            (* 왼쪽 이동 *)
            정수 가능 = 현재블록을 현재회전을 블록와이를 (블록엑스 - 1)을 놓을수있나하다.
            가능 != 0이면 { 블록엑스--다. }
        }
        동작 == 2이면 {
            (* 오른쪽 이동 *)
            정수 가능 = 현재블록을 현재회전을 블록와이를 (블록엑스 + 1)을 놓을수있나하다.
            가능 != 0이면 { 블록엑스++다. }
        }
        동작 == 4이면 {
            (* 회전 *)
            정수 새회전 = 현재회전 + 1.
            정수 가능 = 현재블록을 새회전을 블록와이를 블록엑스를 놓을수있나하다.
            가능 != 0이면 { 현재회전 = 새회전. }
        }

        (* 자동 낙하 *)
        정수 다음행 = 블록와이 + 1.
        정수 낙하가능 = 현재블록을 현재회전을 다음행을 블록엑스를 놓을수있나하다.
        낙하가능 != 0이면 {
            블록와이++다.
        } 아니면 {
            (* 고정 *)
            고정하기().
            정수 제거 = 줄제거().
            줄수 = 줄수 + 제거.
            점수 = 점수 + 제거 * 100 + 10.
            새블록().
        }

        턴++다.
    }

    화면그리기().
    "\nGame Over! Score: %d Lines: %d Turns: %d\n"를 점수를 줄수를 턴을 쓰다.
    반환 0.
}
