(*
 * 마크다운 → HTML 변환기
 * # 제목, **굵게**, *기울임*, `코드`, - 목록, > 인용, 링크
 *)

포함 "std.gl"

외부 [공허 참조 스트림을 feof]는 -> 정수.

(* === 출력 버퍼 === *)
문자[65536] 출력칸.
정수 출력위치.

[정수 코드를 출력넣기]는 {
    출력위치 < 65535이면 {
        출력칸[출력위치] = 코드.
        출력위치++다.
    }
}

[문자열 문장을 출력문장]는 {
    정수 번호 = 0.
    (문장[번호] != 0)동안 {
        문장[번호]를 출력넣기하다.
        번호++다.
    }
}

(* HTML 특수문자 이스케이프 *)
[정수 코드를 안전출력]는 {
    코드 == 60이면 { "&lt;"를 출력문장하다. 반환. }
    코드 == 62이면 { "&gt;"를 출력문장하다. 반환. }
    코드 == 38이면 { "&amp;"를 출력문장하다. 반환. }
    코드를 출력넣기하다.
}

(* === 인라인 파싱 === *)
(* 한 줄 내의 **굵게**, *기울임*, `코드`, [링크](url) 처리 *)

[문자열 줄에서 정수 시작을 인라인처리]는 {
    정수 번호 = 시작.
    (줄[번호] != 0)동안 {
        줄[번호] == 10이면 { 탈출. }
        줄[번호] == 13이면 { 탈출. }

        (* **굵게** *)
        줄[번호] == 42이면 {
            줄[번호 + 1] == 42이면 {
                (* 닫는 ** 찾기 *)
                정수 끝 = 번호 + 2.
                (줄[끝] != 0)동안 {
                    줄[끝] == 42이면 {
                        줄[끝 + 1] == 42이면 { 탈출. }
                    }
                    끝++다.
                }
                줄[끝] == 42이면 {
                    "<strong>"를 출력문장하다.
                    정수 안쪽 = 번호 + 2.
                    (안쪽 < 끝)동안 {
                        줄[안쪽]를 안전출력하다.
                        안쪽++다.
                    }
                    "</strong>"를 출력문장하다.
                    번호 = 끝 + 2.
                    계속.
                }
            }
        }

        (* *기울임* *)
        줄[번호] == 42이면 {
            정수 끝 = 번호 + 1.
            (줄[끝] != 0)동안 {
                줄[끝] == 42이면 { 탈출. }
                끝++다.
            }
            줄[끝] == 42이면 {
                "<em>"를 출력문장하다.
                정수 안쪽 = 번호 + 1.
                (안쪽 < 끝)동안 {
                    줄[안쪽]를 안전출력하다.
                    안쪽++다.
                }
                "</em>"를 출력문장하다.
                번호 = 끝 + 1.
                계속.
            }
        }

        (* `코드` *)
        줄[번호] == 96이면 {
            정수 끝 = 번호 + 1.
            (줄[끝] != 0)동안 {
                줄[끝] == 96이면 { 탈출. }
                끝++다.
            }
            줄[끝] == 96이면 {
                "<code>"를 출력문장하다.
                정수 안쪽 = 번호 + 1.
                (안쪽 < 끝)동안 {
                    줄[안쪽]를 안전출력하다.
                    안쪽++다.
                }
                "</code>"를 출력문장하다.
                번호 = 끝 + 1.
                계속.
            }
        }

        (* [텍스트](url) 링크 *)
        줄[번호] == 91이면 {
            (* ] 찾기 *)
            정수 괄호끝 = 번호 + 1.
            (줄[괄호끝] != 0)동안 {
                줄[괄호끝] == 93이면 { 탈출. }
                괄호끝++다.
            }
            줄[괄호끝] == 93이면 {
                줄[괄호끝 + 1] == 40이면 {
                    (* ( 뒤의 ) 찾기 *)
                    정수 주소끝 = 괄호끝 + 2.
                    (줄[주소끝] != 0)동안 {
                        줄[주소끝] == 41이면 { 탈출. }
                        주소끝++다.
                    }
                    줄[주소끝] == 41이면 {
                        "<a href=\""를 출력문장하다.
                        정수 안쪽 = 괄호끝 + 2.
                        (안쪽 < 주소끝)동안 {
                            줄[안쪽]를 출력넣기하다.
                            안쪽++다.
                        }
                        "\">"를 출력문장하다.
                        안쪽 = 번호 + 1.
                        (안쪽 < 괄호끝)동안 {
                            줄[안쪽]를 안전출력하다.
                            안쪽++다.
                        }
                        "</a>"를 출력문장하다.
                        번호 = 주소끝 + 1.
                        계속.
                    }
                }
            }
        }

        (* 일반 문자 *)
        줄[번호]를 안전출력하다.
        번호++다.
    }
}

(* === 줄 단위 파싱 === *)

정수 목록중.
정수 코드블록중.

[문자열 줄을 블록파싱]는 {
    정수 길이 = 글자수(줄).

    (* 코드 블록 ``` *)
    줄[0] == 96이면 {
        줄[1] == 96이면 {
            줄[2] == 96이면 {
                코드블록중 == 0이면 {
                    코드블록중 = 1.
                    "<pre><code>"를 출력문장하다.
                    반환.
                } 아니면 {
                    코드블록중 = 0.
                    "</code></pre>\n"를 출력문장하다.
                    반환.
                }
            }
        }
    }

    (* 코드 블록 안이면 그대로 출력 *)
    코드블록중 != 0이면 {
        정수 번호 = 0.
        (줄[번호] != 0)동안 {
            줄[번호] == 10이면 { 탈출. }
            줄[번호] == 13이면 { 탈출. }
            줄[번호]를 안전출력하다.
            번호++다.
        }
        정수 줄바꿈 = 10.
        줄바꿈을 출력넣기하다.
        반환.
    }

    (* 빈 줄 — 목록 종료 *)
    줄[0] == 10이면 {
        목록중 != 0이면 {
            "</ul>\n"를 출력문장하다.
            목록중 = 0.
        }
        반환.
    }
    줄[0] == 13이면 {
        줄[1] == 10이면 {
            목록중 != 0이면 {
                "</ul>\n"를 출력문장하다.
                목록중 = 0.
            }
            반환.
        }
    }

    (* # 제목 *)
    줄[0] == 35이면 {
        정수 수준 = 0.
        (줄[수준] == 35)동안 { 수준++다. }
        수준 > 6이면 { 수준 = 6. }
        줄[수준] == 32이면 {
            목록중 != 0이면 { "</ul>\n"를 출력문장하다. 목록중 = 0. }
            "<h"를 출력문장하다.
            정수 코드 = 48 + 수준.
            코드를 출력넣기하다.
            ">"를 출력문장하다.
            정수 내용점 = 수준 + 1.
            줄에서 내용점을 인라인처리하다.
            "</h"를 출력문장하다.
            코드를 출력넣기하다.
            ">\n"를 출력문장하다.
            반환.
        }
    }

    (* > 인용 *)
    줄[0] == 62이면 {
        목록중 != 0이면 { "</ul>\n"를 출력문장하다. 목록중 = 0. }
        "<blockquote><p>"를 출력문장하다.
        정수 내용점 = 1.
        줄[1] == 32이면 { 내용점 = 2. }
        줄에서 내용점을 인라인처리하다.
        "</p></blockquote>\n"를 출력문장하다.
        반환.
    }

    (* - 목록 *)
    줄[0] == 45이면 {
        줄[1] == 32이면 {
            목록중 == 0이면 {
                "<ul>\n"를 출력문장하다.
                목록중 = 1.
            }
            "<li>"를 출력문장하다.
            줄에서 2를 인라인처리하다.
            "</li>\n"를 출력문장하다.
            반환.
        }
    }

    (* --- 수평선 *)
    줄[0] == 45이면 {
        줄[1] == 45이면 {
            줄[2] == 45이면 {
                목록중 != 0이면 { "</ul>\n"를 출력문장하다. 목록중 = 0. }
                "<hr>\n"를 출력문장하다.
                반환.
            }
        }
    }

    (* 일반 단락 *)
    목록중 != 0이면 { "</ul>\n"를 출력문장하다. 목록중 = 0. }
    "<p>"를 출력문장하다.
    줄에서 0을 인라인처리하다.
    "</p>\n"를 출력문장하다.
}

(* === API === *)

[문자열 입력경로를 문자열 출력경로를 변환하기]는 -> 정수 {
    공허 참조 입력 = 파일_열기(입력경로, "r").
    입력 == 0이면 {
        "오류: %s 열기 실패\n"를 입력경로를 쓰다.
        반환 -1.
    }

    출력위치 = 0.
    목록중 = 0.
    코드블록중 = 0.

    "<!DOCTYPE html>\n<html><head><meta charset=\"utf-8\"><title>Document</title></head>\n<body>\n"를 출력문장하다.

    문자[1024] 줄칸.
    (feof(입력) == 0)동안 {
        문자열 결과 = 줄_읽기(줄칸, 1024, 입력).
        결과 == 0이면 { 탈출. }
        줄칸을 블록파싱하다.
    }

    (* 열린 태그 닫기 *)
    목록중 != 0이면 { "</ul>\n"를 출력문장하다. }
    코드블록중 != 0이면 { "</code></pre>\n"를 출력문장하다. }

    "</body>\n</html>\n"를 출력문장하다.
    출력칸[출력위치] = 0.

    파일_닫기(입력).

    (* 출력 파일 쓰기 *)
    공허 참조 출력 = 파일_열기(출력경로, "w").
    출력 == 0이면 {
        "오류: %s 쓰기 실패\n"를 출력경로를 쓰다.
        반환 -1.
    }
    파일_글넣기(출력칸, 출력).
    파일_닫기(출력).
    반환 0.
}

(* === 테스트 === *)

[시작하기]는 -> 정수 {
    "=== Markdown -> HTML Converter ===\n"을 쓰다.

    (* 테스트 마크다운 파일 생성 *)
    공허 참조 작성 = 파일_열기("test.md", "w").
    작성 == 0이면 { 반환 1. }
    파일_글넣기("# Hello World\n\n", 작성).
    파일_글넣기("## Sub Heading\n\n", 작성).
    파일_글넣기("This is **bold** and *italic* text.\n\n", 작성).
    파일_글넣기("Here is `inline code` example.\n\n", 작성).
    파일_글넣기("Visit [Google](https://google.com) for search.\n\n", 작성).
    파일_글넣기("> This is a blockquote.\n\n", 작성).
    파일_글넣기("- First item\n", 작성).
    파일_글넣기("- Second item\n", 작성).
    파일_글넣기("- Third item\n\n", 작성).
    파일_글넣기("---\n\n", 작성).
    파일_글넣기("```\nfunction hello() {\n  return 42;\n}\n```\n\n", 작성).
    파일_글넣기("### Features\n\n", 작성).
    파일_글넣기("Simple & clean **HTML** output with <special> chars.\n", 작성).
    파일_닫기(작성).
    "test.md 생성 완료\n"을 쓰다.

    (* 변환 *)
    정수 결과 = "test.md"를 "test.html"을 변환하다.
    결과 == 0이면 {
        "test.html 변환 완료\n"을 쓰다.
    } 아니면 {
        "변환 실패\n"을 쓰다.
        반환 1.
    }

    (* 결과 출력 *)
    공허 참조 확인 = 파일_열기("test.html", "r").
    확인 != 0이면 {
        "\n--- 생성된 HTML ---\n"을 쓰다.
        문자[256] 읽기칸.
        (feof(확인) == 0)동안 {
            문자열 결과2 = 줄_읽기(읽기칸, 256, 확인).
            결과2 == 0이면 { 탈출. }
            "%s"를 읽기칸을 쓰다.
        }
        파일_닫기(확인).
        "--- 끝 ---\n"을 쓰다.
    }

    "=== 완료 ===\n"을 쓰다.
    반환 0.
}
